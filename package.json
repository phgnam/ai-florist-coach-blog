{
  "name": "vuon-hoa-blog",
  "version": "1.0.0",
  "description": "Static blog about flowers built with Astro, MDX, TailwindCSS v4, and Pagefind.",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0 --port 5000",
    "build": "astro build && pagefind --site dist",
    "build:astro": "astro build",
    "build:search": "pagefind --site dist",
    "preview": "astro preview --host 0.0.0.0 --port 5000"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/typography": "^0.5.19",
    "astro": "^6.2.1",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.13",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "pagefind": "^1.5.2"
  },
  "overrides": {
    "vite": "^7"
  }
}
