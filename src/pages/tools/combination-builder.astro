  gardenia: [
    { name:"The White Garden",       partners:['magnolia','jasmine'],  why:"The most fragrant white combination in floristry — magnolia's star, gardenia's waxy rosette, jasmine's trailing stars. Each flower is individually extraordinary; together they create an arrangement that fills the entire room with scent.", colors:"White · Ivory · Cream",           style:"Minimal / Fragrant", season:"Spring–Summer" },
    { name:"Tropical White",         partners:['orchid','lily'],       why:"Three dramatic architectural whites — lily provides height and grandeur, orchid provides graphic line and exotic detail, gardenia provides extraordinary fragrance. The arrangement of high-end venues and destination weddings.",             colors:"White · Ivory · Green",             style:"Luxury / Exotic",    season:"Summer" },
    { name:"Wedding White",          partners:['rose','sweet-pea'],    why:"A classic bridal palette — gardenia's waxy perfection and intense fragrance alongside rose and sweet pea's softness. Gardenia has been a wedding flower for centuries; this combination explains why.",                                     colors:"White · Blush · Cream",             style:"Wedding / Romantic", season:"Spring–Summer" },
    { name:"Fragrant Classic",       partners:['carnation','freesia'], why:"Three long-lasting, fragrant white flowers — a reliable combination for long-display arrangements. Gardenia anchors with fragrance; freesia adds movement; carnation extends vase life to 2+ weeks.",                                       colors:"White · Cream · Yellow",            style:"Classic / Reliable", season:"Year-round" },
  ],
  jasmine: [
    { name:"Fragrant Garden",        partners:['gardenia','magnolia'], why:"Three whites defined by their scent — jasmine trails below the larger gardenia and magnolia heads, creating a layered, cascading arrangement. One of the most extraordinary fragrance combinations in the floral world.",                  colors:"White · Ivory · Cream",             style:"Minimal / Fragrant", season:"Spring–Summer" },
    { name:"Scent Bouquet",          partners:['freesia','sweet-pea'], why:"Three of the most fragrant small-flowered stems combined — layers of scent from complementary plants. This bouquet is as much for the nose as the eye. A favourite for ceremonies where the fragrance should be noticed.",                 colors:"White · Cream · Lavender",          style:"Fragrant / Delicate",season:"Spring" },
    { name:"French Perfumery",       partners:['rose','lavender'],     why:"The building blocks of French perfume — jasmine and rose are the classic scent pairing of the perfume industry. Lavender adds an herbal note and a contrasting purple tone. A deeply romantic and fragrant trio.",                        colors:"White · Pink · Purple",             style:"Romantic / Fragrant",season:"Summer" },
    { name:"Tropical Delight",       partners:['orchid','lily'],       why:"Jasmine vines weave around architectural orchid stems and tall lilies — a tropical garden feel. The jasmine's intense fragrance transforms an already beautiful combination into something otherworldly.",                                  colors:"White · Ivory · Green",             style:"Tropical / Exotic",  season:"Summer" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type":"Question", "name":"What flowers go well with roses?",
      "acceptedAnswer":{ "@type":"Answer", "text":"Roses pair beautifully with peonies and hydrangea for a lush romantic look; lavender and freesia for a Provençal fragrant combination; dahlias and anemones for dramatic autumn arrangements; or gardenias and magnolias for a minimal all-white composition." } },
    { "@type":"Question", "name":"What flowers pair well with peonies?",
      "acceptedAnswer":{ "@type":"Answer", "text":"Peonies pair best with roses and ranunculus for a full-petaled luxury arrangement; sweet peas and anemones for a whimsical cottage feel; magnolias and irises for a Japanese-inspired elegant combination; or hydrangeas and tulips for a classic garden party look." } },
    { "@type":"Question", "name":"What flowers go well with sunflowers?",
      "acceptedAnswer":{ "@type":"Answer", "text":"Sunflowers pair perfectly with marigolds and chrysanthemums for an autumn harvest arrangement; lavender and freesia for a Provençal summer combination; hydrangeas and roses for a garden party feel; or dahlias and carnations for warm autumn tones." } },
    { "@type":"Question", "name":"What flowers complement lavender?",
      "acceptedAnswer":{ "@type":"Answer", "text":"Lavender pairs beautifully with roses and freesia for a classic French romantic fragrant bouquet; sweet peas and ranunculus for a Provence meadow look; irises and tulips for a Dutch bulb-field combination; or jasmine and gardenia for an intensely fragrant white-and-purple arrangement." } },
    { "@type":"Question", "name":"What is a good flower combination for a wedding bouquet?",
      "acceptedAnswer":{ "@type":"Answer", "text":"Classic wedding combinations include: roses + peonies + hydrangea for lush romantic; lily + orchid + gardenia for luxury minimal; sweet pea + rose + hydrangea for English garden; or peony + ranunculus + sweet pea for an intimate spring bouquet. Choose flowers in season for the best quality and value." } },
    { "@type":"Question", "name":"Which flowers look good together?",
      "acceptedAnswer":{ "@type":"Answer", "text":"Flowers pair well when they share complementary colours, compatible seasons, and contrasting forms (one round, one spiky, one trailing). Classic principles: full-headed flowers (rose, peony, dahlia) alongside filler flowers (carnation, freesia) and structural flowers (iris, lily). Use this combination suggester to find specific pairings for your hero flower." } },
    { "@type":"Question", "name":"What flowers pair with dahlias?",
      "acceptedAnswer":{ "@type":"Answer", "text":"Dahlias pair spectacularly with roses and anemones for an autumn jewel palette; sunflowers and marigolds for a warm harvest arrangement; ranunculus and hydrangea for a lush garden combination; or chrysanthemums and carnations for a long-lasting classic autumn bouquet." } },
    { "@type":"Question", "name":"What flowers go well with orchids?",
      "acceptedAnswer":{ "@type":"Answer", "text":"Orchids pair best with lilies and gardenias for tropical luxury; magnolias and jasmine for an Asian-garden aesthetic; irises and carnations for a modern structured arrangement; or anemones and sweet peas for a surprisingly soft and romantic combination." } },
  ]
};

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Flower Combination Suggester",
  "description": "Free tool to find which flowers pair well together — get curated combination suggestions for any hero flower, with colour stories, style notes, and seasonal availability.",
  "applicationCategory": "LifestyleApplication",
  "operatingSystem": "Web",
  "url": `${siteUrl}/tools/combination-builder/`,
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "inLanguage": "en",
};
---
<BaseLayout
  lang={lang}
  title="Flower Combination Suggester — What Flowers Go Well Together?"
  description="Find the perfect flower pairings: pick any flower and get 4 curated combinations with colour stories, style notes, and seasonal guides. Covers all 20 flowers — roses, peonies, dahlias, sunflowers and more."
  hreflang={hreflang}
  breadcrumbs={breadcrumbs}
>
  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />

  <nav class="breadcrumb-nav" aria-label="Breadcrumb" data-pagefind-ignore>
    <div class="max-w-6xl mx-auto px-6 py-4">
      <ol class="breadcrumb-list">
        <li><a href="/">Home</a></li><li aria-hidden="true">›</li>
        <li><a href="/tools/">Tools</a></li><li aria-hidden="true">›</li>
        <li aria-current="page">Flower Combination Suggester</li>
      </ol>
    </div>
  </nav>

  <article data-pagefind-body>
  <PagefindMeta kind="tool" description="Pick any hero flower and get curated pairings — colour stories, style notes, and seasonal guides." tags={["tool","combinations","arrangement"]} />

  <div class="page-header">
    <div class="max-w-4xl mx-auto px-6 py-20 text-center" style="position:relative;z-index:2">
      <p class="page-eyebrow">Free Florist Tool</p>
      <h1 class="page-title">Flower Combination Suggester</h1>
      <p class="page-sub">Pick your hero flower and discover which flowers pair with it — with colour stories, style notes, and seasonal availability for each combination.</p>
      <a href="/vi/tools/combination-builder/" class="lang-switch-link">🇻🇳 Xem bằng tiếng Việt</a>
    </div>
  </div>

  <div class="tool-wrap">
    <div class="max-w-6xl mx-auto px-4 lg:px-6 py-12">

      <div class="picker-section">
        <h2 class="picker-heading">Choose your hero flower</h2>
        <p class="picker-sub">Select the flower you want to build around:</p>
        <div class="flower-grid" id="flowerGrid">
          {FLOWERS.map(f => (
            <button class="flower-btn" data-id={f.id}>
              <span class="fb-emoji">{f.emoji}</span>
              <span class="fb-name">{f.name}</span>
            </button>
          ))}
        </div>
      </div>

      <div class="results-section" id="resultsSection" hidden>
        <div class="results-intro" id="resultsIntro"></div>
        <div class="combos-grid" id="combosGrid"></div>
        <div class="results-cta" id="resultsCta"></div>
      </div>

      <div class="faq-outer">
        <h2 class="faq-title">Flower Pairing FAQ</h2>
        <div class="faq-list">
          {faqSchema.mainEntity.map(item => (
            <div class="faq-item">
              <button class="faq-q"><span>{item.name}</span><span class="faq-icon">+</span></button>
              <div class="faq-a" hidden><p>{item.acceptedAnswer.text}</p></div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
  </article>
</BaseLayout>

<style>
  .breadcrumb-nav { background:var(--ivory); border-bottom:1px solid var(--ivory-dark); }
  .breadcrumb-list { display:flex; align-items:center; gap:0.5rem; list-style:none; padding:0; margin:0; font-family:'Jost',sans-serif; font-size:0.8rem; color:var(--taupe); flex-wrap:wrap; }
  .breadcrumb-list a { color:var(--blush-dark); text-decoration:none; }
  .page-header { background:linear-gradient(160deg,#FDF0F2 0%,#F5E6EA 50%,#EDA8B8 100%); position:relative; overflow:hidden; }
  .page-header::after { content:''; position:absolute; bottom:-1px; left:0; right:0; height:80px; background:linear-gradient(to top,var(--ivory),transparent); }
  .page-eyebrow { font-family:'Jost',sans-serif; font-size:0.68rem; font-weight:500; letter-spacing:0.3em; text-transform:uppercase; color:var(--gold); margin-bottom:1rem; }
  .page-title { font-family:'Cormorant Garamond',Georgia,serif; font-size:clamp(2.2rem,5.5vw,4rem); font-weight:300; color:var(--mauve); line-height:1.1; margin:0 0 1.2rem; }
  .page-sub { font-family:'Jost',sans-serif; color:var(--mauve-mid); font-size:1rem; font-weight:300; max-width:560px; margin:0 auto 1.25rem; line-height:1.75; }
  .lang-switch-link { display:inline-block; font-family:'Jost',sans-serif; font-size:0.78rem; color:var(--mauve-mid); text-decoration:none; border:1px solid rgba(74,45,53,0.2); padding:0.3rem 1rem; border-radius:999px; transition:all 0.2s; }
  .lang-switch-link:hover { color:var(--mauve); border-color:var(--mauve); }
  .tool-wrap { background:var(--ivory); }
  .picker-section { background:white; border:1px solid var(--ivory-dark); border-radius:20px; padding:2rem; margin-bottom:1.5rem; }
  .picker-heading { font-family:'Cormorant Garamond',serif; font-size:1.5rem; font-weight:600; color:var(--mauve); margin:0 0 0.3rem; }
  .picker-sub { font-family:'Jost',sans-serif; font-size:0.84rem; color:var(--taupe); font-weight:300; margin:0 0 1.5rem; }
  .flower-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(90px,1fr)); gap:0.5rem; }
  .flower-btn { display:flex; flex-direction:column; align-items:center; gap:0.25rem; padding:0.75rem 0.5rem; border:1.5px solid var(--ivory-dark); border-radius:12px; background:var(--ivory); cursor:pointer; transition:all 0.18s; }
  .flower-btn:hover { border-color:var(--blush); background:rgba(232,164,176,0.08); transform:translateY(-1px); }
  .flower-btn.active { border-color:var(--blush-dark); background:rgba(196,122,138,0.12); box-shadow:0 0 0 3px rgba(196,122,138,0.15); }
  .fb-emoji { font-size:1.6rem; }
  .fb-name { font-family:'Jost',sans-serif; font-size:0.68rem; font-weight:500; color:var(--mauve); text-align:center; }
  .results-section { animation:fadeUp 0.4s ease; }
  @keyframes fadeUp { from { opacity:0; transform:translateY(12px); } to { opacity:1; transform:translateY(0); } }
  .results-intro { margin-bottom:1.5rem; }
  .ri-title { font-family:'Cormorant Garamond',serif; font-size:1.7rem; font-weight:300; color:var(--mauve); margin:0 0 0.3rem; }
  .ri-sub { font-family:'Jost',sans-serif; font-size:0.85rem; color:var(--taupe); font-weight:300; margin:0; }
  .combos-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:1.25rem; margin-bottom:1.5rem; }
  .combo-card { background:white; border:1px solid var(--ivory-dark); border-radius:20px; padding:1.75rem; transition:all 0.22s; }
  .combo-card:hover { border-color:var(--blush); box-shadow:0 6px 24px rgba(196,122,138,0.1); transform:translateY(-2px); }
  .cc-number { font-family:'Jost',sans-serif; font-size:0.65rem; font-weight:600; letter-spacing:0.2em; text-transform:uppercase; color:var(--blush-dark); margin-bottom:0.5rem; }
  .cc-name { font-family:'Cormorant Garamond',serif; font-size:1.35rem; font-weight:600; color:var(--mauve); margin:0 0 1rem; }
  .cc-partners { display:flex; gap:0.5rem; margin-bottom:1rem; flex-wrap:wrap; }
  .cc-partner { display:flex; align-items:center; gap:0.4rem; background:rgba(232,164,176,0.1); border:1px solid rgba(196,122,138,0.25); border-radius:999px; padding:0.3rem 0.75rem; text-decoration:none; transition:all 0.18s; }
  .cc-partner:hover { background:rgba(196,122,138,0.15); border-color:var(--blush-dark); }
  .cc-p-emoji { font-size:0.95rem; }
  .cc-p-name { font-family:'Jost',sans-serif; font-size:0.75rem; font-weight:500; color:var(--mauve); }
  .cc-why { font-family:'Jost',sans-serif; font-size:0.83rem; color:var(--text-mid); line-height:1.8; font-weight:300; margin-bottom:1.1rem; }
  .cc-meta { display:flex; flex-direction:column; gap:0.4rem; }
  .cc-colors { display:flex; align-items:center; gap:0.5rem; }
  .cc-colors-dot { width:8px; height:8px; border-radius:50%; background:linear-gradient(135deg,var(--blush) 0%,var(--gold) 100%); flex-shrink:0; }
  .cc-colors-text { font-family:'Jost',sans-serif; font-size:0.75rem; color:var(--taupe); font-style:italic; }
  .cc-badges { display:flex; gap:0.4rem; flex-wrap:wrap; margin-top:0.2rem; }
  .cc-badge { font-family:'Jost',sans-serif; font-size:0.65rem; font-weight:500; letter-spacing:0.06em; padding:0.2rem 0.6rem; border-radius:999px; }
  .cc-badge-style { background:rgba(232,164,176,0.2); color:var(--blush-dark); }
  .cc-badge-season { background:rgba(200,149,106,0.12); color:var(--gold); }
  .results-cta { text-align:center; padding:1.5rem; background:white; border:1px solid var(--ivory-dark); border-radius:16px; margin-bottom:1.5rem; }
  .rc-text { font-family:'Jost',sans-serif; font-size:0.85rem; color:var(--taupe); font-weight:300; margin:0 0 0.75rem; }
  .rc-link { font-family:'Jost',sans-serif; font-size:0.82rem; font-weight:500; color:var(--blush-dark); text-decoration:none; border:1.5px solid var(--blush); padding:0.5rem 1.25rem; border-radius:10px; display:inline-block; transition:all 0.2s; }
  .rc-link:hover { background:var(--blush-dark); color:white; }
  .faq-outer { margin-top:3rem; }
  .faq-title { font-family:'Cormorant Garamond',serif; font-size:clamp(1.5rem,3vw,2.2rem); font-weight:300; color:var(--mauve); margin:0 0 1.5rem; }
  .faq-list { display:grid; grid-template-columns:1fr; gap:0.6rem; }
  @media (min-width:900px) { .faq-list { grid-template-columns:1fr 1fr; } }
  .faq-item { background:white; border:1px solid var(--ivory-dark); border-radius:12px; overflow:hidden; }
  .faq-item.open { border-color:var(--blush); }
  .faq-q { width:100%; display:flex; align-items:center; justify-content:space-between; gap:1rem; padding:0.9rem 1.2rem; background:none; border:none; cursor:pointer; font-family:'Jost',sans-serif; font-size:0.88rem; font-weight:500; color:var(--mauve); text-align:left; }
  .faq-icon { font-size:1.1rem; color:var(--blush-dark); flex-shrink:0; transition:transform 0.2s; }
  .faq-item.open .faq-icon { transform:rotate(45deg); }
  .faq-a { padding:0 1.2rem 0.9rem; }
  .faq-a p { font-family:'Jost',sans-serif; font-size:0.85rem; color:var(--text-mid); line-height:1.85; margin:0; font-weight:300; }
</style>

<script define:vars={{ COMBOS, flowerMap }}>
  const section = document.getElementById('resultsSection');
  const grid = document.getElementById('combosGrid');
  const intro = document.getElementById('resultsIntro');
  const cta = document.getElementById('resultsCta');

  document.querySelectorAll('.flower-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.flower-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const id = btn.dataset.id;
      showCombinations(id);
      section.hidden = false;
      section.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  function showCombinations(id) {
    const hero = flowerMap[id];
    const combos = COMBOS[id] || [];

    intro.innerHTML = `
      <h2 class="ri-title">${hero.emoji} Flowers that go well with ${hero.name}</h2>
      <p class="ri-sub">${combos.length} curated combinations — colour stories, style notes, and seasonal guides included.</p>
    `;

    grid.innerHTML = combos.map((c, i) => {
      const partners = c.partners.map(pid => {
        const p = flowerMap[pid];
        return `<a href="/learn/${pid}/" class="cc-partner"><span class="cc-p-emoji">${p.emoji}</span><span class="cc-p-name">${p.name}</span></a>`;
      }).join('');

      return `
        <div class="combo-card">
          <div class="cc-number">Combination ${i + 1} of ${combos.length}</div>
          <h3 class="cc-name">${c.name}</h3>
          <div class="cc-partners">${partners}</div>
          <p class="cc-why">${c.why}</p>
          <div class="cc-meta">
            <div class="cc-colors">
              <span class="cc-colors-dot"></span>
              <span class="cc-colors-text">${c.colors}</span>
            </div>
            <div class="cc-badges">
              <span class="cc-badge cc-badge-style">${c.style}</span>
              <span class="cc-badge cc-badge-season">${c.season}</span>
            </div>
          </div>
        </div>
      `;
    }).join('');

    cta.innerHTML = `
      <p class="rc-text">Want care tips, seasonal availability, and more for ${hero.name}?</p>
      <a href="/learn/${id}/" class="rc-link">${hero.emoji} Read the ${hero.name} Guide →</a>
    `;
  }

  document.querySelectorAll('.faq-item').forEach(item => {
    item.querySelector('.faq-q').addEventListener('click', () => {
      const open = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(el => { el.classList.remove('open'); el.querySelector('.faq-a').hidden = true; });
      if (!open) { item.classList.add('open'); item.querySelector('.faq-a').hidden = false; }
    });
  });
</script>
