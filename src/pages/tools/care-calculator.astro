---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PagefindMeta from '../../components/PagefindMeta.astro';

export const prerender = true;

const lang = 'en' as const;
const siteUrl = (Astro.site?.toString() ?? import.meta.env.SITE_URL ?? 'https://ai-florist-coach-blog.vercel.app').replace(/\/$/, '');

const hreflang = [
  { lang: 'en', url: `${siteUrl}/tools/care-calculator/` },
  { lang: 'x-default', url: `${siteUrl}/tools/care-calculator/` },
];

const breadcrumbs = [
  { name: 'Home', url: `${siteUrl}/` },
  { name: 'Tools', url: `${siteUrl}/tools/` },
  { name: 'Vase Life Calculator', url: `${siteUrl}/tools/care-calculator/` },
];

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Make Cut Flowers Last Longer",
  "description": "Step-by-step guide to extending the vase life of cut flowers using proper care techniques.",
  "totalTime": "PT5M",
  "supply": [
    { "@type": "HowToSupply", "name": "Clean vase" },
    { "@type": "HowToSupply", "name": "Flower food (preservative)" },
    { "@type": "HowToSupply", "name": "Sharp scissors or knife" },
    { "@type": "HowToSupply", "name": "Cold water" }
  ],
  "step": [
    { "@type": "HowToStep", "name": "Fill vase with cold water and flower food", "text": "Use cold water and dissolve flower food according to package directions. Cold water slows bacterial growth and keeps stems firm." },
    { "@type": "HowToStep", "name": "Recut stems at a 45-degree angle underwater", "text": "Cut 2–3 cm from the base of each stem while holding it under water. The angled cut maximises the water-absorbing surface area." },
    { "@type": "HowToStep", "name": "Remove all leaves below the waterline", "text": "Any foliage submerged in water will rot, introducing bacteria that block the stem and cause premature wilting." },
    { "@type": "HowToStep", "name": "Place in a cool location away from direct sun", "text": "Heat is the number one enemy of cut flower longevity. Keep arrangements away from direct sunlight, radiators, and ripening fruit (which emits ethylene gas)." },
    { "@type": "HowToStep", "name": "Change water and recut stems every 1–2 days", "text": "Fresh water removes bacteria. Recutting opens up the stem's vascular system which can become blocked after 24–48 hours." }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How long do cut flowers last in a vase?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Vase life varies significantly by flower type. Carnations and chrysanthemums last 2–3 weeks. Roses and lilies last 7–14 days with good care. Dahlias and gardenias are among the shortest-lived at 3–8 days. Use our calculator above to get an estimate based on your specific conditions."
      }
    },
    {
      "@type": "Question",
      "name": "What is the best way to make cut flowers last longer?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The five most impactful actions are: (1) Recut stems at a 45-degree angle under water every 1–2 days. (2) Change vase water daily or every 2 days. (3) Add commercial flower food (extends life by 25–40%). (4) Keep flowers in a cool room below 20°C. (5) Remove all foliage below the waterline immediately."
      }
    },
    {
      "@type": "Question",
      "name": "Does aspirin or sugar help flowers last longer?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Aspirin has minimal scientific evidence supporting vase life extension. Sugar can help (it feeds the flower) but without an antibacterial agent it accelerates bacterial growth, often shortening life. Commercial flower food contains the right balance of sugar + antibacterial + pH adjuster — it is by far the most effective home treatment."
      }
    },
    {
      "@type": "Question",
      "name": "Should I put flowers in cold or warm water?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Cold water (2–8°C) is generally best for maintaining cut flower freshness — it slows bacterial growth and cellular respiration. Exception: when forcing closed bulb flowers like tulips or ranunculus to open faster, lukewarm water encourages quicker blooming. For long-term preservation, always use cold water."
      }
    },
    {
      "@type": "Question",
      "name": "Why do my flowers wilt so quickly?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The most common causes of rapid wilting are: bacterial buildup in the vase water blocking the stem (fix: change water daily and recut stems), placing flowers near heat sources or direct sunlight, ethylene gas from ripening fruit nearby, and not removing submerged foliage. Some flowers like dahlias, gardenias, and sweet peas are naturally short-lived regardless of care."
      }
    },
    {
      "@type": "Question",
      "name": "Which flowers last the longest in a vase?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Carnations are the longest-lasting cut flower, surviving 2–4 weeks with proper care. Chrysanthemums follow at 10–21 days. Orchid sprays, lilies, and alstroemerias all regularly exceed 2 weeks. Roses typically last 7–12 days. Dahlias, gardenias, and sweet peas are among the shortest-lived at 3–7 days."
      }
    }
  ]
};

const softwareAppSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Flower Vase Life Calculator",
  "applicationCategory": "UtilitiesApplication",
  "description": "Interactive calculator that estimates how long cut flowers will last based on flower type, room temperature, water care, and handling practices.",
  "url": `${siteUrl}/tools/care-calculator/`,
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
};

const flowers = [
  { slug: 'rose',          emoji: '🌹', name: 'Rose',          min: 5,  max: 12, careLevel: 'Moderate', tip: 'Recut stems at 45° under water daily.' },
  { slug: 'lily',          emoji: '🌷', name: 'Lily',          min: 7,  max: 14, careLevel: 'Easy',     tip: 'Remove stamens immediately to avoid pollen staining.' },
  { slug: 'peony',         emoji: '🌸', name: 'Peony',         min: 5,  max: 10, careLevel: 'Moderate', tip: 'Buy in soft-bud stage; refrigerate at 2°C to slow opening.' },
  { slug: 'tulip',         emoji: '🌷', name: 'Tulip',         min: 5,  max: 10, careLevel: 'Easy',     tip: 'Pin a pin through the stem below the head to keep it upright.' },
  { slug: 'sunflower',     emoji: '🌻', name: 'Sunflower',     min: 6,  max: 12, careLevel: 'Easy',     tip: 'Fill vase deeply — sunflowers drink enormous amounts of water.' },
  { slug: 'orchid',        emoji: '🌺', name: 'Orchid (cut)',  min: 7,  max: 14, careLevel: 'Moderate', tip: 'Mist the blooms lightly daily with cool water.' },
  { slug: 'lavender',      emoji: '💜', name: 'Lavender',      min: 5,  max: 7,  careLevel: 'Easy',     tip: 'Use minimal water — lavender prefers drier conditions than most flowers.' },
  { slug: 'hydrangea',     emoji: '💐', name: 'Hydrangea',     min: 5,  max: 10, careLevel: 'Moderate', tip: 'Submerge the entire bloom in cold water for 30–60 min when it wilts.' },
  { slug: 'dahlia',        emoji: '🌸', name: 'Dahlia',        min: 4,  max: 8,  careLevel: 'Moderate', tip: 'Plunge stem tips in boiling water for 10 sec immediately after cutting.' },
  { slug: 'carnation',     emoji: '🌺', name: 'Carnation',     min: 14, max: 28, careLevel: 'Easy',     tip: 'Cut between nodes (not at a node) for maximum water uptake.' },
  { slug: 'chrysanthemum', emoji: '🌼', name: 'Chrysanthemum', min: 10, max: 21, careLevel: 'Easy',     tip: 'Remove all lower leaves immediately — they decay very rapidly in water.' },
  { slug: 'freesia',       emoji: '🌸', name: 'Freesia',       min: 7,  max: 14, careLevel: 'Easy',     tip: 'Snap off each spent bloom as it fades to encourage remaining buds to open.' },
  { slug: 'gardenia',      emoji: '🤍', name: 'Gardenia',      min: 3,  max: 5,  careLevel: 'Advanced', tip: 'Handle as little as possible — finger oils instantly bruise the petals.' },
  { slug: 'iris',          emoji: '💜', name: 'Iris',          min: 5,  max: 10, careLevel: 'Easy',     tip: 'Remove the outer spathe (papery sheath) to encourage buds to open.' },
  { slug: 'jasmine',       emoji: '🌼', name: 'Jasmine',       min: 2,  max: 4,  careLevel: 'Easy',     tip: 'Use as garlands or clusters of buds — individual blooms are very short-lived.' },
  { slug: 'magnolia',      emoji: '🌸', name: 'Magnolia',      min: 2,  max: 5,  careLevel: 'Moderate', tip: 'Hammer the base of woody stems to maximise water uptake.' },
  { slug: 'marigold',      emoji: '🌼', name: 'Marigold',      min: 7,  max: 14, careLevel: 'Easy',     tip: 'Strip all leaves — the foliage has a very strong smell and decays quickly.' },
  { slug: 'anemone',       emoji: '🌸', name: 'Anemone',       min: 5,  max: 10, careLevel: 'Moderate', tip: 'Keep extremely cold (2–5°C) when not on display — warmth causes rapid opening.' },
  { slug: 'ranunculus',    emoji: '🌸', name: 'Ranunculus',    min: 7,  max: 12, careLevel: 'Easy',     tip: 'Do not use flower food with sugar — it accelerates petal drop in ranunculus.' },
  { slug: 'sweet-pea',     emoji: '🌸', name: 'Sweet Pea',     min: 4,  max: 7,  careLevel: 'Advanced', tip: 'Use only 5–8 cm of water — sweet peas rot quickly when stems are deeply submerged.' },
];
---
<BaseLayout
  lang={lang}
  title="Flower Vase Life Calculator — How Long Will Your Flowers Last?"
  description="Instantly estimate how long your cut flowers will last based on flower type, room temperature, and care routine. Free florist tool with expert tips from Yor Flower."
  hreflang={hreflang}
  breadcrumbs={breadcrumbs}
>
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(softwareAppSchema)} slot="head" />

  <!-- Breadcrumb nav -->
  <nav class="breadcrumb-nav" aria-label="Breadcrumb" data-pagefind-ignore>
    <div class="max-w-5xl mx-auto px-6 py-4">
      <ol class="breadcrumb-list">
        <li><a href="/">Home</a></li>
        <li aria-hidden="true">›</li>
        <li>Tools</li>
        <li aria-hidden="true">›</li>
        <li aria-current="page">Vase Life Calculator</li>
      </ol>
    </div>
  </nav>

  <article data-pagefind-body>
  <PagefindMeta kind="tool" description="Estimate how long your cut flowers will last based on flower type, room temperature, and care routine." tags={["tool","care","vase life"]} />

  <!-- Page header -->
  <div class="page-header">
    <div class="max-w-5xl mx-auto px-6 py-20 text-center" style="position:relative;z-index:2">
      <p class="page-eyebrow">Free Florist Tool</p>
      <h1 class="page-title">Flower Vase Life Calculator</h1>
      <p class="page-sub">How long will your cut flowers last? Enter your flower type and care routine to get an instant estimate — plus personalised tips to maximise freshness.</p>
    </div>
  </div>

  <!-- Calculator -->
  <div class="calc-wrap">
    <div class="max-w-5xl mx-auto px-6 py-14">
      <div class="calc-layout">

        <!-- Inputs panel -->
        <div class="inputs-panel">
          <h2 class="panel-heading">Your Conditions</h2>

          <!-- Flower picker -->
          <div class="field-group">
            <label class="field-label" for="flower-select">Flower type</label>
            <div class="select-wrap">
              <select id="flower-select" class="field-select">
                <option value="">— Choose a flower —</option>
                {flowers.map(f => (
                  <option
                    value={f.slug}
                    data-min={f.min}
                    data-max={f.max}
                    data-tip={f.tip}
                    data-care={f.careLevel}
                    data-emoji={f.emoji}
                    data-name={f.name}
                  >{f.emoji} {f.name}</option>
                ))}
              </select>
            </div>
          </div>

          <!-- Room temperature -->
          <div class="field-group">
            <label class="field-label">Room temperature</label>
            <div class="radio-grid" id="temp-options">
              <label class="radio-card selected" data-val="hot">
                <input type="radio" name="temp" value="hot" class="sr-only" />
                <span class="radio-icon">🌡️</span>
                <span class="radio-title">Hot</span>
                <span class="radio-sub">&gt; 25 °C</span>
              </label>
              <label class="radio-card" data-val="warm">
                <input type="radio" name="temp" value="warm" class="sr-only" />
                <span class="radio-icon">☀️</span>
                <span class="radio-title">Warm</span>
                <span class="radio-sub">20–25 °C</span>
              </label>
              <label class="radio-card" data-val="cool">
                <input type="radio" name="temp" value="cool" class="sr-only" />
                <span class="radio-icon">🍃</span>
                <span class="radio-title">Cool</span>
                <span class="radio-sub">15–20 °C</span>
              </label>
              <label class="radio-card" data-val="cold">
                <input type="radio" name="temp" value="cold" class="sr-only" />
                <span class="radio-icon">❄️</span>
                <span class="radio-title">Cold</span>
                <span class="radio-sub">&lt; 15 °C</span>
              </label>
            </div>
          </div>

          <!-- Water changes -->
          <div class="field-group">
            <label class="field-label">How often do you change the water?</label>
            <div class="radio-grid radio-grid--2" id="water-options">
              <label class="radio-card selected" data-val="never">
                <input type="radio" name="water" value="never" class="sr-only" />
                <span class="radio-icon">🚫</span>
                <span class="radio-title">Never</span>
              </label>
              <label class="radio-card" data-val="few-days">
                <input type="radio" name="water" value="few-days" class="sr-only" />
                <span class="radio-icon">📅</span>
                <span class="radio-title">Every 3–4 days</span>
              </label>
              <label class="radio-card" data-val="every-2">
                <input type="radio" name="water" value="every-2" class="sr-only" />
                <span class="radio-icon">💧</span>
                <span class="radio-title">Every 2 days</span>
              </label>
              <label class="radio-card" data-val="daily">
                <input type="radio" name="water" value="daily" class="sr-only" />
                <span class="radio-icon">✨</span>
                <span class="radio-title">Daily</span>
              </label>
            </div>
          </div>

          <!-- Stem recutting -->
          <div class="field-group">
            <label class="field-label">Do you recut stems when changing water?</label>
            <div class="radio-grid radio-grid--2" id="recut-options">
              <label class="radio-card selected" data-val="no">
                <input type="radio" name="recut" value="no" class="sr-only" />
                <span class="radio-icon">✂️</span>
                <span class="radio-title">No</span>
              </label>
              <label class="radio-card" data-val="yes">
                <input type="radio" name="recut" value="yes" class="sr-only" />
                <span class="radio-icon">✂️✅</span>
                <span class="radio-title">Yes, at an angle</span>
              </label>
            </div>
          </div>

          <!-- Flower food -->
          <div class="field-group">
            <label class="field-label">Using flower food / preservative?</label>
            <div class="radio-grid radio-grid--2" id="food-options">
              <label class="radio-card selected" data-val="no">
                <input type="radio" name="food" value="no" class="sr-only" />
                <span class="radio-icon">💧</span>
                <span class="radio-title">Water only</span>
              </label>
              <label class="radio-card" data-val="yes">
                <input type="radio" name="food" value="yes" class="sr-only" />
                <span class="radio-icon">🌿</span>
                <span class="radio-title">Yes, flower food</span>
              </label>
            </div>
          </div>

          <!-- Leaves removed -->
          <div class="field-group">
            <label class="field-label">Did you remove leaves below the waterline?</label>
            <div class="radio-grid radio-grid--2" id="leaves-options">
              <label class="radio-card selected" data-val="no">
                <input type="radio" name="leaves" value="no" class="sr-only" />
                <span class="radio-icon">🍃</span>
                <span class="radio-title">No</span>
              </label>
              <label class="radio-card" data-val="yes">
                <input type="radio" name="leaves" value="yes" class="sr-only" />
                <span class="radio-icon">🍃✅</span>
                <span class="radio-title">Yes</span>
              </label>
            </div>
          </div>

          <button id="calc-btn" class="calc-btn" disabled>Calculate →</button>
        </div>

        <!-- Results panel -->
        <div class="results-panel" id="results-panel">
          <div class="results-empty" id="results-empty">
            <div class="empty-icon">🌸</div>
            <p class="empty-text">Select a flower and fill in your conditions to see your vase life estimate.</p>
          </div>

          <div class="results-content hidden" id="results-content">
            <!-- Flower ID strip -->
            <div class="result-flower-id" id="result-flower-id">
              <span id="result-emoji" class="result-flower-emoji">🌹</span>
              <div>
                <div class="result-flower-name" id="result-flower-name">Rose</div>
                <div class="result-care-level" id="result-care-level">Moderate care</div>
              </div>
            </div>

            <!-- Score arc -->
            <div class="score-arc-wrap">
              <svg class="score-arc" viewBox="0 0 200 120" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <!-- Track arc -->
                <path d="M 20 110 A 80 80 0 0 1 180 110" stroke="#F0E8E5" stroke-width="14" stroke-linecap="round" fill="none"/>
                <!-- Progress arc — animated via JS -->
                <path id="arc-progress"
                  d="M 20 110 A 80 80 0 0 1 180 110"
                  stroke="url(#arcGrad)"
                  stroke-width="14"
                  stroke-linecap="round"
                  fill="none"
                  stroke-dasharray="251.2"
                  stroke-dashoffset="251.2"
                  style="transition: stroke-dashoffset 0.9s cubic-bezier(0.34,1.56,0.64,1)"/>
                <defs>
                  <linearGradient id="arcGrad" x1="0" y1="0" x2="1" y2="0">
                    <stop offset="0%" stop-color="#E8A4B0"/>
                    <stop offset="100%" stop-color="#C47A8A"/>
                  </linearGradient>
                </defs>
              </svg>
              <div class="score-inner">
                <div class="score-days" id="score-days">—</div>
                <div class="score-label">days</div>
              </div>
            </div>

            <p class="score-range-text" id="score-range-text"></p>

            <!-- Factor breakdown -->
            <div class="factor-list" id="factor-list"></div>

            <!-- Personalised tip -->
            <div class="result-tip" id="result-tip">
              <div class="tip-label">Top tip for this flower</div>
              <div class="tip-text" id="tip-text"></div>
            </div>

            <!-- Action tips -->
            <div class="upgrade-box" id="upgrade-box"></div>

            <!-- Glossary link -->
            <a id="glossary-link" href="/learn/rose/" class="glossary-cta">
              Full Rose care guide →
            </a>
          </div>
        </div>

      </div><!-- /calc-layout -->
    </div>
  </div>

  <!-- How To section (SEO content + rich result) -->
  <section class="howto-section">
    <div class="max-w-5xl mx-auto px-6 py-16">
      <h2 class="howto-title">5 Steps to Make Cut Flowers Last Longer</h2>
      <div class="howto-steps">
        {[
          { n: '01', head: 'Fill vase with cold water + flower food', body: 'Cold water (2–8 °C) slows bacterial growth significantly. Commercial flower food contains a precisely balanced mix of sugar (nutrition), acidifier (pH control), and biocide — more effective than any DIY substitute.' },
          { n: '02', head: 'Recut stems at a 45° angle underwater', body: 'Cut 2–3 cm from each stem base while holding it underwater. The angled cut maximises the surface area for water uptake. Recutting daily re-opens the vascular tissue that becomes blocked by bacteria and air bubbles.' },
          { n: '03', head: 'Strip all leaves below the waterline', body: 'Submerged foliage decays rapidly, introducing millions of bacteria per hour into your vase water. This blocks the stem and poisons the water. Remove every leaf that will touch water — immediately.' },
          { n: '04', head: 'Position away from heat and ethylene', body: 'The four enemies of cut flowers: direct sunlight (heat), radiators (heat), ripening fruit (ethylene gas), and air conditioning vents (cold drafts). A cool, shaded spot at 15–18 °C is optimal for most flowers.' },
          { n: '05', head: 'Change water and recut every 1–2 days', body: 'This single habit has the largest impact on vase life. Bacterial counts double roughly every 20 minutes in vase water at room temperature. Fresh water + fresh stem cuts every 48 hours can extend vase life by 50–80% compared to doing nothing.' },
        ].map(step => (
          <div class="howto-step">
            <div class="step-num">{step.n}</div>
            <div class="step-content">
              <h3 class="step-head">{step.head}</h3>
              <p class="step-body">{step.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ section -->
  <section class="faq-section">
    <div class="max-w-5xl mx-auto px-6 py-16">
      <h2 class="faq-title">Frequently Asked Questions</h2>
      <div class="faq-list" id="faq-accordion">
        {[
          { q: 'How long do cut flowers last in a vase?', a: 'Vase life varies significantly by flower type. Carnations and chrysanthemums last 2–3 weeks. Roses and lilies last 7–14 days with good care. Dahlias and gardenias are among the shortest-lived at 3–8 days. Use our calculator above to get an estimate based on your specific conditions.' },
          { q: 'What is the best way to make cut flowers last longer?', a: 'The five most impactful actions are: (1) Recut stems at a 45-degree angle under water every 1–2 days. (2) Change vase water daily or every 2 days. (3) Add commercial flower food (extends life by 25–40%). (4) Keep flowers in a cool room below 20°C. (5) Remove all foliage below the waterline immediately.' },
          { q: 'Does aspirin or sugar help flowers last longer?', a: 'Aspirin has minimal scientific evidence supporting vase life extension. Sugar can help (it feeds the flower) but without an antibacterial agent it accelerates bacterial growth, often shortening life. Commercial flower food contains the right balance of sugar + antibacterial + pH adjuster — it is by far the most effective home treatment.' },
          { q: 'Should I put flowers in cold or warm water?', a: 'Cold water (2–8°C) is generally best for maintaining cut flower freshness — it slows bacterial growth and cellular respiration. Exception: when forcing closed bulb flowers like tulips or ranunculus to open faster, lukewarm water encourages quicker blooming. For long-term preservation, always use cold water.' },
          { q: 'Why do my flowers wilt so quickly?', a: 'The most common causes of rapid wilting are: bacterial buildup in vase water blocking the stem (fix: change water daily and recut stems), placing flowers near heat or direct sunlight, ethylene gas from ripening fruit nearby, and not removing submerged foliage. Some flowers like dahlias, gardenias, and sweet peas are naturally short-lived regardless of care.' },
          { q: 'Which flowers last the longest in a vase?', a: 'Carnations are the longest-lasting cut flower, surviving 2–4 weeks with proper care. Chrysanthemums follow at 10–21 days. Orchid sprays, lilies, and alstroemerias all regularly exceed 2 weeks. Roses typically last 7–12 days. Dahlias, gardenias, and sweet peas are among the shortest-lived at 3–7 days.' },
        ].map((item, i) => (
          <div class="faq-item" data-index={i}>
            <button class="faq-q" aria-expanded="false">
              <span>{item.q}</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-a" hidden>
              <p>{item.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Vase life table -->
  <section class="table-section">
    <div class="max-w-5xl mx-auto px-6 pb-16">
      <h2 class="table-title">Cut Flower Vase Life Reference Chart</h2>
      <p class="table-sub">Baseline estimates under optimal care conditions (cool room, fresh water every 2 days, flower food used).</p>
      <div class="table-wrap">
        <table class="ref-table">
          <thead>
            <tr>
              <th>Flower</th>
              <th>Minimum (days)</th>
              <th>Maximum (days)</th>
              <th>Care Level</th>
            </tr>
          </thead>
          <tbody>
            {flowers.sort((a, b) => b.max - a.max).map(f => (
              <tr>
                <td><a href={`/learn/${f.slug}/`} class="table-flower-link">{f.emoji} {f.name}</a></td>
                <td>{f.min}</td>
                <td>{f.max}</td>
                <td>
                  <span class:list={['care-pill', `care-${f.careLevel.toLowerCase()}`]}>{f.careLevel}</span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  </article>
</BaseLayout>

<style>
