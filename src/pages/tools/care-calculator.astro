  .care-easy { background:rgba(134,187,134,0.15); color:#4a7a4a; border:1px solid rgba(134,187,134,0.3); }
  .care-moderate { background:rgba(200,149,106,0.15); color:#8a5c30; border:1px solid rgba(200,149,106,0.3); }
  .care-advanced { background:rgba(196,122,138,0.15); color:var(--blush-dark); border:1px solid rgba(196,122,138,0.2); }
</style>

<script>
  // ── State ──────────────────────────────────────────────────────────
  const state = {
    flower: null as null | { slug: string; name: string; emoji: string; min: number; max: number; tip: string; careLevel: string },
    temp: 'hot',
    water: 'never',
    recut: 'no',
    food: 'no',
    leaves: 'no',
  };

  // ── Multipliers ────────────────────────────────────────────────────
  const FACTORS: Record<string, { label: string; icon: string; values: Record<string, { mult: number; text: string; badge: 'boost'|'neutral'|'penalty' }> }> = {
    temp: {
      label: 'Room temperature',
      icon: '🌡️',
      values: {
        hot:  { mult: 0.62, text: 'Hot room reduces life significantly', badge: 'penalty' },
        warm: { mult: 0.82, text: 'Warm room — mild reduction', badge: 'penalty' },
        cool: { mult: 1.00, text: 'Cool room — ideal', badge: 'neutral' },
        cold: { mult: 1.22, text: 'Cold room — extends life considerably', badge: 'boost' },
      }
    },
    water: {
      label: 'Water changes',
      icon: '💧',
      values: {
        never:    { mult: 0.50, text: 'No water changes — heavy bacterial buildup', badge: 'penalty' },
        'few-days':{ mult: 0.82, text: 'Every 3–4 days — moderate bacteria control', badge: 'penalty' },
        'every-2': { mult: 0.96, text: 'Every 2 days — good freshness', badge: 'neutral' },
        daily:    { mult: 1.16, text: 'Daily changes — optimal bacteria control', badge: 'boost' },
      }
    },
    recut: {
      label: 'Stem recutting',
      icon: '✂️',
      values: {
        no:  { mult: 0.85, text: 'No recut — blocked stem vascular tissue', badge: 'penalty' },
        yes: { mult: 1.12, text: 'Recutting at angle — maximises uptake', badge: 'boost' },
      }
    },
    food: {
      label: 'Flower food',
      icon: '🌿',
      values: {
        no:  { mult: 0.90, text: 'Water only — no nutrition or pH control', badge: 'neutral' },
        yes: { mult: 1.17, text: 'Flower food — sugar + antibacterial + pH', badge: 'boost' },
      }
    },
    leaves: {
      label: 'Leaves removed',
      icon: '🍃',
      values: {
        no:  { mult: 0.85, text: 'Submerged leaves — bacterial contamination', badge: 'penalty' },
        yes: { mult: 1.06, text: 'Clean stems — minimal bacterial load', badge: 'boost' },
      }
    },
  };

  // ── DOM helpers ────────────────────────────────────────────────────
  const $ = (id: string) => document.getElementById(id)!;
  const flowerSelect = $('flower-select') as HTMLSelectElement;
  const calcBtn = $('calc-btn') as HTMLButtonElement;
  const resultsEmpty = $('results-empty');
  const resultsContent = $('results-content');

  // ── Radio card clicks ──────────────────────────────────────────────
  function setupRadioGroup(groupId: string, stateKey: keyof typeof state) {
    const container = $(groupId);
    container.querySelectorAll<HTMLElement>('.radio-card').forEach(card => {
      card.addEventListener('click', () => {
        container.querySelectorAll('.radio-card').forEach(c => c.classList.remove('selected'));
        card.classList.add('selected');
        (state as any)[stateKey] = card.dataset.val!;
      });
    });
  }

  setupRadioGroup('temp-options', 'temp');
  setupRadioGroup('water-options', 'water');
  setupRadioGroup('recut-options', 'recut');
  setupRadioGroup('food-options', 'food');
  setupRadioGroup('leaves-options', 'leaves');

  // ── Flower select ──────────────────────────────────────────────────
  flowerSelect.addEventListener('change', () => {
    const opt = flowerSelect.selectedOptions[0];
    if (opt.value) {
      state.flower = {
        slug: opt.value,
        name: opt.dataset.name!,
        emoji: opt.dataset.emoji!,
        min: Number(opt.dataset.min),
        max: Number(opt.dataset.max),
        tip: opt.dataset.tip!,
        careLevel: opt.dataset.care!,
      };
      calcBtn.disabled = false;
    } else {
      state.flower = null;
      calcBtn.disabled = true;
    }
  });

  // ── Calculate ──────────────────────────────────────────────────────
  calcBtn.addEventListener('click', () => {
    if (!state.flower) return;

    // Compute multiplied estimate
    const baseMid = (state.flower.min + state.flower.max) / 2;
    let mult = 1;
    mult *= FACTORS.temp.values[state.temp].mult;
    mult *= FACTORS.water.values[state.water].mult;
    mult *= FACTORS.recut.values[state.recut].mult;
    mult *= FACTORS.food.values[state.food].mult;
    mult *= FACTORS.leaves.values[state.leaves].mult;

    const estimated = Math.round(baseMid * mult);
    const low  = Math.max(1, Math.round(state.flower.min * mult));
    const high = Math.round(state.flower.max * mult);

    // Render
    renderResults(estimated, low, high);
  });

  function renderResults(days: number, low: number, high: number) {
    const f = state.flower!;

    // Header
    ($('result-emoji') as HTMLElement).textContent = f.emoji;
    ($('result-flower-name') as HTMLElement).textContent = f.name;
    ($('result-care-level') as HTMLElement).textContent = `${f.careLevel} care level`;

    // Score number
    ($('score-days') as HTMLElement).textContent = String(days);
    ($('score-range-text') as HTMLElement).textContent = `Estimated range: ${low}–${high} days`;

    // Arc animation — map days 1–30 to 0–100%
    const pct = Math.min(days / 30, 1);
    const arcLen = 251.2;
    const arc = document.getElementById('arc-progress')!;
    // Reset first then animate
    arc.style.transition = 'none';
    arc.style.strokeDashoffset = String(arcLen);
    requestAnimationFrame(() => requestAnimationFrame(() => {
      arc.style.transition = 'stroke-dashoffset 0.9s cubic-bezier(0.34,1.56,0.64,1)';
      arc.style.strokeDashoffset = String(arcLen * (1 - pct));
    }));

    // Factor breakdown
    const factorList = $('factor-list');
    factorList.innerHTML = '';
    const factorKeys = ['temp', 'water', 'recut', 'food', 'leaves'] as const;
    factorKeys.forEach(key => {
      const fac = FACTORS[key];
      const val = fac.values[(state as any)[key]];
      const row = document.createElement('div');
      row.className = 'factor-row';
      row.innerHTML = `
        <span class="factor-icon">${fac.icon}</span>
        <span class="factor-name">${fac.label}</span>
        <span class="factor-badge badge-${val.badge}">${val.text}</span>
      `;
      factorList.appendChild(row);
    });

    // Flower tip
    ($('tip-text') as HTMLElement).textContent = f.tip;

    // Upgrade suggestions
    const upgradeBox = $('upgrade-box');
    const improvements: string[] = [];
    if (state.water === 'never' || state.water === 'few-days') improvements.push('Change vase water every 1–2 days to dramatically reduce bacterial buildup.');
    if (state.recut === 'no') improvements.push('Recut stems at a 45° angle each time you change the water.');
    if (state.food === 'no') improvements.push('Add commercial flower food — it alone can extend vase life by 25–40%.');
    if (state.leaves === 'no') improvements.push('Remove all leaves below the waterline immediately.');
    if (state.temp === 'hot' || state.temp === 'warm') improvements.push('Move to a cooler room (below 20°C) to slow cellular respiration.');

    if (improvements.length > 0) {
      upgradeBox.innerHTML = `
        <div class="upgrade-title">Quick wins to add more days</div>
        ${improvements.map(t => `<div class="upgrade-item"><span class="upgrade-check">+</span><span>${t}</span></div>`).join('')}
      `;
      upgradeBox.style.display = 'flex';
      upgradeBox.style.flexDirection = 'column';
    } else {
      upgradeBox.innerHTML = `<div class="upgrade-item"><span class="upgrade-check">✓</span><span>Excellent care! You\'re already following best practices for this flower.</span></div>`;
      upgradeBox.style.display = 'flex';
    }

    // Glossary link
    const glink = $('glossary-link') as HTMLAnchorElement;
    glink.href = `/learn/${f.slug}/`;
    glink.textContent = `Full ${f.name} care guide →`;

    // Show results
    resultsEmpty.classList.add('hidden');
    resultsContent.classList.remove('hidden');

    // Scroll results into view on mobile
    if (window.innerWidth < 860) {
      $('results-panel').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }

  // ── FAQ accordion ──────────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.faq-item').forEach(item => {
    const btn = item.querySelector<HTMLButtonElement>('.faq-q')!;
    const ans = item.querySelector<HTMLElement>('.faq-a')!;
    btn.addEventListener('click', () => {
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(el => {
        el.classList.remove('open');
        el.querySelector<HTMLButtonElement>('.faq-q')!.setAttribute('aria-expanded', 'false');
        el.querySelector<HTMLElement>('.faq-a')!.hidden = true;
      });
      if (!isOpen) {
        item.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
        ans.hidden = false;
      }
    });
  });
</script>
