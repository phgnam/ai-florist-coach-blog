  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Pet-Safe Flower Reference',
  description: 'Reference list of common florist flowers with cat, dog, and horse toxicity ratings sourced from the ASPCA database.',
  url: `${siteUrl}/tools/pet-safe-checker/`,
  numberOfItems: FLOWERS.length,
  itemListElement: FLOWERS.map((f, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: `${f.name} (${f.scientific})`,
    item: {
      '@type': 'Thing',
      name: f.name,
      alternateName: f.scientific,
      description: `Cat: ${SEVERITY_LABEL[f.cat.level]}. Dog: ${SEVERITY_LABEL[f.dog.level]}. Horse: ${SEVERITY_LABEL[f.horse.level]}.`,
      url: f.glossarySlug ? `${siteUrl}/learn/${f.glossarySlug}/` : (f.aspcaUrl ?? `${siteUrl}/tools/pet-safe-checker/`),
    },
  })),
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: generalFAQs.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---
<BaseLayout
  lang={lang}
  title="Pet-Safe Flower Checker — Are These Flowers Toxic to Cats and Dogs?"
  description="Look up whether a flower is safe for cats, dogs, or horses. Severity ratings, symptoms, and toxic compounds for 35+ popular florist flowers, sourced from the ASPCA. Free tool from Yor Flower."
  hreflang={hreflang}
  breadcrumbs={breadcrumbs}
>
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline />

  <nav class="breadcrumb-nav" aria-label="Breadcrumb" data-pagefind-ignore>
    <div class="max-w-6xl mx-auto px-6 py-4">
      <ol class="breadcrumb-list">
        <li><a href="/">Home</a></li>
        <li aria-hidden="true">›</li>
        <li><a href="/tools/">Tools</a></li>
        <li aria-hidden="true">›</li>
        <li aria-current="page">Pet-Safe Flower Checker</li>
      </ol>
    </div>
  </nav>

  <article data-pagefind-body>
  <PagefindMeta kind="tool" description="Pet-safe flower checker. Look up cat, dog, and horse toxicity for 35+ florist flowers, with symptoms and safer alternatives. Sourced from the ASPCA database." tags={["tool","pet-safe","toxicity","florist-safety"]} />

  <div class="page-header">
    <div class="max-w-6xl mx-auto px-6 py-20 text-center" style="position:relative;z-index:2">
      <p class="page-eyebrow">Free florist tool</p>
      <h1 class="page-title">Pet-Safe Flower Checker</h1>
      <p class="page-sub">Are these flowers toxic to cats, dogs, or horses? Search 35+ popular florist flowers, get a severity rating per pet, and find safer alternatives.</p>
      <a href="/vi/tools/pet-safe-checker/" class="lang-switch-link">🇻🇳 Xem bằng tiếng Việt</a>
    </div>
  </div>

  <aside class="emergency-banner" data-pagefind-ignore>
    <div class="max-w-6xl mx-auto px-6 py-5">
      <div class="emergency-grid">
        <div class="emergency-text">
          <p class="emergency-eyebrow">⚠ If your pet has already ingested something</p>
          <p class="emergency-body">Call your vet, or one of the 24-hour poison-control lines below, <em>before</em> you wait for symptoms. Bring the plant — or a clear photo — to the appointment.</p>
        </div>
        <div class="emergency-numbers">
          <a class="emergency-num" href="tel:+18884264435">
            <span class="emergency-num-label">ASPCA Animal Poison Control (US)</span>
            <span class="emergency-num-value">(888) 426-4435</span>
          </a>
          <a class="emergency-num" href="tel:+18557647661">
            <span class="emergency-num-label">Pet Poison Helpline (US/Canada)</span>
            <span class="emergency-num-value">(855) 764-7661</span>
          </a>
        </div>
      </div>
    </div>
  </aside>

  <section class="quick-answer">
    <div class="max-w-6xl mx-auto px-6 py-8">
      <p><strong>Quick answer:</strong> The single most dangerous flower in any florist shop is the <strong>true lily</strong> (Lilium and Hemerocallis — Easter, Asiatic, Tiger, Stargazer, Oriental, daylily). Even pollen on fur or vase water can cause fatal kidney failure in cats within 72 hours. The safest "all-rounder" stems for cat- and dog-friendly arrangements are <a href="/learn/rose/">roses</a>, <a href="/learn/sunflower/">sunflowers</a>, <a href="/learn/snapdragon/">snapdragons</a>, <a href="/learn/gerbera/">gerbera daisies</a>, <a href="/learn/lisianthus/">lisianthus</a>, <a href="/learn/orchid/">orchids</a>, <a href="/learn/stock/">stock</a>, and statice.</p>
    </div>
  </section>

  <div class="checker-wrap">
    <div class="max-w-6xl mx-auto px-4 lg:px-6 py-10">

      <div class="filter-bar">
        <div class="filter-search">
          <label for="flower-search" class="filter-label">Search a flower</label>
          <input
            type="search"
            id="flower-search"
            placeholder="e.g. lily, hydrangea, gerbera…"
            class="filter-input"
            aria-describedby="filter-help"
          />
        </div>

        <fieldset class="filter-group">
          <legend class="filter-label">Show only safe for</legend>
          <div class="filter-chips" role="group">
            <button type="button" class="chip" data-filter-pet="all" aria-pressed="true">All pets</button>
            <button type="button" class="chip" data-filter-pet="cat" aria-pressed="false">🐱 Cats</button>
            <button type="button" class="chip" data-filter-pet="dog" aria-pressed="false">🐶 Dogs</button>
            <button type="button" class="chip" data-filter-pet="horse" aria-pressed="false">🐴 Horses</button>
          </div>
        </fieldset>

        <fieldset class="filter-group">
          <legend class="filter-label">Severity</legend>
          <div class="filter-chips" role="group">
            <button type="button" class="chip" data-filter-sev="all" aria-pressed="true">Show all</button>
            <button type="button" class="chip chip-safe" data-filter-sev="safe" aria-pressed="false">✓ Safe only</button>
            <button type="button" class="chip chip-toxic" data-filter-sev="toxic" aria-pressed="false">⚠ Toxic only</button>
          </div>
        </fieldset>
      </div>
      <p id="filter-help" class="filter-help">Showing <span id="result-count">{FLOWERS.length}</span> of {FLOWERS.length} flowers. Severity is a quick reference, not vet advice.</p>

      <div class="severity-legend" role="region" aria-label="Severity legend">
        <span class="legend-pill chip-safe">{SEVERITY_ICON.safe} Safe — non-toxic per ASPCA</span>
        <span class="legend-pill chip-mild">{SEVERITY_ICON.mild} Mild — GI upset / oral irritation</span>
        <span class="legend-pill chip-severe">{SEVERITY_ICON.severe} Severe — vet visit needed</span>
        <span class="legend-pill chip-lethal">{SEVERITY_ICON.lethal} Lethal — can be fatal</span>
      </div>

      <div class="flower-grid" id="flower-grid">
        {FLOWERS.map((f) => (
          <article
            class="flower-card"
            data-name={f.name.toLowerCase()}
            data-aliases={(f.aliases ?? []).join(',').toLowerCase()}
            data-cat={f.cat.level}
            data-dog={f.dog.level}
            data-horse={f.horse.level}
          >
            <header class="card-head">
              <span class="card-emoji" aria-hidden="true">{f.emoji}</span>
              <div class="card-title-wrap">
                <h2 class="card-name">{f.name}</h2>
                <p class="card-sci">{f.scientific}</p>
              </div>
            </header>

            <div class="pet-row">
              {(['cat', 'dog', 'horse'] as const).map((pet) => (
                <div class={`pet-cell pet-cell-${f[pet].level}`}>
                  <span class="pet-icon">{pet === 'cat' ? '🐱' : pet === 'dog' ? '🐶' : '🐴'}</span>
                  <span class="pet-status">
                    <span class="pet-status-icon">{SEVERITY_ICON[f[pet].level]}</span>
                    <span class="pet-status-label">{SEVERITY_LABEL[f[pet].level]}</span>
                  </span>
                </div>
              ))}
            </div>

            {(f.cat.symptoms || f.dog.symptoms || f.horse.symptoms) && (
              <div class="card-section">
                <h3 class="card-sub">Symptoms if ingested</h3>
                <ul class="card-list">
                  {f.cat.symptoms && <li><strong>Cats:</strong> {f.cat.symptoms}</li>}
                  {f.dog.symptoms && f.dog.symptoms !== f.cat.symptoms && <li><strong>Dogs:</strong> {f.dog.symptoms}</li>}
                  {f.dog.symptoms && f.dog.symptoms === f.cat.symptoms && <li><strong>Dogs:</strong> Same as cats above.</li>}
                  {f.horse.symptoms && <li><strong>Horses:</strong> {f.horse.symptoms}</li>}
                </ul>
              </div>
            )}

            {f.toxicCompound && (
              <div class="card-section">
                <h3 class="card-sub">Toxic compound</h3>
                <p class="card-body">{f.toxicCompound}</p>
              </div>
            )}

            {f.notes && (
              <div class="card-section card-notes">
                <h3 class="card-sub">Florist note</h3>
                <p class="card-body">{f.notes}</p>
              </div>
            )}

            <div class="card-links">
              {f.glossarySlug && (
                <a class="card-link" href={`/learn/${f.glossarySlug}/`}>Full guide →</a>
              )}
              {f.aspcaUrl && (
                <a class="card-link card-link-ext" href={f.aspcaUrl} target="_blank" rel="noopener noreferrer">ASPCA reference ↗</a>
              )}
            </div>
          </article>
        ))}
      </div>

      <p class="empty-state" id="empty-state" hidden>No flowers match this filter. Try a different search term or clear filters.</p>
    </div>
  </div>

  <section class="faq-section">
    <div class="max-w-6xl mx-auto px-4 lg:px-6 py-16">
      <h2 class="faq-title">Pet-Safe Flower FAQs — What Florists and Pet Owners Ask</h2>
      <div class="faq-list">
        {generalFAQs.map((item, i) => (
          <div class="faq-item" data-index={i}>
            <button class="faq-q" aria-expanded="false">
              <span>{item.q}</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-a" hidden>
              <p>{item.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="tips-section">
    <div class="max-w-6xl mx-auto px-4 lg:px-6 py-14">
      <h2 class="tips-title">How Should You Build a Truly Pet-Safe Bouquet?</h2>
      <div class="tips-grid">
        <div class="tip-card">
          <div class="tip-icon">🐱</div>
          <h3 class="tip-head">Never deliver lilies to cat households</h3>
          <p class="tip-body">If you don't know whether the recipient has a cat, default to a no-lily arrangement. The kidney-failure toxin in true lilies has no equivalent "low dose" — even pollen on a paw is enough. Substitute lisianthus, alstroemeria (NOT a true lily), or oriental-style ranunculus for the same look.</p>
        </div>
        <div class="tip-card">
          <div class="tip-icon">🐶</div>
          <h3 class="tip-head">Watch out for bulb-stem flowers</h3>
          <p class="tip-body">Tulip, daffodil, and hyacinth are most dangerous to dogs that dig in the garden — the bulbs are far more toxic than the cut stems. Cut flowers in a vase are lower-risk, but still position them on shelves or hung where a dog cannot pull them down.</p>
        </div>
        <div class="tip-card">
          <div class="tip-icon">🌿</div>
          <h3 class="tip-head">Don't forget the foliage</h3>
          <p class="tip-body">Filler greens are often more accessible than the showy flowers. Eucalyptus, ivy, leatherleaf, and ruscus all have varying toxicity — eucalyptus is a mild GI/CNS irritant for cats and dogs. For pet households, prefer pet-safe foliage like leather leaf fern, parlor palm, or boston fern.</p>
        </div>
        <div class="tip-card">
          <div class="tip-icon">📞</div>
          <h3 class="tip-head">Save these numbers in your phone now</h3>
          <p class="tip-body">ASPCA Animal Poison Control: (888) 426-4435 (consultation fee). Pet Poison Helpline: (855) 764-7661 (consultation fee). Both run 24/7 and have direct lines to vets. Faster than searching for symptoms when your pet is already showing them.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="disclaimer">
    <div class="max-w-6xl mx-auto px-6 py-10">
      <p><strong>Sources & disclaimer:</strong> Severity ratings draw on the <a href="https://www.aspca.org/pet-care/animal-poison-control/toxic-and-non-toxic-plants" target="_blank" rel="noopener noreferrer">ASPCA Toxic and Non-Toxic Plants database</a> and the <a href="https://www.petpoisonhelpline.com/poisons/" target="_blank" rel="noopener noreferrer">Pet Poison Helpline</a>. This page is intended as a quick reference for florists and gift-givers, not as veterinary advice. If your pet has actually ingested a plant, call a vet or poison-control line immediately — do not rely on a web page to make the call for you.</p>
    </div>
  </section>

  </article>
</BaseLayout>

<script>
  const grid = document.querySelector<HTMLElement>('#flower-grid');
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.flower-card'));
  const search = document.querySelector<HTMLInputElement>('#flower-search');
  const counter = document.querySelector<HTMLElement>('#result-count');
  const empty = document.querySelector<HTMLElement>('#empty-state');
  const petChips = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-filter-pet]'));
  const sevChips = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-filter-sev]'));

  let activePet: 'all' | 'cat' | 'dog' | 'horse' = 'all';
  let activeSev: 'all' | 'safe' | 'toxic' = 'all';
  let activeQuery = '';

  function applyFilters() {
    let visible = 0;
    const q = activeQuery.trim().toLowerCase();
    cards.forEach(card => {
      const name = card.dataset.name ?? '';
      const aliases = card.dataset.aliases ?? '';
      const matchesQuery = !q || name.includes(q) || aliases.includes(q);

      const cat = card.dataset.cat ?? 'safe';
      const dog = card.dataset.dog ?? 'safe';
      const horse = card.dataset.horse ?? 'safe';

      let matchesPet = true;
      if (activePet === 'cat') matchesPet = cat === 'safe';
      else if (activePet === 'dog') matchesPet = dog === 'safe';
      else if (activePet === 'horse') matchesPet = horse === 'safe';

      const allSafe = cat === 'safe' && dog === 'safe' && horse === 'safe';
      const anyToxic = cat !== 'safe' || dog !== 'safe' || horse !== 'safe';
      let matchesSev = true;
      if (activeSev === 'safe') matchesSev = allSafe;
      else if (activeSev === 'toxic') matchesSev = anyToxic;

      const show = matchesQuery && matchesPet && matchesSev;
      card.hidden = !show;
      if (show) visible += 1;
    });
    if (counter) counter.textContent = String(visible);
    if (empty) empty.hidden = visible !== 0;
  }

  search?.addEventListener('input', () => {
    activeQuery = search.value;
    applyFilters();
  });

  petChips.forEach(chip => {
    chip.addEventListener('click', () => {
      petChips.forEach(c => c.setAttribute('aria-pressed', 'false'));
      chip.setAttribute('aria-pressed', 'true');
      activePet = (chip.dataset.filterPet ?? 'all') as typeof activePet;
      applyFilters();
    });
  });

  sevChips.forEach(chip => {
    chip.addEventListener('click', () => {
      sevChips.forEach(c => c.setAttribute('aria-pressed', 'false'));
      chip.setAttribute('aria-pressed', 'true');
      activeSev = (chip.dataset.filterSev ?? 'all') as typeof activeSev;
      applyFilters();
    });
  });

  document.querySelectorAll<HTMLButtonElement>('.faq-q').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
      const answer = btn.nextElementSibling as HTMLElement | null;
      if (answer) answer.hidden = expanded;
      const icon = btn.querySelector('.faq-icon');
      if (icon) icon.textContent = expanded ? '+' : '−';
    });
  });
</script>

