// Group by severity for the legend / filtering
const COUNTS = {
  safe: FLOWERS.filter(f => f.cat.level === 'safe' && f.dog.level === 'safe').length,
  mild: FLOWERS.filter(f => (f.cat.level === 'mild' || f.dog.level === 'mild') && f.cat.level !== 'severe' && f.dog.level !== 'severe' && f.cat.level !== 'lethal' && f.dog.level !== 'lethal').length,
  severe: FLOWERS.filter(f => (f.cat.level === 'severe' || f.dog.level === 'severe') && f.cat.level !== 'lethal' && f.dog.level !== 'lethal').length,
  lethal: FLOWERS.filter(f => f.cat.level === 'lethal' || f.dog.level === 'lethal').length,
};

