---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PagefindMeta from '../../components/PagefindMeta.astro';

export const prerender = true;

const lang = 'en' as const;
const siteUrl = (Astro.site?.toString() ?? import.meta.env.SITE_URL ?? 'https://ai-florist-coach-blog.vercel.app').replace(/\/$/, '');

const hreflang = [
  { lang: 'en', url: `${siteUrl}/tools/pet-safe-checker/` },
  { lang: 'vi', url: `${siteUrl}/vi/tools/pet-safe-checker/` },
  { lang: 'x-default', url: `${siteUrl}/tools/pet-safe-checker/` },
];

const breadcrumbs = [
  { name: 'Home', url: `${siteUrl}/` },
  { name: 'Tools', url: `${siteUrl}/tools/` },
  { name: 'Pet-Safe Flower Checker', url: `${siteUrl}/tools/pet-safe-checker/` },
];

type Severity = 'safe' | 'mild' | 'severe' | 'lethal';

interface PetStatus {
  level: Severity;
  symptoms?: string;
  notes?: string;
}

interface FlowerEntry {
  name: string;
  scientific: string;
  emoji: string;
  glossarySlug: string | null;
  cat: PetStatus;
  dog: PetStatus;
  horse: PetStatus;
  toxicCompound: string | null;
  aspcaUrl?: string;
  aliases?: string[];
}

// Data sourced primarily from the ASPCA Toxic and Non-Toxic Plants database
// (https://www.aspca.org/pet-care/animal-poison-control/toxic-and-non-toxic-plants)
// and the Pet Poison Helpline. Severity buckets are simplified for at-a-glance use:
//   safe   — non-toxic per ASPCA, no clinical signs expected from incidental contact
//   mild   — GI upset, oral irritation, dermatitis; usually self-limiting
//   severe — vet visit needed; significant systemic effects
//   lethal — can be fatal, especially without rapid intervention
