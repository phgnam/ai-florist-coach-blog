<script>
  // ── Month tab switching ────────────────────────────────────────────
  const monthTabs = document.querySelectorAll<HTMLElement>('.month-tab');
  const monthPanels = document.querySelectorAll<HTMLElement>('.month-panel');

  monthTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const mi = Number(tab.dataset.month);
      monthTabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
      monthPanels.forEach(p => { p.hidden = true; });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
      const panel = document.getElementById(`panel-${mi}`);
      if (panel) panel.hidden = false;
    });
  });

  // ── View toggle ────────────────────────────────────────────────────
  const btnMonth = document.getElementById('btn-by-month')!;
  const btnFlower = document.getElementById('btn-by-flower')!;
  const viewMonth = document.getElementById('view-by-month')!;
  const viewFlower = document.getElementById('view-by-flower')!;

  btnMonth.addEventListener('click', () => {
    btnMonth.classList.add('active'); btnMonth.setAttribute('aria-pressed', 'true');
    btnFlower.classList.remove('active'); btnFlower.setAttribute('aria-pressed', 'false');
    viewMonth.removeAttribute('hidden');
    viewFlower.hidden = true;
  });

  btnFlower.addEventListener('click', () => {
    btnFlower.classList.add('active'); btnFlower.setAttribute('aria-pressed', 'true');
    btnMonth.classList.remove('active'); btnMonth.setAttribute('aria-pressed', 'false');
    viewFlower.removeAttribute('hidden');
    viewMonth.hidden = true;
  });

  // ── FAQ accordion ──────────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.faq-item').forEach(item => {
    const btn = item.querySelector<HTMLButtonElement>('.faq-q')!;
    const ans = item.querySelector<HTMLElement>('.faq-a')!;
    btn.addEventListener('click', () => {
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(el => {
        el.classList.remove('open');
        el.querySelector<HTMLButtonElement>('.faq-q')!.setAttribute('aria-expanded', 'false');
        (el.querySelector<HTMLElement>('.faq-a')!).hidden = true;
      });
      if (!isOpen) {
        item.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
        ans.hidden = false;
      }
    });
  });
</script>
