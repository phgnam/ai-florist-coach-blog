---
import { getCollection } from 'astro:content';
import TagPostsListing from '../../../../components/TagPostsListing.astro';
import { tagPaginationPaths } from '../../../../lib/tag-pages';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft && data.lang === 'en');
  return tagPaginationPaths(posts);
}

const { tag } = Astro.params;
const { posts, currentPage, totalPages, totalPosts } = Astro.props;
---
<TagPostsListing
  lang="en"
  tag={tag}
  posts={posts}
  currentPage={currentPage}
  totalPages={totalPages}
  totalPosts={totalPosts}
  basePath={`/tags/${tag}`}
  postSlugPrefix="/posts"
/>
