---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import TagList from '../../components/TagList.astro';
import Giscus from '../../components/Giscus.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import AuthorBox from '../../components/AuthorBox.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'en' as const;
const t = useTranslations(lang);
const siteUrl = (Astro.site?.toString() ?? 'https://vuon-hoa.replit.app').replace(/\/$/, '');

function readingTime(body: string): number {
  const text = body.replace(/<[^>]+>/g, ' ').replace(/import\s+[^;]+;/g, ' ');
  const words = text.trim().split(/\s+/).filter((w) => /\w/.test(w)).length;
  return Math.max(1, Math.round(words / 200));
}

function firstBodyImage(body: string): string | undefined {
  return body?.match(/<figure>[\s\S]*?<img[^>]+src="([^"]+)"/)?.[1] ?? undefined;
}

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft && data.lang === 'en');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const allPosts = await getCollection('posts', ({ data }) => !data.draft && data.lang === 'en');
const { Content } = await render(post);
const { title, description, pubDate, updatedDate, heroImage, heroAlt, tags = [], author } = post.data;

const mins = readingTime(post.body);
const ogImage = heroImage?.src ?? firstBodyImage(post.body);

const hreflang = [
  { lang: 'en', url: `${siteUrl}/posts/${post.id}` },
  { lang: 'x-default', url: `${siteUrl}/posts/${post.id}` },
];

const breadcrumbs = [
  { name: 'Home', url: `${siteUrl}/` },
  { name: 'Articles', url: `${siteUrl}/posts` },
  { name: title, url: `${siteUrl}/posts/${post.id}` },
];
---
<BaseLayout
  lang={lang}
  title={title}
  description={description}
  image={ogImage}
  type="article"
  padTop={false}
  pubDate={pubDate}
  updatedDate={updatedDate}
  author={author}
  tags={tags}
  hreflang={hreflang}
  breadcrumbs={breadcrumbs}
>
  <div id="reading-progress"></div>

  <div class="post-hero">
    {heroImage ? (
      <img src={heroImage.src} alt={heroAlt ?? title} width={heroImage.width} height={heroImage.height} class="post-hero-img" />
    ) : (
      <div class="post-hero-placeholder"></div>
    )}
    <div class="post-hero-overlay"></div>
    <div class="post-hero-content max-w-4xl mx-auto px-6">
      <div class="fade-up fade-up-1">
        {tags.length > 0 && <span class="post-category">{tags[0]}</span>}
      </div>
      <h1 class="post-hero-title fade-up fade-up-2">{title}</h1>
      <div class="post-hero-meta fade-up fade-up-3">
        <span class="post-author">✍ {author}</span>
        <span class="post-dot">·</span>
        <FormattedDate date={pubDate} lang={lang} />
        <span class="post-dot">·</span>
        <span class="post-reading-time">⏱ {mins} {t('post.readingTime')}</span>
        {updatedDate && (
          <>
            <span class="post-dot">·</span>
            <span>{t('post.updated')} <FormattedDate date={updatedDate} lang={lang} /></span>
          </>
        )}
      </div>
    </div>
  </div>

  <aside id="toc-sidebar" aria-label="Table of contents">
    <p class="toc-title">Contents</p>
    <nav id="toc-nav"></nav>
  </aside>

  <div class="post-content-wrap">
    <div class="post-content max-w-4xl mx-auto px-6 py-14">
      {tags.length > 0 && (
        <div class="mb-10 fade-up fade-up-1">
          <TagList tags={tags} />
        </div>
      )}
      <div class="prose prose-lg fade-up fade-up-2">
        <Content />
      </div>
      <div class="post-divider my-16 fade-up fade-up-3"></div>
      <div class="share-box fade-up fade-up-4">
        <p class="share-text">{t('post.share')}</p>
        <div class="share-tags">
          {tags.map(tag => <span class="share-tag">#{tag}</span>)}
        </div>
        <div class="social-share" aria-label="Social sharing">
          <a class="share-btn share-btn--x" href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(`${siteUrl}/posts/${post.id}`)}&text=${encodeURIComponent(title)}`} target="_blank" rel="noreferrer">X / Twitter</a>
          <a class="share-btn share-btn--facebook" href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(`${siteUrl}/posts/${post.id}`)}`} target="_blank" rel="noreferrer">Facebook</a>
          <button class="share-btn share-btn--copy" type="button" data-copy-url={`${siteUrl}/posts/${post.id}`}>Copy link</button>
        </div>
      </div>

      <AuthorBox author={author} lang={lang} />

      <RelatedPosts
        currentId={post.id}
        currentTags={tags}
        allPosts={allPosts}
        lang={lang}
        postBasePath="/posts"
      />

      <section class="mt-16">
        <h2 class="comments-title">{t('post.comments')}</h2>
        <Giscus />
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  #reading-progress { position:fixed; top:0; left:0; width:0%; height:3px; background:linear-gradient(to right, #E8A4B0, #C47A8A, #9B5968); z-index:9999; transition:width 0.1s linear; border-radius:0 2px 2px 0; box-shadow:0 0 8px rgba(196,122,138,0.5); }
  .post-hero { position:relative; min-height:560px; display:flex; align-items:flex-end; overflow:hidden; background:linear-gradient(155deg,#FDF0F2 0%,#F0D8E0 40%,#C47A8A 100%); }
  .post-hero-img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; opacity:0.38; }
  .post-hero-placeholder { position:absolute; inset:0; background:linear-gradient(155deg,#FDF0F2 0%,#F0D0D8 40%,#B86878 100%); }
  .post-hero-overlay { position:absolute; inset:0; background:linear-gradient(to top,rgba(58,32,40,0.72) 0%,rgba(74,45,53,0.28) 55%,transparent 100%); pointer-events:none; }
  .post-hero-content { position:relative; z-index:10; padding-bottom:4rem; width:100%; }
  .post-category { display:inline-flex; align-items:center; gap:0.45rem; font-family:'Jost',sans-serif; font-size:0.65rem; font-weight:600; letter-spacing:0.26em; text-transform:uppercase; color:rgba(255,255,255,0.9); border:1px solid rgba(255,255,255,0.32); padding:0.3rem 0.95rem; border-radius:999px; margin-bottom:1.4rem; background:rgba(255,255,255,0.1); backdrop-filter:blur(8px); -webkit-backdrop-filter:blur(8px); }
  .post-hero-title { font-family:'Cormorant Garamond',Georgia,serif; font-size:clamp(2rem,4.8vw,3.6rem); font-weight:600; color:white; line-height:1.1; margin:0 0 1.35rem; max-width:860px; text-shadow:0 2px 24px rgba(58,32,40,0.18); letter-spacing:-0.01em; }
  .post-hero-meta { display:flex; flex-wrap:wrap; align-items:center; gap:0.55rem; font-family:'Jost',sans-serif; font-size:0.83rem; color:rgba(255,255,255,0.65); font-weight:300; }
  .post-author { color:rgba(255,255,255,0.88); font-weight:400; }
  .post-dot { color:rgba(255,255,255,0.28); }
  .post-reading-time { color:rgba(255,255,255,0.75); }
  .post-content-wrap { background:var(--ivory); position:relative; }
  .prose figure { margin:2.75rem 0; }
  .prose figure img { width:100%; border-radius:14px; display:block; box-shadow:0 6px 32px rgba(74,45,53,0.1); }
  .prose figure figcaption { font-family:'Jost',sans-serif; font-size:0.76rem; color:var(--taupe); text-align:center; margin-top:0.6rem; font-style:italic; opacity:0.8; letter-spacing:0.02em; }
  .post-divider { height:1px; background:linear-gradient(to right,transparent,rgba(232,164,176,0.38),transparent); }
  .share-box { background:linear-gradient(105deg,var(--blush-light),rgba(253,240,242,0.7)); border-left:2px solid var(--blush-dark); padding:1.75rem 2.25rem; border-radius:0 18px 18px 0; }
  .share-text { font-family:'Cormorant Garamond',serif; font-size:1.15rem; font-style:italic; color:var(--mauve); margin:0 0 0.85rem; font-weight:400; line-height:1.5; }
  .share-tags { display:flex; flex-wrap:wrap; gap:0.5rem; margin-bottom:1.1rem; }
  .share-tag { font-family:'Jost',sans-serif; font-size:0.76rem; color:var(--blush-dark); font-weight:500; letter-spacing:0.04em; }
  .social-share { display:flex; flex-wrap:wrap; gap:0.65rem; }
  .share-btn { appearance:none; cursor:pointer; display:inline-flex; align-items:center; justify-content:center; padding:0.65rem 1.15rem; border-radius:999px; font-family:'Jost',sans-serif; font-size:0.76rem; font-weight:500; letter-spacing:0.05em; text-decoration:none; color:var(--mauve); background:white; border:1px solid rgba(232,164,176,0.32); transition:transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease, color 0.22s ease; }
  .share-btn:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(196,122,138,0.14); border-color:rgba(196,122,138,0.4); color:var(--blush-dark); }
  .share-btn--x { background:#111827; color:white; border-color:#111827; }
  .share-btn--x:hover { color:white; }
  .share-btn--facebook { background:#1877f2; color:white; border-color:#1877f2; }
  .share-btn--facebook:hover { color:white; }
  .share-btn--copy.copied { background:var(--blush-dark); color:white; border-color:var(--blush-dark); }
  .comments-title { font-family:'Cormorant Garamond',serif; font-size:1.85rem; font-weight:600; color:var(--mauve); margin-bottom:1.5rem; padding-bottom:0.75rem; border-bottom:1px solid rgba(232,164,176,0.28); }

  /* ── TOC Sidebar ── */
  #toc-sidebar { display: none; position: fixed; top: 50%; right: max(1.5rem, calc(50vw - 32rem - 260px)); transform: translateY(-50%); width: 220px; max-height: 70vh; overflow-y: auto; padding: 1.25rem 1rem; background: rgba(255,255,255,0.85); backdrop-filter: blur(12px); border: 1px solid var(--ivory-dark); border-radius: 16px; box-shadow: 0 4px 24px rgba(196,122,138,0.10); z-index: 800; scrollbar-width: none; }
  #toc-sidebar::-webkit-scrollbar { display: none; }
  @media (min-width: 1400px) { #toc-sidebar { display: block; } }
  .toc-title { font-family: 'Jost', sans-serif; font-size: 0.62rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--taupe); margin: 0 0 0.9rem; padding-bottom: 0.6rem; border-bottom: 1px solid var(--ivory-dark); }
  :global(#toc-nav a) { display: block; font-family: 'Jost', sans-serif; font-size: 0.78rem; font-weight: 400; color: var(--taupe); text-decoration: none; padding: 0.3rem 0.5rem; margin-bottom: 0.15rem; border-left: 2px solid transparent; border-radius: 0 6px 6px 0; line-height: 1.45; transition: color 0.2s, border-color 0.2s, background 0.2s; }
  :global(#toc-nav a.toc-h3) { padding-left: 1.1rem; font-size: 0.73rem; }
  :global(#toc-nav a:hover) { color: var(--blush-dark); background: rgba(232,164,176,0.08); }
  :global(#toc-nav a.toc-active) { color: var(--blush-dark); border-left-color: var(--blush-dark); font-weight: 500; background: rgba(232,164,176,0.12); }
</style>

<script define:vars={{ postSlug: post.id }}>
  const bar = document.getElementById('reading-progress');
  if (bar) {
    window.addEventListener('scroll', () => {
      const docH = document.documentElement.scrollHeight - window.innerHeight;
      bar.style.width = (docH > 0 ? (window.scrollY / docH) * 100 : 0) + '%';
    }, { passive: true });
  }

  try {
    const key = 'vh_views_' + postSlug;
    const cur = parseInt(localStorage.getItem(key) || '0');
    localStorage.setItem(key, String(cur + 1));
  } catch (_) {}

  const tocNav = document.getElementById('toc-nav');
  const tocSidebar = document.getElementById('toc-sidebar');
  if (tocNav && tocSidebar) {
    const prose = document.querySelector('.prose');
    const headings = prose ? Array.from(prose.querySelectorAll('h2, h3')) : [];
    if (headings.length >= 2) {
      headings.forEach((h, i) => {
        if (!h.id) h.id = 'toc-' + i;
        const a = document.createElement('a');
        a.href = '#' + h.id;
        a.textContent = h.textContent ?? '';
        if (h.tagName === 'H3') a.classList.add('toc-h3');
        a.addEventListener('click', (e) => {
          e.preventDefault();
          document.getElementById(h.id)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
        tocNav.appendChild(a);
      });

      const links = Array.from(tocNav.querySelectorAll('a'));
      let activeId = '';
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) activeId = entry.target.id;
        });
        links.forEach(link => {
          const active = link.getAttribute('href') === '#' + activeId;
          link.classList.toggle('toc-active', active);
          if (active) link.scrollIntoView({ block: 'nearest' });
        });
      }, { rootMargin: '-64px 0px -60% 0px', threshold: 0 });

      headings.forEach(h => observer.observe(h));
    } else {
      tocSidebar.style.display = 'none';
    }
  }

  const copyButtons = Array.from(document.querySelectorAll('[data-copy-url]'));
  copyButtons.forEach((button) => {
    button.addEventListener('click', async () => {
      const url = button.getAttribute('data-copy-url') ?? window.location.href;
      try {
        await navigator.clipboard.writeText(url);
        button.classList.add('copied');
        const original = button.textContent;
        button.textContent = 'Copied!';
        window.setTimeout(() => {
          button.textContent = original;
          button.classList.remove('copied');
        }, 1600);
      } catch {
        window.prompt('Copy this link', url);
      }
    });
  });
</script>