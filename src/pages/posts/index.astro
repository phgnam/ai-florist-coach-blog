---
import { getCollection } from 'astro:content';
import PostsListing from '../../components/PostsListing.astro';
import { useTranslations } from '../../i18n/utils';
import { paginate } from '../../lib/posts-pagination';

export const prerender = true;

const lang = 'en' as const;
const t = useTranslations(lang);

const allPosts = (await getCollection('posts', ({ data }) => !data.draft && data.lang === 'en'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const { slice: posts, currentPage, totalPages } = paginate(allPosts, 1);
---
<PostsListing
  lang={lang}
  title={t('posts.title')}
  description={t('posts.sub')}
  posts={posts}
  currentPage={currentPage}
  totalPages={totalPages}
  basePath="/posts"
  postSlugPrefix="/posts"
/>
