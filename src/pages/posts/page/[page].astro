---
import { getCollection } from 'astro:content';
import PostsListing from '../../../components/PostsListing.astro';
import { useTranslations } from '../../../i18n/utils';

export const prerender = true;

const POSTS_PER_PAGE = 36;
const lang = 'en' as const;

export async function getStaticPaths() {
  const POSTS_PER_PAGE = 36;
  const allPosts = (await getCollection('posts', ({ data }) => !data.draft && data.lang === 'en'))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  const totalPages = Math.max(1, Math.ceil(allPosts.length / POSTS_PER_PAGE));
  // Page 1 lives at /posts (index.astro). Generate pages 2..N here.
  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, i) => {
    const page = i + 2;
    const posts = allPosts.slice((page - 1) * POSTS_PER_PAGE, page * POSTS_PER_PAGE);
    return {
      params: { page: String(page) },
      props: { posts, currentPage: page, totalPages },
    };
  });
}

const { posts, currentPage, totalPages } = Astro.props;
const t = useTranslations(lang);
---
<PostsListing
  lang={lang}
  title={t('posts.title')}
  description={t('posts.sub')}
  posts={posts}
  currentPage={currentPage}
  totalPages={totalPages}
  basePath="/posts"
  postSlugPrefix="/posts"
/>
