---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import { useTranslations } from '../../../i18n/utils';

const lang = 'en' as const;
const t = useTranslations(lang);

const posts = (await getCollection('posts', ({ data }) => !data.draft && data.lang === 'en'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout lang={lang} title={t('posts.title')} description={t('posts.sub')} padTop={false}>

  <div class="page-header">
    <div class="header-deco" aria-hidden="true">
      <svg viewBox="0 0 300 280" fill="none">
        <ellipse cx="220" cy="100" rx="55" ry="28" fill="rgba(196,122,138,0.13)" transform="rotate(20 220 100)"/>
        <ellipse cx="260" cy="180" rx="40" ry="20" fill="rgba(232,164,176,0.1)" transform="rotate(-15 260 180)"/>
        <circle cx="200" cy="50" r="8" fill="rgba(200,149,106,0.25)"/>
      </svg>
    </div>
    <div class="max-w-7xl mx-auto px-6 lg:px-10 py-24 text-center" style="position:relative;z-index:2">
      <p class="page-eyebrow">{t('posts.eyebrow')}</p>
      <h1 class="page-title">{t('posts.title')}</h1>
      <p class="page-sub">{t('posts.sub')}</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 lg:px-10 py-14">
    {posts.length === 0 ? (
      <div class="empty-state">
        <span class="empty-icon">🌱</span>
        <p>{t('posts.empty')}</p>
      </div>
    ) : (
      <div class="posts-grid">
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={`/en/posts/${post.id}`}
            tags={post.data.tags}
            heroImage={post.data.heroImage as any}
            heroAlt={post.data.heroAlt}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .page-header { background:linear-gradient(160deg,#FDF0F2 0%,#F5E6EA 50%,#EDA8B8 100%); position:relative; overflow:hidden; }
  .page-header::after { content:''; position:absolute; bottom:-1px; left:0; right:0; height:80px; background:linear-gradient(to top,var(--ivory),transparent); }
  .header-deco { position:absolute; right:0; top:0; bottom:0; width:320px; pointer-events:none; opacity:0.8; }
  .header-deco svg { width:100%; height:100%; }
  .page-eyebrow { font-family:'Jost',sans-serif; font-size:0.68rem; font-weight:500; letter-spacing:0.3em; text-transform:uppercase; color:var(--gold); margin-bottom:1rem; }
  .page-title { font-family:'Cormorant Garamond',Georgia,serif; font-size:clamp(2.8rem,7vw,5rem); font-weight:300; color:var(--mauve); line-height:1.08; margin:0 0 1.2rem; }
  .page-sub { font-family:'Jost',sans-serif; color:var(--mauve-mid); font-size:1rem; font-weight:300; max-width:460px; margin:0 auto; line-height:1.7; }
  .posts-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:1.75rem; }
  .empty-state { text-align:center; padding:6rem 0; color:var(--taupe); }
  .empty-icon { display:block; font-size:3rem; margin-bottom:1rem; }
</style>
