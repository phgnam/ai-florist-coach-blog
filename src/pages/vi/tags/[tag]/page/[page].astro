---
import { getCollection } from 'astro:content';
import TagPostsListing from '../../../../../components/TagPostsListing.astro';
import { tagPaginationPaths } from '../../../../../lib/tag-pages';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft && data.lang === 'vi');
  return tagPaginationPaths(posts);
}

const { tag } = Astro.params;
const { posts, currentPage, totalPages, totalPosts } = Astro.props;
---
<TagPostsListing
  lang="vi"
  tag={tag}
  posts={posts}
  currentPage={currentPage}
  totalPages={totalPages}
  totalPosts={totalPosts}
  basePath={`/vi/tags/${tag}`}
  postSlugPrefix="/vi/posts"
/>
