---
import { getCollection } from 'astro:content';
import PostsListing from '../../../../components/PostsListing.astro';
import { paginate } from '../../../../lib/posts-pagination';

export const prerender = true;

const lang = 'vi' as const;

export async function getStaticPaths() {
  const allPosts = (await getCollection('posts', ({ data }) => !data.draft && data.lang === 'vi'))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  const { totalPages } = paginate(allPosts, 1);
  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, i) => {
    const pageNumber = i + 2;
    const { slice } = paginate(allPosts, pageNumber);
    return {
      params: { page: String(pageNumber) },
      props: { posts: slice, currentPage: pageNumber, totalPages },
    };
  });
}

const { posts, currentPage, totalPages } = Astro.props;
---
<PostsListing
  lang={lang}
  title="Tất cả bài viết"
  description="Danh sách tất cả bài viết trên Yor Flower"
  posts={posts}
  currentPage={currentPage}
  totalPages={totalPages}
  basePath="/vi/posts"
  postSlugPrefix="/vi/posts"
/>
