---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations, localePath } from '../../i18n/utils';
import { getCollection } from 'astro:content';

export const prerender = true;

const lang = 'vi' as const;
const t = useTranslations(lang);
const p = (path: string) => localePath(lang, path);

const posts = await getCollection(
  'posts',
  ({ data }: { data: { draft?: boolean; lang: string } }) => !data.draft && data.lang === lang,
);
const articleCount = posts.length;

const tagCount = new Map<string, number>();
for (const post of posts) {
  for (const tag of (post.data.tags ?? []) as string[]) {
    tagCount.set(tag, (tagCount.get(tag) ?? 0) + 1);
  }
}
const allTags = [...tagCount.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .map(([tag]) => tag);

const sectionLabels = {
  article: t('search.section.article'),
  glossary: t('search.section.glossary'),
  tool: t('search.section.tool'),
  guide: t('search.section.guide'),
};
---

<BaseLayout lang={lang} title="Tìm kiếm — Vườn Hoa" description={t('search.sub')} padTop={false}>

  <div class="page-header">
    <div class="max-w-3xl mx-auto px-6 lg:px-10 py-20 text-center" style="position:relative;z-index:2">
      <p class="page-eyebrow">{t('search.title')}</p>
      <h1 class="page-title">{t('search.title')}</h1>
      <p class="page-sub">{t('search.sub')}</p>
    </div>
  </div>

  <div class="max-w-3xl mx-auto px-6 lg:px-10 pb-20">

    <div class="search-box">
      <div class="search-input-wrap">
        <svg class="si" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input
          id="page-search-input"
          type="search"
          placeholder={t('search.placeholder')}
          autocomplete="off"
          spellcheck="false"
          autofocus
        />
      </div>
      <p id="page-search-meta" class="search-meta" aria-live="polite"></p>
    </div>

    <div class="tag-filters">
      <p class="tag-filters-label">{t('search.filterByTag')}</p>
      <div class="tag-pills">
        <button class="tag-pill tag-pill--active" data-tag="">
          {t('search.allTopics')}
        </button>
        {allTags.map((tag) => (
          <button class="tag-pill" data-tag={tag}>#{tag}</button>
        ))}
      </div>
    </div>

    <div
      id="page-search-results"
      class="results-grid"
      data-lang={lang}
      data-no-results={t('search.noResults')}
      data-results-text={t('search.results')}
      data-section-article={sectionLabels.article}
      data-section-glossary={sectionLabels.glossary}
      data-section-tool={sectionLabels.tool}
      data-section-guide={sectionLabels.guide}
    ></div>

    <div id="page-search-empty" class="empty-state hidden">
      <span class="empty-icon">🔍</span>
      <p id="page-search-msg"></p>
      <p class="empty-hint">{t('search.hint')}</p>
      <a href={p('/posts')} class="browse-link">Xem tất cả bài viết →</a>
    </div>

    <div id="page-search-initial" class="initial-hint">
      <p>Bắt đầu gõ để tìm trong {articleCount} bài viết, từ điển, công cụ và hướng dẫn.</p>
    </div>

  </div>
</BaseLayout>

<style>
  .page-header {
    background: linear-gradient(160deg, var(--blush) 0%, var(--ivory) 60%);
    border-bottom: 1px solid var(--ivory-dark);
  }
  .page-eyebrow {
    font-family: 'Jost', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--blush-dark);
    margin-bottom: 0.75rem;
  }
  .page-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--mauve);
    font-weight: 400;
    margin: 0 0 1rem;
    line-height: 1.1;
  }
  .page-sub {
    font-family: 'Jost', sans-serif;
    font-size: 1rem;
    color: var(--taupe);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.6;
    font-weight: 300;
  }

  .search-box { margin-bottom: 1.5rem; }
  .search-input-wrap {
    display: flex;
    align-items: center;
    gap: 12px;
    background: white;
    border: 2px solid rgba(196, 122, 138, 0.35);
    border-radius: 14px;
    padding: 14px 20px;
    box-shadow: 0 4px 20px rgba(196, 122, 138, 0.08);
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .search-input-wrap:focus-within {
    border-color: var(--blush-dark);
    box-shadow: 0 0 0 4px rgba(196, 122, 138, 0.12), 0 4px 20px rgba(196, 122, 138, 0.1);
  }
  .si { color: var(--taupe); flex-shrink: 0; }
  #page-search-input {
    flex: 1;
    border: none;
    outline: none;
    font-family: 'Jost', sans-serif;
    font-size: 1.1rem;
    color: var(--mauve);
    background: transparent;
  }
  #page-search-input::placeholder { color: var(--taupe); opacity: 0.6; }
  #page-search-input::-webkit-search-cancel-button { display: none; }

  .search-meta {
    font-family: 'Jost', sans-serif;
    font-size: 0.78rem;
    color: var(--taupe);
    letter-spacing: 0.05em;
    margin: 10px 4px 0;
    min-height: 1em;
  }
  .search-meta:empty { display: none; }

  .tag-filters { margin-bottom: 2rem; }
  .tag-filters-label {
    font-family: 'Jost', sans-serif;
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--taupe);
    margin: 0 0 0.75rem;
  }
  .tag-pills { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .tag-pill {
    display: inline-block;
    padding: 0.35rem 1rem;
    border: 1px solid var(--ivory-dark);
    border-radius: 999px;
    font-family: 'Jost', sans-serif;
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--taupe);
    background: white;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.03em;
  }
  .tag-pill:hover { border-color: var(--blush-dark); color: var(--blush-dark); }
  .tag-pill--active {
    background: var(--blush-dark);
    border-color: var(--blush-dark);
    color: white;
  }

  .results-grid { display: flex; flex-direction: column; gap: 1.25rem; }

  .empty-state {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--taupe);
  }
  .empty-state.hidden { display: none; }
  .empty-icon { font-size: 2.5rem; display: block; margin-bottom: 1rem; opacity: 0.5; }
  .empty-state p { font-family: 'Jost', sans-serif; margin: 0 0 0.5rem; }
  .empty-hint { font-size: 0.85rem; color: var(--taupe); }
  .browse-link {
    display: inline-block;
    margin-top: 1rem;
    font-family: 'Jost', sans-serif;
    font-size: 0.85rem;
    color: var(--blush-dark);
    text-decoration: none;
    transition: color 0.2s;
  }
  .browse-link:hover { color: var(--mauve); }

  .initial-hint {
    text-align: center;
    padding: 3rem 1rem;
    font-family: 'Jost', sans-serif;
    font-size: 0.9rem;
    color: var(--taupe);
  }
</style>

<style is:global>
  .page-result-section + .page-result-section {
    border-top: 1px solid var(--ivory-dark);
    padding-top: 1.25rem;
    margin-top: 0.25rem;
  }
  .page-result-section-label {
    font-family: 'Jost', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--blush-dark);
    margin: 0 0 0.75rem;
  }
  .page-result-card {
    display: block;
    padding: 18px 22px;
    background: white;
    border: 1px solid var(--ivory-dark);
    border-radius: 12px;
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s;
    margin-bottom: 0.75rem;
  }
  .page-result-card:hover {
    border-color: rgba(196, 122, 138, 0.4);
    box-shadow: 0 4px 16px rgba(196, 122, 138, 0.1);
    transform: translateY(-1px);
  }
  .page-result-card-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--mauve);
    margin-bottom: 5px;
    line-height: 1.35;
  }
  .page-result-card-snippet,
  .page-result-card-desc {
    font-family: 'Jost', sans-serif;
    font-size: 0.85rem;
    color: var(--taupe);
    line-height: 1.5;
    margin-bottom: 10px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-weight: 300;
  }
  .page-result-card-snippet mark {
    background: rgba(232, 164, 176, 0.45);
    color: var(--mauve);
    padding: 0 2px;
    border-radius: 3px;
  }
  .page-result-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }
  .page-result-card-tag {
    font-family: 'Jost', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: rgba(232, 164, 176, 0.2);
    color: var(--blush-dark);
    border-radius: 999px;
    padding: 2px 9px;
  }
</style>

<script>
  import {
    escapeHtml,
    saveRecentSearch,
    trackSearchDebounced,
    loadPagefind,
    groupResultsByKind,
    type PagefindModule,
    type PagefindResultData,
  } from '../../lib/searchClient';

  const input = document.getElementById('page-search-input') as HTMLInputElement | null;
  const resultsEl = document.getElementById('page-search-results');
  const emptyEl = document.getElementById('page-search-empty');
  const emptyMsg = document.getElementById('page-search-msg');
  const initialEl = document.getElementById('page-search-initial');
  const metaEl = document.getElementById('page-search-meta');

  if (input && resultsEl && emptyEl && emptyMsg && initialEl && metaEl) {
    const lang = (resultsEl.dataset.lang as 'en' | 'vi') ?? 'en';
    const noResultsText = resultsEl.dataset.noResults ?? 'No results';
    const resultsText = resultsEl.dataset.resultsText ?? 'results';
    const sectionLabels: Record<string, string> = {
      article: resultsEl.dataset.sectionArticle ?? 'Articles',
      glossary: resultsEl.dataset.sectionGlossary ?? 'Glossary',
      tool: resultsEl.dataset.sectionTool ?? 'Tools',
      guide: resultsEl.dataset.sectionGuide ?? 'Guides',
    };

    let pagefind: PagefindModule | null = null;
    let activeTag = '';
    let lastSearchToken = 0;

    async function init() {
      pagefind = await loadPagefind();

      const params = new URLSearchParams(window.location.search);
      const tagParam = params.get('tag');
      if (tagParam) {
        activeTag = tagParam;
        document.querySelectorAll<HTMLButtonElement>('.tag-pill').forEach((pill) => {
          pill.classList.remove('tag-pill--active');
          if (pill.dataset.tag === tagParam) pill.classList.add('tag-pill--active');
        });
      }
      const q = params.get('q');
      if (q && input) {
        input.value = q;
      }
      runQuery(input!.value);
    }

    async function getResults(query: string): Promise<PagefindResultData[]> {
      const trimmed = query.trim();
      if (!pagefind) return [];

      const filters: Record<string, string | string[]> | undefined = activeTag
        ? { tag: activeTag }
        : undefined;

      const searchTerm = trimmed.length < 2 ? null : trimmed;
      if (searchTerm === null && !activeTag) return [];

      const token = ++lastSearchToken;
      const search = await pagefind.search(searchTerm, filters ? { filters } : undefined);
      if (token !== lastSearchToken) return [];

      const top = search.results.slice(0, 24);
      const hits = await Promise.all(top.map((r) => r.data()));
      if (token !== lastSearchToken) return [];
      return hits;
    }

    function render(hits: PagefindResultData[], query: string) {
      const trimmed = query.trim();
      const hasQuery = trimmed.length >= 2;
      if (!hasQuery && !activeTag) {
        resultsEl!.innerHTML = '';
        emptyEl!.classList.add('hidden');
        initialEl!.style.display = 'block';
        metaEl!.textContent = '';
        return;
      }
      initialEl!.style.display = 'none';

      if (hits.length === 0) {
        resultsEl!.innerHTML = '';
        if (emptyMsg) emptyMsg.textContent = `${noResultsText} "${trimmed || activeTag}"`;
        emptyEl!.classList.remove('hidden');
        metaEl!.textContent = `0 ${resultsText}`;
        return;
      }

      emptyEl!.classList.add('hidden');
      metaEl!.textContent = `${hits.length} ${resultsText}`;

      const grouped = groupResultsByKind(hits);
      resultsEl!.innerHTML = grouped
        .map((g) => {
          const items = g.hits
            .map((hit) => {
              const title = hit.meta.title ?? hit.url;
              const desc = hasQuery && hit.excerpt
                ? `<div class="page-result-card-snippet">${hit.excerpt}</div>`
                : hit.meta.description
                  ? `<div class="page-result-card-desc">${escapeHtml(hit.meta.description)}</div>`
                  : hit.excerpt
                    ? `<div class="page-result-card-snippet">${hit.excerpt}</div>`
                    : '';
              const tags = (hit.filters.tag ?? []).slice(0, 5);
              const tagsHtml =
                tags.length > 0
                  ? `<div class="page-result-card-tags">${tags
                      .map((tag) => `<span class="page-result-card-tag">${escapeHtml(tag)}</span>`)
                      .join('')}</div>`
                  : '';
              return `
                <a href="${hit.url}" class="page-result-card">
                  <div class="page-result-card-title">${escapeHtml(title)}</div>
                  ${desc}
                  ${tagsHtml}
                </a>`;
            })
            .join('');
          return `
            <div class="page-result-section">
              <p class="page-result-section-label">${sectionLabels[g.kind]}</p>
              ${items}
            </div>`;
        })
        .join('');
    }

    async function runQuery(query: string) {
      if (!pagefind) {
        emptyEl!.classList.remove('hidden');
        if (emptyMsg) emptyMsg.textContent = 'Search index unavailable in dev — run `npm run build`.';
        return;
      }
      const hits = await getResults(query);
      render(hits, query);
      const trimmed = query.trim();
      const url = new URL(window.location.href);
      if (trimmed) url.searchParams.set('q', trimmed);
      else url.searchParams.delete('q');
      if (activeTag) url.searchParams.set('tag', activeTag);
      else url.searchParams.delete('tag');
      history.replaceState({}, '', url);
      if (trimmed.length >= 2) {
        trackSearchDebounced(trimmed, lang, hits.length);
      }
    }

    document.querySelectorAll<HTMLButtonElement>('.tag-pill').forEach((pill) => {
      pill.addEventListener('click', () => {
        document.querySelectorAll<HTMLButtonElement>('.tag-pill').forEach((p) =>
          p.classList.remove('tag-pill--active')
        );
        pill.classList.add('tag-pill--active');
        activeTag = pill.dataset.tag || '';
        runQuery(input!.value);
      });
    });

    input!.addEventListener('input', (e) => {
      runQuery((e.target as HTMLInputElement).value);
    });

    input!.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        const q = input!.value.trim();
        if (q.length >= 2) saveRecentSearch(q);
      }
    });

    resultsEl.addEventListener('click', (e) => {
      const card = (e.target as HTMLElement).closest<HTMLAnchorElement>('.page-result-card');
      if (!card) return;
      const q = input!.value.trim();
      if (q.length >= 2) saveRecentSearch(q);
    });

    init();
  }
</script>
