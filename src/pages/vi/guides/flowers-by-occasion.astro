---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const lang = 'vi' as const;
const siteUrl = (Astro.site?.toString() ?? import.meta.env.SITE_URL ?? 'https://ai-florist-coach-blog.vercel.app').replace(/\/$/, '');

const hreflang = [
  { lang: 'en',        url: `${siteUrl}/guides/flowers-by-occasion/` },
  { lang: 'vi',        url: `${siteUrl}/vi/guides/flowers-by-occasion/` },
  { lang: 'x-default', url: `${siteUrl}/guides/flowers-by-occasion/` },
];
const breadcrumbs = [
  { name: 'Trang chủ', url: `${siteUrl}/vi/` },
  { name: 'Hoa theo dịp', url: `${siteUrl}/vi/guides/flowers-by-occasion/` },
];

const FLOWER_NAMES: Record<string,string> = {
  rose:'Hoa Hồng', peony:'Hoa Mẫu Đơn', ranunculus:'Hoa Mao Lương', tulip:'Hoa Tulip',
  lily:'Hoa Ly', sunflower:'Hoa Hướng Dương', orchid:'Hoa Lan', hydrangea:'Hoa Cẩm Tú Cầu',
  dahlia:'Hoa Thược Dược', anemone:'Hoa Hải Quỳ', 'sweet-pea':'Hoa Đậu Thơm', freesia:'Hoa Freesia',
  iris:'Hoa Diên Vĩ', carnation:'Hoa Cẩm Chướng', chrysanthemum:'Hoa Cúc',
  lavender:'Hoa Oải Hương', marigold:'Hoa Vạn Thọ', magnolia:'Hoa Mộc Lan',
  gardenia:'Hoa Dạ Lý Hương', jasmine:'Hoa Nhài',
};
const FLOWER_EMOJI: Record<string,string> = {
  rose:'🌹', peony:'🌸', ranunculus:'🌸', tulip:'🌷', lily:'🌷', sunflower:'🌻',
  orchid:'🌺', hydrangea:'💐', dahlia:'🌸', anemone:'🌸', 'sweet-pea':'🌸',
  freesia:'🌸', iris:'💜', carnation:'🌺', chrysanthemum:'🌼', lavender:'💜',
  marigold:'🌼', magnolia:'🌸', gardenia:'🤍', jasmine:'🌼',
};

interface Flower { id: string; note: string; }
interface Occasion {
  id: string; icon: string; name: string; tagline: string; intro: string;
  best: Flower[]; avoid: string; colors: string; colorDots: string[];
  proTip: string; combo: { flowers: string[]; label: string; url: string };
}

const OCCASIONS: Occasion[] = [
  {
    id: 'wedding', icon: '💍', name: 'Hoa Đám Cưới',
    tagline: 'Dịp hoa được tìm kiếm nhiều nhất thế giới',
    intro: 'Hoa đám cưới thiết lập toàn bộ tông màu hình ảnh của ngày trọng đại. Những loài hoa đám cưới tốt nhất là loài đúng mùa, có ý nghĩa với cặp đôi, và có thể chịu đựng một ngày lễ dài mà không héo. Đây là những lựa chọn được cộng đồng florist chứng minh nhiều nhất.',
    best: [
      { id: 'rose',      note: 'Có trong mọi tông trắng và hồng phấn; giữ tươi 6–8 giờ ngoài nước' },
      { id: 'peony',     note: 'Loài hoa đám cưới được thèm muốn nhất — đặt sớm, đỉnh tháng 5–6' },
      { id: 'hydrangea', note: 'Lấp đầy thể tích bó hoa đẹp; kết hợp với hầu hết mọi loài hoa' },
      { id: 'ranunculus',note: 'Cánh hoa phân lớp chụp ảnh đẹp như hoa hồng; nhẹ nhàng và tinh tế hơn' },
      { id: 'sweet-pea', note: 'Những tua rua buông thả thêm chuyển động cho bó hoa và vòm hoa' },
      { id: 'lily',      note: 'Hoa ly trắng cho lễ; cân nhắc loại bỏ nhị phấn cam để tránh ố vải' },
    ],
    avoid: 'Những loài hoa gây dị ứng như cúc gần khách mời; tránh hoa ly có mùi nồng nếu có người mang thai. Hoa vạn thọ mang liên tưởng đám tang trong một số văn hóa châu Á và châu Mỹ Latin.',
    colors: 'Trắng · Hồng phấn · Ngà · Champagne · Xanh lá nhạt',
    colorDots: ['#FFF5F7','#F5D5DC','#FFF8F0','#E8C99A','#C8D8C0'],
    proTip: 'Chọn hoa đúng mùa — mẫu đơn tháng 5–6, thược dược tháng 8–10. Hoa trái mùa đắt gấp 3–4 lần và đến từ nơi xa hơn, ảnh hưởng đến độ tươi. Hỏi florist của bạn xem mẫu ở trang trại trước khi quyết định.',
    combo: { flowers: ['rose','peony','hydrangea'], label: 'Hồng + Mẫu Đơn + Cẩm Tú Cầu — "Lãng Mạn Nồng Nàn"', url: '/vi/tools/combination-builder/' },
  },
  {
    id: 'sympathy', icon: '🕊️', name: 'Hoa Chia Buồn & Tang Lễ',
    tagline: 'Hoa gửi khi lời nói không đủ',
    intro: 'Hoa chia buồn truyền đạt sự quan tâm, bình yên và tôn trọng. Theo phổ quát, hoa trắng và nhạt màu là phù hợp nhất. Phong cách sắp xếp cũng quan trọng: bó hoa buộc tay mang tính cá nhân; vòng hoa hoặc cành cắm chính thức dành cho tang lễ.',
    best: [
      { id: 'lily',         note: 'Hoa ly trắng là loài hoa chia buồn được hiểu phổ quát nhất' },
      { id: 'chrysanthemum',note: 'Trong nhiều văn hóa châu Á, cúc trắng là hoa tang lễ điển hình' },
      { id: 'carnation',    note: 'Lâu bền và có màu trắng tinh khiết; lựa chọn trang trọng, cổ điển' },
      { id: 'orchid',       note: 'Hoa lan Phalaenopsis trắng cho lời tri ân hiện đại, lâu bền' },
      { id: 'iris',         note: 'Diên vĩ lam hoặc trắng đại diện cho đức tin, hy vọng và trí tuệ trong tang chế' },
