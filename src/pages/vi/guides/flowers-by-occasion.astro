      { id: 'iris',       note: 'Đại diện cho sự chu đáo và trí tuệ — rất phù hợp cho người cố vấn hoặc giáo viên' },
      { id: 'hydrangea',  note: 'Có nghĩa là lòng biết ơn chân thành trong ngôn ngữ hoa thời Victoria' },
      { id: 'sunflower',  note: 'Ấm áp, hào phóng, khiêm tốn — nói cảm ơn với nụ cười' },
      { id: 'carnation',  note: 'Lâu bền và chân thành; cẩm chướng hồng có nghĩa là "tôi sẽ không bao giờ quên bạn"' },
