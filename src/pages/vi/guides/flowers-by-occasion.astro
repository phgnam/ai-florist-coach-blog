    colors: 'Trắng · Kem · Oải hương nhạt · Lam nhạt · Vàng nhạt',
    colorDots: ['#FFFFFF','#FFF8F0','#E8D8F0','#C8D8E8','#FFFACC'],
    proTip: 'Hoa ly trắng là lựa chọn an toàn nhất cho mọi tình huống chia buồn. Nếu gửi đến bệnh viện hoặc nhà riêng, hãy loại bỏ nhị phấn cam — chúng làm ố quần áo và có thể gây dị ứng cho bệnh nhân suy giảm miễn dịch. Một sắp xếp đơn giản, thanh lịch nói lên nhiều hơn một bó hoa lớn phức tạp.',
    combo: { flowers: ['lily','orchid','carnation'], label: 'Hoa Ly + Hoa Lan + Cẩm Chướng — phẩm giá yên tĩnh, lâu bền', url: '/vi/tools/combination-builder/' },
  },
  {
    id: 'birthday', icon: '🎂', name: 'Hoa Sinh Nhật',
    tagline: 'Vui tươi, cá nhân, lễ kỷ niệm',
    intro: 'Hoa sinh nhật là linh hoạt nhất trong tất cả — gần như không có quy tắc, chỉ cần phản ánh tính cách của người nhận. Mục tiêu là niềm vui và năng lượng. Màu sắc táo bạo, kết cấu thú vị, và những loài hoa mà người nhận thực sự yêu thích luôn tốt hơn lựa chọn "đúng đắn".',
    best: [
      { id: 'sunflower', note: 'Tỏa ra niềm vui và năng lượng; lâu bền (7–10 ngày) và ấn tượng thị giác' },
      { id: 'dahlia',    note: 'Ngoạn mục cho sinh nhật cột mốc — táo bạo, kiến trúc, lễ kỷ niệm' },
      { id: 'rose',      note: 'Bất kỳ màu nào ngoại trừ trắng (truyền thống dành cho dịp trang trọng hơn)' },
      { id: 'tulip',     note: 'Vui vẻ và kiến trúc; tuyệt vời cho sinh nhật mùa xuân' },
      { id: 'freesia',   note: 'Thơm ngát và chu đáo; có trong mọi màu sắc' },
      { id: 'ranunculus',note: 'Cánh hoa ngọt ngào, phân lớp chụp ảnh đẹp; giữ được 7+ ngày' },
    ],
    avoid: 'Sắp xếp thuần trắng có thể đọc như hoa chia buồn trong một số ngữ cảnh. Ngoài ra, hầu hết mọi thứ đều được — rủi ro chính là gửi thứ gì đó người nhận bị dị ứng.',
    colors: 'Theo màu yêu thích của người nhận; hoặc chọn rực rỡ: san hô · vàng nắng · hồng fuchsia · tím',
    colorDots: ['#FF7043','#FDD835','#E91E8C','#7C4DFF','#4CAF50'],
    proTip: 'Cho sinh nhật cột mốc (30, 40, 50), hỏi florist để bao gồm đúng số cành đó như một dấu ấn cá nhân — 40 cành hoa yêu thích của người đó có ý nghĩa hơn nhiều so với bất kỳ sắp xếp chung chung nào. Freesia già đi đẹp và lâu 10+ ngày, là lựa chọn tốt nhất cho ai sống một mình.',
    combo: { flowers: ['sunflower','dahlia','rose'], label: 'Hướng Dương + Thược Dược + Hồng — sôi động và mừng vui', url: '/vi/tools/combination-builder/' },
  },
  {
    id: 'anniversary', icon: '💑', name: 'Hoa Kỷ Niệm',
    tagline: 'Từ năm đầu tiên đến năm vàng',
    intro: 'Hoa kỷ niệm theo truyền thống theo dõi sự tiến triển của một mối quan hệ — từ sự ngọt ngào của năm đầu tiên đến sự hoành tráng của nhiều thập kỷ bên nhau. Trong khi hoa hồng đỏ luôn phù hợp, việc phù hợp với loài hoa truyền thống cho năm đó là một cử chỉ thể hiện sự suy nghĩ.',
    best: [
      { id: 'rose',      note: 'Năm 1: một hoa hồng đỏ. Mọi năm: hoa hồng đỏ có nghĩa là tình yêu bền vững' },
      { id: 'carnation', note: 'Hoa kỷ niệm năm 1 theo truyền thống — đáng ngạc nhiên lãng mạn màu đỏ đậm hoặc san hô' },
      { id: 'iris',      note: 'Hoa kỷ niệm năm 25; cũng đại diện cho đức tin và ngưỡng mộ' },
      { id: 'orchid',    note: 'Tốt nhất cho kỷ niệm cột mốc (năm 10, 25, 50) — biểu hiện sự xa hoa sâu sắc' },
      { id: 'lily',      note: 'Sự thanh lịch và cam kết; hoa ly trắng cho kỷ niệm năm 30' },
      { id: 'gardenia',  note: 'Biểu hiện "em thật tuyệt vời" và tình yêu bền vững — lựa chọn rất cá nhân' },
    ],
    avoid: 'Hoa vàng trong một số văn hóa biểu hiện ghen tuông hoặc tình bạn hơn là tình yêu. Hoa xanh có thể đọc như lạnh lùng. Tránh bất cứ thứ gì có vẻ bình thường cho một kỷ niệm quan trọng.',
    colors: 'Đỏ · Hồng đậm · Đỏ đậm · Tím · Vàng · Champagne',
    colorDots: ['#C0392B','#E8618C','#7A2040','#6A1B9A','#B8860B','#E8C99A'],
    proTip: 'Hoa kỷ niệm theo năm truyền thống: năm 1 = Cẩm Chướng, năm 5 = Freesia (cho Cúc Vạn Thọ Nhỏ), năm 10 = Diên Vĩ (cho Thủy Tiên), năm 25 = Diên Vĩ, năm 50 = Hoa Hồng Vàng hoặc Hoa Lan. Ngay cả khi đối tác của bạn không biết truyền thống, bạn biết — và bạn có thể giải thích khi tặng hoa, điều này nhân đôi ý nghĩa của chúng.',
    combo: { flowers: ['rose','orchid','gardenia'], label: 'Hồng + Hoa Lan + Dạ Lý Hương — lãng mạn, xa hoa, khó quên', url: '/vi/tools/combination-builder/' },
  },
  {
    id: 'get-well', icon: '🌿', name: 'Hoa Chúc Mau Khỏe',
    tagline: 'Vui vẻ, hy vọng, nâng cao tinh thần',
    intro: 'Hoa chúc mau khỏe nên nâng cao tinh thần mà không áp đảo phòng bệnh. Những lựa chọn tốt nhất là những loài có màu sắc tươi sáng, ít phấn hoa, và đủ lâu để làm sáng phòng trong suốt thời gian hồi phục. Sắp xếp nhỏ, vui vẻ hoạt động tốt hơn những loại lớn trang trọng.',
    best: [
      { id: 'sunflower',  note: 'Loài hoa nâng cao tinh thần nhất — gương mặt của nó truyền đạt sự ấm áp và tích cực' },
