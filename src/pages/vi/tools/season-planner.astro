</style>

<script>
  const monthTabs = document.querySelectorAll<HTMLElement>('.month-tab');
  const monthPanels = document.querySelectorAll<HTMLElement>('.month-panel');
  monthTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const mi = Number(tab.dataset.month);
      monthTabs.forEach(t => t.classList.remove('active'));
      monthPanels.forEach(p => { p.hidden = true; });
      tab.classList.add('active');
      document.getElementById(`panel-${mi}`)!.hidden = false;
    });
  });
  const btnMonth = document.getElementById('btn-by-month')!;
  const btnFlower = document.getElementById('btn-by-flower')!;
  const viewMonth = document.getElementById('view-by-month')!;
  const viewFlower = document.getElementById('view-by-flower')!;
  btnMonth.addEventListener('click', () => {
    btnMonth.classList.add('active'); btnFlower.classList.remove('active');
    viewMonth.removeAttribute('hidden'); viewFlower.hidden = true;
  });
  btnFlower.addEventListener('click', () => {
    btnFlower.classList.add('active'); btnMonth.classList.remove('active');
    viewFlower.removeAttribute('hidden'); viewMonth.hidden = true;
  });
  document.querySelectorAll<HTMLElement>('.faq-item').forEach(item => {
    const btn = item.querySelector<HTMLButtonElement>('.faq-q')!;
    const ans = item.querySelector<HTMLElement>('.faq-a')!;
    btn.addEventListener('click', () => {
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(el => {
        el.classList.remove('open');
        (el.querySelector<HTMLElement>('.faq-a')!).hidden = true;
      });
      if (!isOpen) { item.classList.add('open'); ans.hidden = false; }
    });
  });
</script>
