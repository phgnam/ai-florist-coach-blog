---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const lang = 'vi' as const;
const siteUrl = (Astro.site?.toString() ?? 'https://vuon-hoa.replit.app').replace(/\/$/, '');

const hreflang = [
  { lang: 'en', url: `${siteUrl}/tools/combination-builder/` },
  { lang: 'vi', url: `${siteUrl}/vi/tools/combination-builder/` },
  { lang: 'x-default', url: `${siteUrl}/tools/combination-builder/` },
];
const breadcrumbs = [
  { name: 'Trang chủ', url: `${siteUrl}/vi/` },
  { name: 'Công cụ', url: `${siteUrl}/vi/tools/` },
  { name: 'Gợi ý kết hợp hoa', url: `${siteUrl}/vi/tools/combination-builder/` },
];

const FLOWERS = [
  { id: 'rose',         name: 'Hoa Hồng',        emoji: '🌹' },
  { id: 'peony',        name: 'Hoa Mẫu Đơn',    emoji: '🌸' },
  { id: 'ranunculus',   name: 'Hoa Mao Lương',   emoji: '🌸' },
  { id: 'tulip',        name: 'Hoa Tulip',       emoji: '🌷' },
  { id: 'lily',         name: 'Hoa Ly',          emoji: '🌷' },
  { id: 'sunflower',    name: 'Hoa Hướng Dương', emoji: '🌻' },
  { id: 'orchid',       name: 'Hoa Lan',         emoji: '🌺' },
  { id: 'hydrangea',    name: 'Hoa Cẩm Tú Cầu', emoji: '💐' },
  { id: 'dahlia',       name: 'Hoa Thược Dược',  emoji: '🌸' },
  { id: 'anemone',      name: 'Hoa Hải Quỳ',    emoji: '🌸' },
  { id: 'sweet-pea',    name: 'Hoa Đậu Thơm',   emoji: '🌸' },
  { id: 'freesia',      name: 'Hoa Freesia',     emoji: '🌸' },
  { id: 'iris',         name: 'Hoa Diên Vĩ',    emoji: '💜' },
  { id: 'carnation',    name: 'Hoa Cẩm Chướng', emoji: '🌺' },
  { id: 'chrysanthemum',name: 'Hoa Cúc',        emoji: '🌼' },
  { id: 'lavender',     name: 'Hoa Oải Hương',  emoji: '💜' },
  { id: 'marigold',     name: 'Hoa Vạn Thọ',   emoji: '🌼' },
  { id: 'magnolia',     name: 'Hoa Mộc Lan',    emoji: '🌸' },
  { id: 'gardenia',     name: 'Hoa Dạ Lý Hương',emoji: '🤍' },
  { id: 'jasmine',      name: 'Hoa Nhài',        emoji: '🌼' },
];

const flowerMap = Object.fromEntries(FLOWERS.map(f => [f.id, f]));

const COMBOS: Record<string, Array<{name:string;partners:[string,string];why:string;colors:string;style:string;season:string}>> = {
  rose: [
    { name:"Lãng Mạn Nồng Nàn",      partners:['peony','hydrangea'],   why:"Ba loài hoa đầu tròn ở ba tầm vóc khác nhau — mẫu đơn là ngôi sao, hồng là nét duyên, cẩm tú cầu lấp đầy không gian. Những cánh hoa lồng nhau trong tông hồng phấn tạo vẻ đẹp vườn hoa nở rộ điển hình của floristry cổ điển.",      colors:"Hồng phấn · Ngà · Hồng nhạt",        style:"Lãng mạn / Đám cưới", season:"Xuân–Hạ" },
    { name:"Vùng Quê Pháp",           partners:['lavender','freesia'],  why:"Oải hương tạo chuyển động theo chiều dọc và hương thơm; freesia uốn cong thêm chiều cao và mùi ngát. Cùng với hoa hồng, chúng tái hiện bảng màu nước hoa Provence cổ điển — ba loài hoa vườn được yêu thích nhất nước Pháp.",             colors:"Tím · Kem · Vàng nhạt",             style:"Lãng mạn / Đồng quê", season:"Xuân–Hạ" },
    { name:"Báu Vật Mùa Thu",         partners:['dahlia','anemone'],    why:"Thược dược sánh ngang với sự xa hoa của hồng; mắt gần đen của hải quỳ tạo tương phản nổi bật trước những cánh nhung. Tông trang sức phong phú — đỏ đậm, đỏ sâu, đen — mang đến cảm giác sang trọng cuối mùa.",                            colors:"Đỏ đậm · Đỏ sâu · Đen",            style:"Kịch tính / Ấn tượng",season:"Thu" },
    { name:"Trắng Tinh Khiết",        partners:['gardenia','magnolia'], why:"Ba bông hoa trắng và kem với hình dáng hoàn toàn khác nhau — hoa hồng với lớp cánh chồng, dạ lý hương với độ bóng sáp, mộc lan với hình ngôi sao. Thành phần đơn sắc tinh tế nhất trong floristry; hương thơm từ cả ba loài là phi thường.",  colors:"Trắng · Ngà · Kem",                 style:"Tối giản / Thanh lịch",season:"Xuân–Hạ" },
  ],
  peony: [
    { name:"Bộ Ba Xa Hoa",            partners:['rose','ranunculus'],   why:"Ba loài hoa đầu tròn ở ba tầm vóc khác nhau — mẫu đơn là ngôi sao, hồng là chủ đạo, mao lương là chi tiết dịu dàng. Cùng một bộ cánh lồng nhau tạo chiều sâu mà không đơn điệu.",                                                          colors:"Hồng phấn · Hồng · Ngà",            style:"Xa hoa / Đám cưới",   season:"Xuân" },
    { name:"Xuân Thơ Mộng",           partners:['sweet-pea','anemone'], why:"Đậu thơm uốn mình nhẹ nhàng làm nổi bật sự hùng vĩ của mẫu đơn; hình dáng giống hoa anh túc của hải quỳ với mắt đen tạo điểm nhấn tương phản với sự no tròn. Một bó hoa xuân phóng khoáng, đồng nội.",                                       colors:"Hồng nhạt · Tím · Trắng",           style:"Lãng mạn / Đồng quê", season:"Xuân" },
    { name:"Xuân Nhật Bản",           partners:['magnolia','iris'],     why:"Những bông mộc lan hình ngôi sao kết hợp với vẻ đẹp hình học của diên vĩ — mẫu đơn cung cấp điểm tương phản đầy đặn. Kết hợp này lấy cảm hứng từ nghệ thuật cắm hoa Đông Á, nơi hình dáng tương phản được đề cao.",                         colors:"Hồng nhạt · Trắng · Tím",           style:"Thanh lịch / Nghệ thuật",season:"Xuân" },
    { name:"Tiệc Vườn",               partners:['hydrangea','tulip'],   why:"Cẩm tú cầu lấp đầy không gian như đám mây; tulip thêm kết cấu đứng thẳng; mẫu đơn là ngôi sao thu hút mọi ánh nhìn. Ba loài yêu thích của vườn xuân mọc cùng nhau trong cùng khu đất.",                                                    colors:"Hồng · Hồng-lam · Kem",             style:"Vườn / Cổ điển",      season:"Xuân–Hạ" },
  ],
  ranunculus: [
    { name:"Giấc Mơ Đồng Cỏ",        partners:['anemone','sweet-pea'], why:"Ba loài hoa xuân mong manh với dáng hình tương phản — mao lương với lớp cánh chặt chẽ, hải quỳ với mặt mở, đậu thơm với tua rua buông thõng. Cùng nhau chúng trông như một nắm hoa hái từ đồng cỏ hoang dã.",                              colors:"Hồng · Tím · Trắng",                style:"Lãng mạn / Đồng quê", season:"Xuân" },
    { name:"Bó Hoa Chợ Xuân",         partners:['tulip','freesia'],     why:"Kết hợp chợ hoa lục địa cổ điển: tulip thẳng đứng tương phản mao lương tròn; freesia thêm hương thơm và chùm hoa cong. Bộ ba này tươi tắn và hoàn hảo theo mùa.",                                                                            colors:"Vàng · Đỏ · Kem",                   style:"Tươi mới / Cổ điển",  season:"Xuân" },
    { name:"Lãng Mạn Provence",       partners:['rose','lavender'],     why:"Hồng và mao lương đều có đầu hoa đầy đặn và kết hợp tự nhiên; oải hương tạo cầu nối bằng hương thơm và tông tím-xám bổ sung cho hồng và hồng nhạt.",                                                                                         colors:"Hồng phấn · Tím · Xanh lá-xám",    style:"Lãng mạn / Đồng quê", season:"Xuân–Hạ" },
    { name:"Tranh Tĩnh Vật",          partners:['iris','magnolia'],     why:"Hình học đậm nét của diên vĩ, dáng hoa cốc của mộc lan, và những lớp cánh của mao lương tạo nên bộ ba đọc như tranh tĩnh vật Hà Lan — ba hình dạng hoa riêng biệt chia sẻ bảng màu tự nhiên mềm mại.",                                      colors:"Tím · Trắng · Hồng nhạt",           style:"Nghệ thuật / Thanh lịch",season:"Xuân" },
  ],
  tulip: [
    { name:"Xuân Hà Lan",             partners:['iris','ranunculus'],   why:"Diên vĩ và tulip mọc trên cùng cánh đồng Hà Lan và là cặp đôi tự nhiên; mao lương làm mềm kết cấu bằng những lớp cánh tròn. Cả ba đạt đỉnh vào mùa xuân, luôn có sẵn và tươi ngon cùng nhau.",                                               colors:"Tím · Cam · Vàng",                  style:"Ấn tượng / Cổ điển",  season:"Xuân" },
    { name:"Vườn Anh",                partners:['rose','sweet-pea'],    why:"Quintessentially Anh Quốc — dáng thẳng của tulip kết hợp với cành hồng cong và những bông đậu thơm mỏng manh. Đây là sự kết hợp định nghĩa thẩm mỹ vườn nhà gỗ Anh.",                                                                         colors:"Hồng · Kem · Oải hương",            style:"Lãng mạn / Đồng quê", season:"Xuân" },
    { name:"Xuân Tối Giản",           partners:['magnolia','anemone'],  why:"Ba loài hoa với dáng hình đồ họa mạnh: cốc sạch của tulip, ngôi sao của mộc lan, và mặt mắt đen của hải quỳ. Mắt đen của hải quỳ tạo điểm nhấn kịch tính trên nền trắng và hồng.",                                                          colors:"Trắng · Hồng · Mắt đen",            style:"Tối giản / Hiện đại",  season:"Xuân" },
    { name:"Thị Trường Pastel",       partners:['freesia','peony'],     why:"Sự tươi mới đầu xuân — chùm nhỏ của freesia bao quanh mẫu đơn hùng vĩ; tulip lấp đầy bằng những đường thẳng sạch sẽ. Hương thơm của freesia mang cả bộ kết hợp. Bộ ba được chứng minh cho đám cưới và sự kiện.",                             colors:"Kem · Vàng · Hồng phấn",            style:"Tươi mới / Xa hoa",   season:"Xuân" },
  ],
  lily: [
    { name:"Trắng Nhiệt Đới",         partners:['orchid','gardenia'],   why:"Ba loài hoa trắng nổi bật với tính cách hoàn toàn khác nhau: hoa ly cung cấp chiều cao, dạ lý hương cung cấp hương thơm sáp, hoa lan cung cấp đường nét kiến trúc kỳ lạ. Một trong những kết hợp trắng xa hoa nhất trong floristry.",         colors:"Trắng · Ngà · Xanh lá",             style:"Xa hoa / Nhiệt đới",  season:"Hạ" },
    { name:"Đám Cưới Mùa Hạ",         partners:['hydrangea','freesia'], why:"Khối mây của cẩm tú cầu lấp đầy lọ xung quanh hoa ly thanh lịch cao; freesia thêm hương thơm và thân cong ở tầm trung. Kết hợp được chứng minh cho đám cưới — đẹp, lâu bền, và dễ tìm.",                                                      colors:"Trắng · Hồng-lam · Vàng",           style:"Đám cưới / Cổ điển",  season:"Hạ" },
    { name:"Màn Sương Tím",           partners:['iris','lavender'],     why:"Những chiếc kèn trắng cao của hoa ly được diên vĩ và oải hương ở các độ cao khác nhau phản chiếu — xây dựng bảng màu hoàn toàn tím và trắng với kết cấu đứng đáng kinh ngạc.",                                                                 colors:"Tím · Tím nhạt · Trắng",            style:"Ấn tượng / Kịch tính",season:"Hạ" },
    { name:"Vườn Cuối Hạ",            partners:['rose','chrysanthemum'],why:"Cúc kéo dài mùa khi các loài hoa khác tàn; hồng mang lại tính lãng mạn; hoa ly nâng tầm nhìn lên cao. Cùng nhau chúng bắc cầu từ cuối hạ sang đầu thu.",                                                                                       colors:"Hồng · Trắng · Vàng",               style:"Cổ điển / Vườn",      season:"Hạ–Thu" },
  ],
  sunflower: [
    { name:"Mùa Gặt Bội Thu",         partners:['marigold','chrysanthemum'], why:"Bộ ba thu điển hình — tất cả ấm áp, tất cả tâm đĩa, tất cả cuối mùa. Hướng dương chiếm ưu thế ở trên; vạn thọ phân tầng ở giữa; cúc lấp đầy bên dưới. Sắp xếp thu hoạch phong phú, lễ hội.",                                       colors:"Vàng · Cam · Hổ phách",             style:"Đồng quê / Lễ hội",  season:"Thu" },
    { name:"Cánh Đồng Provence",      partners:['lavender','freesia'],  why:"Đĩa hướng dương vàng táo bạo trước những ngọn oải hương và chùm freesia tạo cảm giác vùng quê Provence — miền Nam nước Pháp trong một bình hoa. Cả ba thịnh vượng trong nắng hè và có tính cách vui tươi.",                                    colors:"Vàng · Tím · Kem",                   style:"Đồng quê / Thơm ngát",season:"Hạ" },
    { name:"Tiệc Vườn",               partners:['hydrangea','rose'],    why:"Hướng dương thêm chiều cao và năng lượng táo bạo; cẩm tú cầu cung cấp đám mây hồng-lam mềm mại; hồng thêm nét lãng mạn. Hướng dương nâng cặp đôi hồng-cẩm tú cầu cổ điển này lên một tầm cao mới.",                                          colors:"Vàng · Hồng · Hồng-lam",            style:"Vườn / Vui tươi",     season:"Hạ" },
    { name:"Ấm Áp Mùa Thu",           partners:['dahlia','carnation'],  why:"Hai loài hoa táo bạo bổ sung cho đĩa hướng dương vui tươi — thược dược cung cấp chiều sâu điêu khắc, cẩm chướng lấp đầy khoảng trống bằng kết cấu. Tất cả đều mặc cam và đỏ đẹp.",                                                           colors:"Cam · Đỏ · Vàng",                   style:"Ấn tượng / Đồng quê", season:"Hạ–Thu" },
  ],
  orchid: [
    { name:"Xa Hoa Nhiệt Đới",        partners:['lily','gardenia'],     why:"Ba loài trắng kiến trúc — hoa lan cung cấp bóng dáng đồ họa, hoa ly mang chiều cao và vẻ hoành tráng, dạ lý hương cung cấp hương thơm phi thường. Đây là cách cắm hoa của khách sạn sang trọng và đám cưới cao cấp.",                          colors:"Trắng · Ngà · Xanh lá",             style:"Xa hoa / Kỳ lạ",      season:"Quanh năm" },
    { name:"Vườn Châu Á",             partners:['magnolia','jasmine'],  why:"Bảng màu Đông phương với ba loài hoa trung tâm trong văn hóa hoa châu Á. Nhài chảy bên dưới những bông mộc lan; hình dáng hình học của hoa lan neo giữ phía trên. Sâu lắng hương thơm và yên bình thị giác.",                                 colors:"Trắng · Hồng · Xanh lá",            style:"Thanh lịch / Tối giản",season:"Xuân–Hạ" },
    { name:"Studio Hiện Đại",         partners:['iris','carnation'],    why:"Hình dạng hình học của diên vĩ phản ánh chất lượng kiến trúc của hoa lan; cẩm chướng cung cấp chất liệu lâu bền, lâu tàn. Cùng nhau chúng tạo sắp xếp hiện đại, có cấu trúc kéo dài đến hai tuần.",                                           colors:"Tím · Trắng · Đồ họa",              style:"Hiện đại / Có cấu trúc",season:"Quanh năm" },
    { name:"Kỳ Lạ Hiện Đại",          partners:['anemone','sweet-pea'], why:"Mắt đen của hải quỳ phản chiếu cổ họng phức tạp của hoa lan; những bông đậu thơm mỏng manh thêm sự mềm mại tương phản với độ chính xác của hoa lan. Kết hợp bất ngờ nhưng thú vị.",                                                            colors:"Tím · Đen · Trắng",                 style:"Hiện đại / Kịch tính", season:"Xuân" },
  ],
  hydrangea: [
    { name:"Đám Cưới Anh Cổ Điển",   partners:['rose','sweet-pea'],    why:"Bộ ba đám cưới Anh điển hình — cẩm tú cầu cung cấp khối bông gòn, hồng cung cấp vẻ đẹp và lãng mạn, đậu thơm cung cấp sự mỏng manh buông thả. Được chứng minh qua hàng nghìn đám cưới; vẫn cảm thấy tươi mới.",                              colors:"Hồng phấn · Trắng · Hồng nhạt",     style:"Đám cưới / Lãng mạn", season:"Hạ" },
    { name:"Hạ Pháp",                 partners:['lavender','freesia'],  why:"Những ngọn oải hương và chùm freesia nép vào những chiếc đầu vòm của cẩm tú cầu, tạo kết hợp hạ Provence ngát hương. Cả ba đạt đỉnh vào tháng 6–7 và khô đẹp.",                                                                              colors:"Hồng-lam · Tím · Kem",              style:"Lãng mạn / Đồng quê", season:"Hạ" },
    { name:"Vườn Đầy Đặn",            partners:['peony','ranunculus'],  why:"Ba loài hoa đầu tròn được tìm kiếm nhất trong floristry — một bình hoa với lượng cánh tối đa. Mẫu đơn dẫn đầu, mao lương chi tiết, cẩm tú cầu lấp đầy. Cùng nhau chúng đạt được vẻ đẹp vườn tràn đầy.",                                     colors:"Hồng · San hô · Hồng phấn",         style:"Xa hoa / Vườn",       season:"Xuân–Hạ" },
    { name:"Kịch Tính Cuối Hạ",       partners:['dahlia','carnation'],  why:"Tông màu lam-xanh mát của cẩm tú cầu tạo tương phản nhiệt độ kịch tính với chiều sâu ấm của thược dược. Cẩm chướng lấp đầy khoảng trống với kết cấu lâu bền — kết hợp giữ đẹp 10–14 ngày.",                                                  colors:"Lam-xanh · Tím · San hô",           style:"Ấn tượng / Vườn",     season:"Hạ–Thu" },
  ],
  dahlia: [
    { name:"Báu Vật Mùa Thu",         partners:['rose','anemone'],      why:"Mắt gần đen của hải quỳ là người bạn đồng hành hoàn hảo cho thược dược và hồng tông tối; hồng thêm chiều sâu nhung vào bảng màu trang sức. Kết hợp này định nghĩa sự xa hoa thu trong floristry.",                                           colors:"Đỏ đậm · Đen · Đỏ sâu",            style:"Kịch tính / Xa hoa",  season:"Thu" },
