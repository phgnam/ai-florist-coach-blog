<script>
  const grid = document.querySelector<HTMLElement>('#flower-grid');
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.flower-card'));
  const search = document.querySelector<HTMLInputElement>('#flower-search');
  const counter = document.querySelector<HTMLElement>('#result-count');
  const empty = document.querySelector<HTMLElement>('#empty-state');
  const petChips = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-filter-pet]'));
  const sevChips = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-filter-sev]'));

  let activePet: 'all' | 'cat' | 'dog' | 'horse' = 'all';
  let activeSev: 'all' | 'safe' | 'toxic' = 'all';
  let activeQuery = '';

  function applyFilters() {
    let visible = 0;
    const q = activeQuery.trim().toLowerCase();
    cards.forEach(card => {
      const name = card.dataset.name ?? '';
      const aliases = card.dataset.aliases ?? '';
      const matchesQuery = !q || name.includes(q) || aliases.includes(q);

      const cat = card.dataset.cat ?? 'safe';
      const dog = card.dataset.dog ?? 'safe';
      const horse = card.dataset.horse ?? 'safe';

      let matchesPet = true;
      if (activePet === 'cat') matchesPet = cat === 'safe';
      else if (activePet === 'dog') matchesPet = dog === 'safe';
      else if (activePet === 'horse') matchesPet = horse === 'safe';

      const allSafe = cat === 'safe' && dog === 'safe' && horse === 'safe';
      const anyToxic = cat !== 'safe' || dog !== 'safe' || horse !== 'safe';
      let matchesSev = true;
      if (activeSev === 'safe') matchesSev = allSafe;
      else if (activeSev === 'toxic') matchesSev = anyToxic;

      const show = matchesQuery && matchesPet && matchesSev;
      card.hidden = !show;
      if (show) visible += 1;
    });
    if (counter) counter.textContent = String(visible);
    if (empty) empty.hidden = visible !== 0;
  }

  search?.addEventListener('input', () => {
    activeQuery = search.value;
    applyFilters();
  });

  petChips.forEach(chip => {
    chip.addEventListener('click', () => {
      petChips.forEach(c => c.setAttribute('aria-pressed', 'false'));
      chip.setAttribute('aria-pressed', 'true');
      activePet = (chip.dataset.filterPet ?? 'all') as typeof activePet;
      applyFilters();
    });
  });

  sevChips.forEach(chip => {
    chip.addEventListener('click', () => {
      sevChips.forEach(c => c.setAttribute('aria-pressed', 'false'));
      chip.setAttribute('aria-pressed', 'true');
      activeSev = (chip.dataset.filterSev ?? 'all') as typeof activeSev;
      applyFilters();
    });
  });

  document.querySelectorAll<HTMLButtonElement>('.faq-q').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
      const answer = btn.nextElementSibling as HTMLElement | null;
      if (answer) answer.hidden = expanded;
      const icon = btn.querySelector('.faq-icon');
      if (icon) icon.textContent = expanded ? '+' : '−';
    });
  });
</script>

