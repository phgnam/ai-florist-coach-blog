---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PagefindMeta from '../../../components/PagefindMeta.astro';

export const prerender = true;

const lang = 'vi' as const;
const siteUrl = (Astro.site?.toString() ?? import.meta.env.SITE_URL ?? 'https://ai-florist-coach-blog.vercel.app').replace(/\/$/, '');

const hreflang = [
  { lang: 'en', url: `${siteUrl}/tools/pet-safe-checker/` },
  { lang: 'vi', url: `${siteUrl}/vi/tools/pet-safe-checker/` },
  { lang: 'x-default', url: `${siteUrl}/tools/pet-safe-checker/` },
];

const breadcrumbs = [
  { name: 'Trang chủ', url: `${siteUrl}/vi/` },
  { name: 'Công cụ', url: `${siteUrl}/vi/tools/` },
  { name: 'Kiểm Tra Hoa An Toàn Cho Thú Cưng', url: `${siteUrl}/vi/tools/pet-safe-checker/` },
];

type Severity = 'safe' | 'mild' | 'severe' | 'lethal';

interface PetStatus {
  level: Severity;
  symptoms?: string;
  notes?: string;
}

interface FlowerEntry {
  name: string;
  scientific: string;
  emoji: string;
  glossarySlug: string | null;
  cat: PetStatus;
  dog: PetStatus;
  horse: PetStatus;
  toxicCompound: string | null;
  aspcaUrl?: string;
  aliases?: string[];
  notes?: string;
}

// Dữ liệu dựa trên ASPCA Toxic and Non-Toxic Plants database và Pet Poison Helpline.
// Mức độ rút gọn để tra nhanh:
//   safe   — không độc theo ASPCA, không có dấu hiệu lâm sàng khi tiếp xúc thông thường
//   mild   — kích ứng tiêu hóa / khoang miệng / da; thường tự khỏi
//   severe — cần đưa thú đi gặp bác sĩ thú y; có triệu chứng toàn thân
//   lethal — có thể tử vong, đặc biệt nếu không can thiệp kịp thời
