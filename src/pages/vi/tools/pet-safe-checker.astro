    notes: 'LOÀI HOA NGUY HIỂM NHẤT cho mèo trong tiệm hoa. Bao gồm Easter, Tiger, Asiatic, Stargazer, Oriental, daylily. Liếm phấn dính trên lông hoặc uống nước cắm hoa cũng có thể tử vong. Không bao giờ giao lily đến nhà có mèo.',
    aliases: ['lily', 'easter lily', 'asiatic', 'tiger lily', 'stargazer', 'oriental', 'daylily', 'hoa loa ken', 'huong duong nuoc'],
  },
  {
    name: 'Linh lan (Lily of the Valley)', scientific: 'Convallaria majalis', emoji: '🤍', glossarySlug: 'lily-of-the-valley',
    cat: { level: 'lethal', symptoms: 'Nôn, nhịp tim chậm, rối loạn nhịp nghiêm trọng, co giật, tử vong nếu không can thiệp tim mạch tích cực.' },
    dog: { level: 'lethal', symptoms: 'Nôn, nhịp tim chậm, rối loạn nhịp nghiêm trọng, co giật, tử vong nếu không can thiệp tim mạch tích cực.' },
    horse: { level: 'lethal' },
    toxicCompound: 'Cardiac glycoside (convallatoxin, convallarin) — cùng nhóm với digitalis',
    aspcaUrl: 'https://www.aspca.org/pet-care/animal-poison-control/toxic-and-non-toxic-plants/lily-valley',
    aliases: ['linh lan', 'lily of the valley', 'convallaria'],
  },
  {
    name: 'Mao địa hoàng (Foxglove)', scientific: 'Digitalis purpurea', emoji: '💜', glossarySlug: null,
    cat: { level: 'lethal', symptoms: 'Rối loạn nhịp tim, yếu, nôn, ngất, tử vong. Trong y học từng dùng làm thuốc tim — liều điều trị và liều tử vong rất gần nhau.' },
    dog: { level: 'lethal', symptoms: 'Rối loạn nhịp tim, yếu, nôn, ngất, tử vong.' },
    horse: { level: 'lethal' },
    toxicCompound: 'Cardiac glycoside (digitoxin, digoxin)',
    aspcaUrl: 'https://www.aspca.org/pet-care/animal-poison-control/toxic-and-non-toxic-plants/foxglove',
    aliases: ['mao dia hoang', 'foxglove', 'digitalis'],
  },
  {
    name: 'Trúc đào (Oleander)', scientific: 'Nerium oleander', emoji: '🌸', glossarySlug: null,
    cat: { level: 'lethal', symptoms: 'Triệu chứng tiêu hóa nặng, rối loạn nhịp tim, hạ thân nhiệt, tử vong. Một trong những cây cảnh độc nhất.' },
    dog: { level: 'lethal', symptoms: 'Triệu chứng tiêu hóa nặng, rối loạn nhịp tim, hạ thân nhiệt, tử vong.' },
    horse: { level: 'lethal' },
    toxicCompound: 'Cardiac glycoside (oleandrin, neriin)',
    aspcaUrl: 'https://www.aspca.org/pet-care/animal-poison-control/toxic-and-non-toxic-plants/oleander',
    notes: 'Mọi bộ phận đều cực độc, kể cả lá khô, khói khi đốt và nước cắm hoa. Nhiều florist từ chối làm việc với trúc đào.',
    aliases: ['truc dao', 'oleander', 'nerium'],
  },
  {
    name: 'Đỗ quyên (Azalea / Rhododendron)', scientific: 'Rhododendron spp.', emoji: '🌸', glossarySlug: null,
    cat: { level: 'lethal', symptoms: 'Nôn, tăng tiết nước bọt, yếu, rối loạn nhịp tim nặng, hôn mê, tử vong.' },
    dog: { level: 'lethal', symptoms: 'Nôn, tăng tiết nước bọt, yếu, rối loạn nhịp tim nặng, hôn mê, tử vong.' },
    horse: { level: 'lethal' },
    toxicCompound: 'Grayanotoxin',
    aspcaUrl: 'https://www.aspca.org/pet-care/animal-poison-control/toxic-and-non-toxic-plants/azalea',
    aliases: ['do quyen', 'azalea', 'rhododendron'],
  },
];

const SEVERITY_LABEL: Record<Severity, string> = {
  safe: 'An toàn',
  mild: 'Nhẹ',
  severe: 'Nặng',
  lethal: 'Tử vong',
};

const SEVERITY_ICON: Record<Severity, string> = {
  safe: '✓',
  mild: '⚠',
  severe: '⛔',
  lethal: '☠',
};

const generalFAQs = [
  {
    q: 'Loài hoa nào nguy hiểm nhất với mèo?',
    a: 'Hoa lily thật (chi Lilium và Hemerocallis — Easter, Tiger, Asiatic, Stargazer, Oriental, daylily) là hoa nguy hiểm nhất cho mèo. Bất kỳ phần nào — cánh, lá, phấn dính trên lông, kể cả nước cắm trong bình — đều có thể gây suy thận tử vong trong 72 giờ. Các loài tử vong khác cho mèo gồm linh lan, mao địa hoàng, trúc đào và đỗ quyên.',
  },
  {
    q: 'Hoa hồng có an toàn cho mèo và chó không?',
    a: 'Có — hoa hồng (Rosa spp.) được ASPCA xếp là không độc. Cánh và cuống không gây ngộ độc cho chó hoặc mèo. Tuy nhiên gai có thể gây cắt, hóc hoặc thủng đường tiêu hóa, vì vậy nên dùng hoa hồng đã tỉa gai hoặc giống không gai trong nhà có thú cưng.',
  },
  {
    q: 'Mèo của tôi vừa cắn cánh hoa lily — phải làm gì?',
    a: 'Hãy coi đây là tình huống khẩn cấp. Gọi bác sĩ thú y ngay, hoặc liên hệ ASPCA Animal Poison Control (888) 426-4435 (Hoa Kỳ) hoặc Pet Poison Helpline (855) 764-7661. Đừng đợi triệu chứng — một khi suy thận đã bắt đầu, tiên lượng giảm mạnh. Mang theo cây hoặc ảnh chụp rõ khi đến khám.',
  },
  {
    q: 'Hoa tulip có độc với chó không?',
    a: 'Có — tulip chứa tulipalin A và B gây nôn, tăng tiết nước bọt và mệt mỏi ở chó. Củ độc hơn nhiều so với hoa cắt, nên những con chó hay đào vườn có nguy cơ cao nhất. Tulip cắt cành cắm bình rủi ro thấp hơn nhưng vẫn nên để xa tầm với.',
  },
  {
    q: 'Bó hoa nào an toàn nhất để gửi đến nhà có mèo?',
    a: 'Bó kết hợp hoa hồng, hướng dương, snapdragon, lisianthus (cát tường), gerbera, stock, statice, freesia, lan hồ điệp và lá xanh đơn giản như leatherleaf, ruscus (eucalyptus là chất kích ứng nhẹ — xem ghi chú). Luôn tránh MỌI loại lily thật (Lilium / Hemerocallis), kể cả một cành, trong nhà có mèo.',
  },
  {
    q: 'Tinh dầu oải hương (lavender) có an toàn cho chó mèo không?',
    a: 'Cây oải hương chỉ gây kích ứng tiêu hóa nhẹ nếu ăn phải, nhưng tinh dầu oải hương cô đặc độc hơn nhiều và là nguyên nhân của hầu hết các ca ngộ độc lavender — không bao giờ bôi tinh dầu trực tiếp lên thú cưng hoặc dùng máy khuếch tán trong phòng kín có mèo.',
  },
  {
    q: 'Dữ liệu này lấy từ đâu?',
    a: 'Mức độ trên công cụ này dựa vào ASPCA Toxic and Non-Toxic Plants database và Pet Poison Helpline. Đây là tham chiếu nhanh, không phải lời khuyên thú y — hãy luôn gọi bác sĩ hoặc tổng đài chống độc thú nuôi nếu thú cưng đã ăn phải. Liên kết tới ASPCA được dẫn ở mỗi mục khi có.',
  },
  {
    q: 'Đặt hoa cao có ngăn được ngộ độc không?',
    a: 'Hữu ích nhưng không tuyệt đối, đặc biệt với mèo — chúng nhảy và xô đổ đồ. Phấn rơi xuống bề mặt rồi dính vào lông và bị liếm sạch; nước đổ ra từ bình chứa độc tố lily; lá nhai rơi xuống sàn. Lựa chọn an toàn hoàn toàn cho nhà có mèo là không bao giờ mang lily thật vào nhà, và để hoa độc tính trung bình ở phòng mèo không vào được.',
  },
];

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Tham chiếu hoa an toàn cho thú cưng',
  description: 'Danh sách các loài hoa florist phổ biến với mức độ độc tính cho mèo, chó và ngựa, dựa trên ASPCA database.',
  url: `${siteUrl}/vi/tools/pet-safe-checker/`,
  numberOfItems: FLOWERS.length,
  itemListElement: FLOWERS.map((f, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: `${f.name} (${f.scientific})`,
    item: {
      '@type': 'Thing',
      name: f.name,
      alternateName: f.scientific,
      description: `Mèo: ${SEVERITY_LABEL[f.cat.level]}. Chó: ${SEVERITY_LABEL[f.dog.level]}. Ngựa: ${SEVERITY_LABEL[f.horse.level]}.`,
      url: f.glossarySlug ? `${siteUrl}/vi/learn/${f.glossarySlug}/` : (f.aspcaUrl ?? `${siteUrl}/vi/tools/pet-safe-checker/`),
    },
  })),
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: generalFAQs.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---
<BaseLayout
  lang={lang}
  title="Kiểm Tra Hoa An Toàn Cho Thú Cưng — Hoa Nào Độc Với Mèo và Chó?"
  description="Tra cứu loài hoa nào an toàn cho mèo, chó hoặc ngựa. Mức độ độc tính, triệu chứng và hợp chất gây độc cho 35+ loài hoa florist phổ biến, dựa trên ASPCA. Công cụ miễn phí từ Yor Flower."
  hreflang={hreflang}
  breadcrumbs={breadcrumbs}
>
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline />

  <nav class="breadcrumb-nav" aria-label="Breadcrumb" data-pagefind-ignore>
    <div class="max-w-6xl mx-auto px-6 py-4">
      <ol class="breadcrumb-list">
        <li><a href="/vi/">Trang chủ</a></li>
        <li aria-hidden="true">›</li>
        <li><a href="/vi/tools/">Công cụ</a></li>
        <li aria-hidden="true">›</li>
        <li aria-current="page">Kiểm Tra Hoa An Toàn Cho Thú Cưng</li>
      </ol>
    </div>
  </nav>

  <article data-pagefind-body>
  <PagefindMeta kind="tool" description="Kiểm tra hoa an toàn cho thú cưng. Tra cứu mức độ độc cho mèo, chó, ngựa của 35+ loài hoa, kèm triệu chứng và lựa chọn an toàn thay thế. Dựa trên ASPCA database." tags={["tool","pet-safe","toxicity","florist-safety"]} />

  <div class="page-header">
    <div class="max-w-6xl mx-auto px-6 py-20 text-center" style="position:relative;z-index:2">
      <p class="page-eyebrow">Công cụ florist miễn phí</p>
      <h1 class="page-title">Kiểm Tra Hoa An Toàn Cho Thú Cưng</h1>
      <p class="page-sub">Hoa này có độc với mèo, chó hay ngựa không? Tra cứu 35+ loài hoa florist phổ biến, xem mức độ độc theo từng loài thú và tìm lựa chọn an toàn thay thế.</p>
      <a href="/tools/pet-safe-checker/" class="lang-switch-link">🇬🇧 View in English</a>
    </div>
  </div>

  <aside class="emergency-banner" data-pagefind-ignore>
    <div class="max-w-6xl mx-auto px-6 py-5">
      <div class="emergency-grid">
        <div class="emergency-text">
          <p class="emergency-eyebrow">⚠ Nếu thú cưng đã ăn phải</p>
          <p class="emergency-body">Gọi bác sĩ thú y ngay, hoặc một trong các tổng đài chống độc 24/7 dưới đây, <em>trước khi</em> đợi triệu chứng. Mang theo cây — hoặc ảnh chụp rõ — khi đến khám.</p>
        </div>
        <div class="emergency-numbers">
          <a class="emergency-num" href="tel:+18884264435">
            <span class="emergency-num-label">ASPCA Animal Poison Control (Hoa Kỳ)</span>
            <span class="emergency-num-value">(888) 426-4435</span>
          </a>
          <a class="emergency-num" href="tel:+18557647661">
            <span class="emergency-num-label">Pet Poison Helpline (Mỹ/Canada)</span>
            <span class="emergency-num-value">(855) 764-7661</span>
          </a>
        </div>
      </div>
    </div>
  </aside>

  <section class="quick-answer">
    <div class="max-w-6xl mx-auto px-6 py-8">
      <p><strong>Trả lời nhanh:</strong> Loài hoa nguy hiểm nhất trong tiệm hoa là <strong>hoa lily thật</strong> (Lilium và Hemerocallis — Easter, Asiatic, Tiger, Stargazer, Oriental, daylily). Phấn dính trên lông hoặc nước cắm trong bình cũng có thể gây suy thận tử vong cho mèo trong 72 giờ. Các stem an toàn cho cả chó và mèo gồm <a href="/vi/learn/rose/">hoa hồng</a>, <a href="/vi/learn/sunflower/">hướng dương</a>, <a href="/vi/learn/snapdragon/">mõm chó</a>, <a href="/vi/learn/gerbera/">gerbera</a>, <a href="/vi/learn/lisianthus/">cát tường</a>, <a href="/vi/learn/orchid/">lan hồ điệp</a>, <a href="/vi/learn/stock/">stock</a> và statice.</p>
    </div>
  </section>

  <div class="checker-wrap">
    <div class="max-w-6xl mx-auto px-4 lg:px-6 py-10">

      <div class="filter-bar">
        <div class="filter-search">
          <label for="flower-search" class="filter-label">Tìm tên hoa</label>
          <input
            type="search"
            id="flower-search"
            placeholder="vd: lily, hydrangea, gerbera…"
            class="filter-input"
            aria-describedby="filter-help"
          />
        </div>

        <fieldset class="filter-group">
          <legend class="filter-label">Chỉ hiện an toàn cho</legend>
          <div class="filter-chips" role="group">
            <button type="button" class="chip" data-filter-pet="all" aria-pressed="true">Mọi thú</button>
            <button type="button" class="chip" data-filter-pet="cat" aria-pressed="false">🐱 Mèo</button>
            <button type="button" class="chip" data-filter-pet="dog" aria-pressed="false">🐶 Chó</button>
            <button type="button" class="chip" data-filter-pet="horse" aria-pressed="false">🐴 Ngựa</button>
          </div>
        </fieldset>

        <fieldset class="filter-group">
          <legend class="filter-label">Mức độ</legend>
          <div class="filter-chips" role="group">
            <button type="button" class="chip" data-filter-sev="all" aria-pressed="true">Hiện tất cả</button>
            <button type="button" class="chip chip-safe" data-filter-sev="safe" aria-pressed="false">✓ Chỉ an toàn</button>
            <button type="button" class="chip chip-toxic" data-filter-sev="toxic" aria-pressed="false">⚠ Chỉ có độc</button>
          </div>
        </fieldset>
      </div>
      <p id="filter-help" class="filter-help">Đang hiện <span id="result-count">{FLOWERS.length}</span> trên {FLOWERS.length} loài hoa. Mức độ là tham chiếu nhanh, không phải lời khuyên thú y.</p>

      <div class="severity-legend" role="region" aria-label="Chú thích mức độ">
        <span class="legend-pill chip-safe">{SEVERITY_ICON.safe} An toàn — không độc theo ASPCA</span>
        <span class="legend-pill chip-mild">{SEVERITY_ICON.mild} Nhẹ — kích ứng tiêu hóa / khoang miệng</span>
        <span class="legend-pill chip-severe">{SEVERITY_ICON.severe} Nặng — cần đi khám thú y</span>
        <span class="legend-pill chip-lethal">{SEVERITY_ICON.lethal} Tử vong — có thể gây chết</span>
      </div>

      <div class="flower-grid" id="flower-grid">
        {FLOWERS.map((f) => (
          <article
            class="flower-card"
            data-name={f.name.toLowerCase()}
            data-aliases={(f.aliases ?? []).join(',').toLowerCase()}
            data-cat={f.cat.level}
            data-dog={f.dog.level}
            data-horse={f.horse.level}
          >
            <header class="card-head">
              <span class="card-emoji" aria-hidden="true">{f.emoji}</span>
              <div class="card-title-wrap">
                <h2 class="card-name">{f.name}</h2>
                <p class="card-sci">{f.scientific}</p>
              </div>
            </header>

            <div class="pet-row">
              {(['cat', 'dog', 'horse'] as const).map((pet) => (
                <div class={`pet-cell pet-cell-${f[pet].level}`}>
                  <span class="pet-icon">{pet === 'cat' ? '🐱' : pet === 'dog' ? '🐶' : '🐴'}</span>
                  <span class="pet-status">
                    <span class="pet-status-icon">{SEVERITY_ICON[f[pet].level]}</span>
                    <span class="pet-status-label">{SEVERITY_LABEL[f[pet].level]}</span>
                  </span>
                </div>
              ))}
            </div>

            {(f.cat.symptoms || f.dog.symptoms || f.horse.symptoms) && (
              <div class="card-section">
                <h3 class="card-sub">Triệu chứng nếu ăn phải</h3>
                <ul class="card-list">
                  {f.cat.symptoms && <li><strong>Mèo:</strong> {f.cat.symptoms}</li>}
                  {f.dog.symptoms && f.dog.symptoms !== f.cat.symptoms && <li><strong>Chó:</strong> {f.dog.symptoms}</li>}
                  {f.dog.symptoms && f.dog.symptoms === f.cat.symptoms && <li><strong>Chó:</strong> Giống mèo phía trên.</li>}
                  {f.horse.symptoms && <li><strong>Ngựa:</strong> {f.horse.symptoms}</li>}
                </ul>
              </div>
            )}

            {f.toxicCompound && (
              <div class="card-section">
                <h3 class="card-sub">Hợp chất gây độc</h3>
                <p class="card-body">{f.toxicCompound}</p>
              </div>
            )}

            {f.notes && (
              <div class="card-section card-notes">
                <h3 class="card-sub">Ghi chú florist</h3>
                <p class="card-body">{f.notes}</p>
              </div>
            )}

            <div class="card-links">
              {f.glossarySlug && (
                <a class="card-link" href={`/vi/learn/${f.glossarySlug}/`}>Xem hướng dẫn đầy đủ →</a>
              )}
              {f.aspcaUrl && (
                <a class="card-link card-link-ext" href={f.aspcaUrl} target="_blank" rel="noopener noreferrer">Tham chiếu ASPCA ↗</a>
              )}
            </div>
          </article>
        ))}
      </div>

      <p class="empty-state" id="empty-state" hidden>Không có loài hoa nào khớp bộ lọc. Thử từ khóa khác hoặc xóa bộ lọc.</p>
    </div>
  </div>

  <section class="faq-section">
    <div class="max-w-6xl mx-auto px-4 lg:px-6 py-16">
      <h2 class="faq-title">Câu Hỏi Thường Gặp Về Hoa An Toàn Cho Thú Cưng</h2>
      <div class="faq-list">
        {generalFAQs.map((item, i) => (
          <div class="faq-item" data-index={i}>
            <button class="faq-q" aria-expanded="false">
              <span>{item.q}</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-a" hidden>
              <p>{item.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="tips-section">
    <div class="max-w-6xl mx-auto px-4 lg:px-6 py-14">
      <h2 class="tips-title">Làm Sao Để Có Một Bó Hoa Thực Sự An Toàn Cho Thú Cưng?</h2>
      <div class="tips-grid">
        <div class="tip-card">
          <div class="tip-icon">🐱</div>
          <h3 class="tip-head">Không bao giờ giao lily đến nhà có mèo</h3>
          <p class="tip-body">Nếu bạn không biết người nhận có nuôi mèo hay không, mặc định bó không có lily. Độc tố thận trong lily không có "liều thấp an toàn" — chỉ phấn dính trên chân thôi cũng đủ. Hãy thay thế bằng cát tường, alstroemeria (KHÔNG phải lily thật), hoặc ranunculus theo phong cách phương Đông để giữ vẻ tương tự.</p>
        </div>
        <div class="tip-card">
          <div class="tip-icon">🐶</div>
          <h3 class="tip-head">Cẩn thận với hoa từ củ</h3>
          <p class="tip-body">Tulip, thủy tiên và lan dạ hương nguy hiểm nhất với chó hay đào vườn — củ độc hơn cuống cắt rất nhiều. Hoa cắt cắm bình ít rủi ro hơn nhưng vẫn nên đặt ở kệ cao hoặc treo nơi chó không kéo xuống được.</p>
