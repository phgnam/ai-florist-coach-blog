      meaning: 'Thủy tiên trắng paperwhite tượng trưng cho lời chúc tốt lành, lòng trung thành và sự đổi mới — mang nốt hương hy vọng vào giữa lòng mùa đông.',
      personality: 'Người tháng 12 mang khả năng nở của paperwhite — người bạn làm sáng phòng khi tất cả những người khác đang co cụm.',
      gifts: ['Chậu củ paperwhite để ép nở trên cửa sổ', 'Centerpiece mùa đông paperwhite + amaryllis', 'Posy mùa đông có hương kết hợp paperwhite + thông'],
    },
    secondary: {
      name: 'Ô rô (Holly)', emoji: '🌿', glossarySlug: null, color: '#2E7D4E',
      meaning: 'Holly tượng trưng cho hạnh phúc gia đình, sự bảo vệ và lời chúc tốt — biểu tượng thường xanh mùa đông từ rất lâu trước khi gắn với Giáng sinh.',
      personality: 'Người tháng 12 thiên holly biết bảo vệ, hân hoan và vững chãi — người chủ nhà thầm lặng giữ cho cả mùa được trọn vẹn.',
      gifts: ['Vòng cửa Giáng sinh holly + paperwhite', 'Runner bàn ăn ngày lễ holly + tuyết tùng', 'Centerpiece mùa đông phong cách "hái rừng" với holly có quả'],
    },
    zodiac: [{ sign: 'Nhân Mã', range: 'đến 21/12' }, { sign: 'Ma Kết', range: 'từ 22/12' }],
  },
];

const firstSentence = (text: string) => text.split('.')[0].trim() + '.';
const monthFAQs = MONTHS.map(m => ({
  q: `Hoa sinh nhật của ${m.name} là gì?`,
  a: `Hoa chính của ${m.name} là ${m.primary.name}. ${firstSentence(m.primary.meaning)} Hoa phụ là ${m.secondary.name}. ${firstSentence(m.secondary.meaning)} ${firstSentence(m.primary.personality)}`,
}));

const generalFAQs = [
  {
    q: 'Hoa sinh nhật theo tháng là gì?',
    a: 'Hoa sinh nhật là một loài hoa được gán cho mỗi tháng trong năm, tương tự như đá sinh nhật. Truyền thống này kết hợp biểu tượng của La Mã, Anglo-Saxon cùng mùa nở tự nhiên của mỗi loài hoa. Phần lớn các tháng có cả hoa chính và hoa phụ vì phong tục mỗi vùng mỗi khác.',
  },
  {
    q: 'Vì sao tháng của tôi có hai loài hoa?',
    a: 'Phần lớn các tháng có cả hoa chính và hoa phụ vì không có truyền thống nào là duy nhất. Hoa chính thường là loài được các florist, niên giám và thợ kim hoàn dùng nhiều nhất (ví dụ cẩm chướng cho tháng 1, hoa hồng cho tháng 6). Hoa phụ thường là một thay thế theo vùng hoặc theo mùa — hữu ích khi hoa chính không có sẵn ở địa phương.',
  },
  {
    q: 'Hoa sinh nhật khác hoa cung hoàng đạo thế nào?',
    a: 'Hoa sinh nhật được gán theo tháng dương lịch (ví dụ tháng 1 = cẩm chướng). Hoa cung hoàng đạo được gán cho 12 cung (ví dụ Bảo Bình = lan), và mỗi cung trải qua một phần của hai tháng. Nếu sinh nhật rơi vào cuối hoặc đầu tháng, bạn có cả hoa sinh nhật và hoa cung hoàng đạo — cả hai đều dùng được cho quà tặng cá nhân hóa hoặc hình xăm.',
  },
  {
    q: 'Có thể dùng hoa sinh nhật trong bó hoa cưới không?',
    a: 'Hoàn toàn được — bó "hoa sinh nhật" là cách cá nhân hóa rất phổ biến. Lấy hoa sinh nhật của cô dâu làm hoa chủ, hoa của chú rể làm hoa phụ, và hoa sinh nhật theo tháng cưới làm hoa độn. Lưu ý kiểm tra mùa: không phải hoa sinh nhật nào cũng có ở Việt Nam tại mọi thời điểm. Hãy dùng Lịch Hoa Theo Mùa của Yor Flower để xác nhận.',
  },
  {
    q: 'Loài hoa sinh nhật nào hiếm nhất?',
    a: 'Linh lan (tháng 5) thường được xem là hoa sinh nhật hiếm nhất trong chuỗi cung ứng florist. Mùa tự nhiên rất ngắn (3–6 tuần đầu xuân), chủ yếu được trồng trong nhà kính cho thị trường cao cấp châu Âu, và là một trong những loài hoa cắt cành đắt đỏ nhất. Hawthorn (hoa phụ tháng 5) gần như không bán dưới dạng hoa cắt mà chủ yếu là hàng rào hoặc cành.',
  },
  {
    q: 'Hoa sinh nhật có giống nhau ở mọi văn hóa không?',
    a: 'Không. Danh sách 12 tháng trên trang này theo truyền thống Anh-Mỹ phổ biến hóa bởi The Old Farmer\'s Almanac và các thợ kim hoàn hiện đại. Các nền văn hóa khác có hệ thống riêng. Floriography của Hàn Quốc và Nhật Bản gán một loài hoa cho mỗi ngày trong năm. Truyền thống Việt Nam và Trung Quốc gắn hoa với các tháng âm lịch và 24 tiết khí thay vì lịch dương phương Tây.',
  },
];

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Hoa Sinh Nhật Theo Tháng',
  description: 'Danh sách 12 loài hoa sinh nhật theo truyền thống Anh-Mỹ với hoa chính, hoa phụ, ý nghĩa và gợi ý quà tặng.',
  url: `${siteUrl}/vi/tools/birth-flower/`,
  numberOfItems: MONTHS.length,
  itemListElement: MONTHS.map(m => ({
    '@type': 'ListItem',
    position: m.num,
    name: `${m.name} — ${m.primary.name}`,
    item: {
      '@type': 'Thing',
      name: m.primary.name,
      description: m.primary.meaning,
      url: m.primary.glossarySlug ? `${siteUrl}/vi/learn/${m.primary.glossarySlug}/` : `${siteUrl}/vi/tools/birth-flower/`,
    },
  })),
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [...monthFAQs, ...generalFAQs].map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};

// BreadcrumbList JSON-LD is emitted automatically by SEO.astro when `breadcrumbs` is passed.
---
<BaseLayout
  lang={lang}
  title="Hoa Sinh Nhật Theo Tháng — Tra Cứu Hoa Theo Tháng Sinh"
  description="Tra cứu hoa sinh nhật theo tháng. Hoa chính, hoa phụ, ý nghĩa, gợi ý quà tặng và liên kết cung hoàng đạo cho cả 12 tháng. Công cụ miễn phí từ Yor Flower."
  hreflang={hreflang}
  breadcrumbs={breadcrumbs}
>
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline />

  <nav class="breadcrumb-nav" aria-label="Breadcrumb" data-pagefind-ignore>
    <div class="max-w-6xl mx-auto px-6 py-4">
      <ol class="breadcrumb-list">
        <li><a href="/vi/">Trang chủ</a></li>
        <li aria-hidden="true">›</li>
        <li><a href="/vi/tools/">Công cụ</a></li>
        <li aria-hidden="true">›</li>
        <li aria-current="page">Hoa Sinh Nhật Theo Tháng</li>
      </ol>
    </div>
  </nav>

  <article data-pagefind-body>
  <PagefindMeta kind="tool" description="Tra cứu hoa sinh nhật theo tháng. Hoa chính và hoa phụ, ý nghĩa, gợi ý quà tặng và cung hoàng đạo cho cả 12 tháng." tags={["tool","birth-flower","gift-guide"]} />

  <div class="page-header">
    <div class="max-w-6xl mx-auto px-6 py-20 text-center" style="position:relative;z-index:2">
      <p class="page-eyebrow">Công cụ florist miễn phí</p>
      <h1 class="page-title">Hoa Sinh Nhật Theo Tháng</h1>
      <p class="page-sub">Hoa sinh nhật của bạn là gì? Chọn một tháng để khám phá hoa chính, hoa phụ, ý nghĩa, gợi ý quà tặng và cung hoàng đạo tương ứng.</p>
      <a href="/tools/birth-flower/" class="lang-switch-link">🇬🇧 View in English</a>
    </div>
  </div>

  <div class="planner-wrap">
    <div class="max-w-6xl mx-auto px-4 lg:px-6 py-12">

      <div class="picker-controls">
        <label for="bday-input" class="picker-label">Nhập ngày sinh <span aria-hidden="true">·</span> hoặc chọn tháng bên dưới</label>
        <div class="picker-row">
          <input type="date" id="bday-input" class="bday-input" aria-describedby="picker-help" />
          <button type="button" id="bday-clear" class="bday-clear" aria-label="Xóa ngày sinh">Xóa</button>
        </div>
        <p id="picker-help" class="picker-help">Chúng tôi chỉ dùng tháng/ngày từ thông tin bạn nhập — không lưu trữ ngày sinh.</p>
      </div>

      <div class="month-tabs" role="tablist" aria-label="Chọn tháng sinh">
        {MONTHS.map((m) => (
          <button
            class:list={['month-tab', { 'active': m.num - 1 === new Date().getMonth() }]}
            role="tab"
            aria-selected={m.num - 1 === new Date().getMonth() ? 'true' : 'false'}
            data-month={m.num - 1}
            id={`tab-${m.num - 1}`}
            aria-controls={`panel-${m.num - 1}`}
          >{m.short}</button>
        ))}
      </div>

      {MONTHS.map((m) => (
        <div
          class="month-panel"
          id={`panel-${m.num - 1}`}
          role="tabpanel"
          aria-labelledby={`tab-${m.num - 1}`}
          data-month={m.num - 1}
          hidden={m.num - 1 !== new Date().getMonth()}
        >
          <div class="month-panel-header">
            <h2 class="month-panel-title">Hoa sinh nhật cho <em>{m.name}</em></h2>
            <p class="month-panel-zodiac">
              {m.zodiac.map((z, zi) => (
                <span>
                  <strong>{z.sign}</strong> <span class="zodiac-range">({z.range})</span>{zi < m.zodiac.length - 1 ? ' · ' : ''}
                </span>
              ))}
            </p>
          </div>

          <div class="flower-grid">
            {[
              { ...m.primary, slot: 'Hoa chính' as const },
              { ...m.secondary, slot: 'Hoa phụ' as const },
            ].map((f) => (
              <article class="flower-card" style={`--accent:${f.color}`}>
                <header class="flower-card-head">
                  <span class="flower-card-emoji" aria-hidden="true">{f.emoji}</span>
                  <div>
                    <p class="flower-card-slot">{f.slot}</p>
                    <h3 class="flower-card-name">{f.name}</h3>
                  </div>
                  <span class="flower-card-swatch" aria-hidden="true"></span>
                </header>

                <h4 class="flower-card-subhead">Ý nghĩa của {f.name.toLowerCase()}</h4>
                <p class="flower-card-text">{f.meaning}</p>

                <h4 class="flower-card-subhead">Người sinh {m.name}</h4>
                <p class="flower-card-text">{f.personality}</p>

                <h4 class="flower-card-subhead">Gợi ý quà tặng</h4>
                <ul class="flower-card-list">
                  {f.gifts.map(g => <li>{g}</li>)}
                </ul>

                {f.glossarySlug && (
                  <a class="flower-card-link" href={`/vi/learn/${f.glossarySlug}/`}>
                    Xem hướng dẫn đầy đủ về {f.name.toLowerCase()} →
                  </a>
                )}
              </article>
            ))}
          </div>

          <aside class="cross-tool">
            <p>
              Đang lên ý tưởng quà sinh nhật {m.name}?
              {' '}<a href="/vi/tools/combination-builder/">Xem các loài hoa kết hợp với {m.primary.name.toLowerCase()}</a>,
              {' '}<a href="/vi/tools/budget-planner/">tính giá bó hoa</a>,
              hoặc <a href="/vi/tools/season-planner/">kiểm tra hoa nào đang vào mùa</a>.
            </p>
          </aside>
        </div>
      ))}

    </div>
  </div>

  <section class="table-section">
    <div class="max-w-6xl mx-auto px-4 lg:px-6 py-14">
      <h2 class="table-title">Hoa Sinh Nhật Theo Tháng — Bảng Tra Nhanh</h2>
      <p class="table-sub">Tham chiếu nhanh 12 loài hoa sinh nhật theo truyền thống Anh-Mỹ. Bấm vào hoa có hướng dẫn để đọc thêm.</p>
      <div class="table-wrap">
        <table class="bf-table">
          <thead>
            <tr>
              <th scope="col">Tháng</th>
              <th scope="col">Hoa chính</th>
              <th scope="col">Hoa phụ</th>
              <th scope="col">Ý nghĩa cốt lõi</th>
              <th scope="col">Cung hoàng đạo</th>
            </tr>
          </thead>
          <tbody>
            {MONTHS.map(m => (
              <tr>
                <th scope="row">{m.name}</th>
                <td>
                  {m.primary.glossarySlug
                    ? <a href={`/vi/learn/${m.primary.glossarySlug}/`}>{m.primary.emoji} {m.primary.name}</a>
                    : <span>{m.primary.emoji} {m.primary.name}</span>}
                </td>
                <td>
                  {m.secondary.glossarySlug
                    ? <a href={`/vi/learn/${m.secondary.glossarySlug}/`}>{m.secondary.emoji} {m.secondary.name}</a>
                    : <span>{m.secondary.emoji} {m.secondary.name}</span>}
                </td>
                <td>{m.primary.meaning.split('.')[0]}.</td>
                <td>{m.zodiac.map(z => z.sign).join(' · ')}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="max-w-6xl mx-auto px-4 lg:px-6 py-16">
      <h2 class="faq-title">Câu Hỏi Thường Gặp Về Hoa Sinh Nhật</h2>
      <div class="faq-list">
        {[...monthFAQs, ...generalFAQs].map((item, i) => (
          <div class="faq-item" data-index={i}>
            <button class="faq-q" aria-expanded="false">
              <span>{item.q}</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-a" hidden>
              <p>{item.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="tips-section">
    <div class="max-w-6xl mx-auto px-4 lg:px-6 py-14">
      <h2 class="tips-title">Cách Dùng Hoa Sinh Nhật — Quà Tặng, Hình Xăm và Cá Nhân Hóa Đám Cưới</h2>
      <div class="tips-grid">
        <div class="tip-card">
          <div class="tip-icon">🎁</div>
          <h3 class="tip-head">Làm quà tặng cá nhân hóa</h3>
          <p class="tip-body">Xây bó hoa quanh hoa sinh nhật của người nhận làm hoa chủ, sau đó thêm hoa độn và lá. Với người yêu hoặc bố mẹ, hãy thêm hoa sinh nhật của bạn để bó hoa mang cả hai câu chuyện.</p>
        </div>
        <div class="tip-card">
          <div class="tip-icon">💍</div>
          <h3 class="tip-head">Trong bó hoa cưới</h3>
          <p class="tip-body">Một "bó hoa sinh nhật" gồm hoa của cô dâu, chú rể và hoa của tháng cưới. Kiểm tra Lịch Hoa Theo Mùa trước — không phải hoa sinh nhật nào cũng có vào mọi thời điểm; có thể phải dùng hoa phụ hoặc giống cùng họ thay thế.</p>
        </div>
        <div class="tip-card">
          <div class="tip-icon">🖋️</div>
          <h3 class="tip-head">Cho hình xăm hoặc trang sức</h3>
          <p class="tip-body">Hoa sinh nhật ngày càng phổ biến cho hình xăm fine-line và mặt dây khắc tên. Lợi thế so với đá sinh nhật: hoa sinh nhật có thể mang màu sắc, biến tấu nét vẽ, và kết hợp hoa của người yêu/con nhỏ vào một thiết kế chung.</p>
        </div>
        <div class="tip-card">
          <div class="tip-icon">🌸</div>
          <h3 class="tip-head">Để tưởng nhớ</h3>
          <p class="tip-body">Một bó posy hoa sinh nhật trong lễ tưởng niệm (hoặc ép khung sau đó) là cách thầm lặng để vinh danh ai đó — đặc biệt khi loài hoa của họ có ý nghĩa tưởng nhớ riêng (lay-ơn, anh túc, cúc trắng).</p>
        </div>
      </div>
    </div>
  </section>

  </article>
</BaseLayout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.month-tab');
  const panels = document.querySelectorAll<HTMLElement>('.month-panel');

  function activateMonth(monthIdx: number) {
    tabs.forEach(tab => {
      const isActive = Number(tab.dataset.month) === monthIdx;
      tab.classList.toggle('active', isActive);
      tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });
    panels.forEach(panel => {
      const isActive = Number(panel.dataset.month) === monthIdx;
      panel.hidden = !isActive;
    });
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const idx = Number(tab.dataset.month);
      if (!Number.isNaN(idx)) activateMonth(idx);
    });
  });

  const bdayInput = document.querySelector<HTMLInputElement>('#bday-input');
  const bdayClear = document.querySelector<HTMLButtonElement>('#bday-clear');

  bdayInput?.addEventListener('change', () => {
    if (!bdayInput.value) return;
    const parts = bdayInput.value.split('-');
    if (parts.length !== 3) return;
    const monthIdx = Number(parts[1]) - 1;
    if (monthIdx >= 0 && monthIdx < 12) {
      activateMonth(monthIdx);
      const target = document.getElementById(`panel-${monthIdx}`);
      target?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });

  bdayClear?.addEventListener('click', () => {
    if (bdayInput) bdayInput.value = '';
  });

  document.querySelectorAll<HTMLButtonElement>('.faq-q').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
      const answer = btn.nextElementSibling as HTMLElement | null;
      if (answer) answer.hidden = expanded;
      const icon = btn.querySelector('.faq-icon');
      if (icon) icon.textContent = expanded ? '+' : '−';
    });
  });
</script>

<style>
