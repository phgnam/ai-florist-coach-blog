---
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import TagList from '../components/TagList.astro';
import Giscus from '../components/Giscus.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: ImageMetadata;
  heroAlt?: string;
  tags?: string[];
  author?: string;
}

const { title, description, pubDate, updatedDate, heroImage, heroAlt, tags = [], author } = Astro.props;
---
<BaseLayout title={title} description={description} type="article" padTop={false}>
  <!-- Reading progress bar -->
  <div id="reading-progress"></div>

  <!-- Hero -->
  <div class="post-hero">
    {heroImage ? (
      <img src={heroImage.src} alt={heroAlt ?? title} width={heroImage.width} height={heroImage.height} class="post-hero-img" />
    ) : (
      <div class="post-hero-placeholder"></div>
    )}
    <div class="post-hero-overlay"></div>
    <div class="post-hero-content max-w-4xl mx-auto px-6">
      <div class="fade-up fade-up-1">
        {tags.length > 0 && (
          <span class="post-category">{tags[0]}</span>
        )}
      </div>
      <h1 class="post-hero-title fade-up fade-up-2">{title}</h1>
      <div class="post-hero-meta fade-up fade-up-3">
        <span class="post-author">✍ {author}</span>
        <span class="post-dot">·</span>
        <FormattedDate date={pubDate} />
        {updatedDate && (
          <>
            <span class="post-dot">·</span>
            <span class="post-updated">Cập nhật: <FormattedDate date={updatedDate} /></span>
          </>
        )}
      </div>
    </div>
  </div>

  <!-- Article body -->
  <div class="post-content-wrap">
    <div class="post-content max-w-4xl mx-auto px-6 py-14">

      <!-- Tags row -->
      {tags.length > 0 && (
        <div class="mb-10 fade-up fade-up-1">
          <TagList tags={tags} />
        </div>
      )}

      <!-- Main content -->
      <div class="prose prose-lg fade-up fade-up-2">
        <slot />
      </div>

      <!-- Divider -->
      <div class="post-divider my-16 fade-up fade-up-3"></div>

      <!-- Share prompt -->
      <div class="share-box fade-up fade-up-4">
        <p class="share-text">Bạn thấy bài viết này hữu ích? Hãy chia sẻ với bạn bè!</p>
        <div class="share-tags">
          {tags.map(t => <span class="share-tag">#{t}</span>)}
        </div>
      </div>

      <!-- Comments -->
      <section class="mt-16">
        <h2 class="comments-title">Bình luận</h2>
        <Giscus />
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .post-hero {
    position: relative;
    min-height: 520px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: var(--green-deep);
  }
  .post-hero-img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    opacity: 0.5;
  }
  .post-hero-placeholder {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, var(--green-deep) 0%, #2d5040 50%, #1a3028 100%);
  }
  .post-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(10,24,18,0.92) 0%, rgba(10,24,18,0.5) 50%, rgba(10,24,18,0.2) 100%);
    pointer-events: none;
  }
  .post-hero-content {
    position: relative; z-index: 10;
    padding-bottom: 3.5rem;
    width: 100%;
  }
  .post-category {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    border: 1px solid var(--gold);
    padding: 0.3rem 0.9rem;
    border-radius: 999px;
    margin-bottom: 1.2rem;
  }
  .post-hero-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.8rem, 4.5vw, 3.2rem);
    font-weight: 900;
    color: white;
    line-height: 1.15;
    margin: 0 0 1.2rem;
    max-width: 820px;
  }
  .post-hero-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
    font-weight: 300;
  }
  .post-author { color: rgba(255,255,255,0.8); font-weight: 400; }
  .post-dot { color: rgba(255,255,255,0.3); }

  .post-content-wrap {
    background: var(--cream);
    position: relative;
  }
  .post-content-wrap::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 120px;
    background: linear-gradient(to bottom, rgba(10,24,18,0.04), transparent);
    pointer-events: none;
  }

  .post-divider {
    height: 1px;
    background: linear-gradient(to right, transparent, var(--cream-dark), transparent);
  }

  .share-box {
    background: var(--green-light);
    border-left: 4px solid var(--green-mid);
    padding: 1.5rem 2rem;
    border-radius: 0 12px 12px 0;
  }
  .share-text {
    font-size: 0.95rem;
    color: var(--green-deep);
    margin: 0 0 0.75rem;
    font-weight: 600;
    font-style: italic;
  }
  .share-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .share-tag {
    font-size: 0.78rem;
    color: var(--green-mid);
    font-weight: 700;
  }

  .comments-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    color: var(--green-deep);
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--cream-dark);
  }
</style>

<script>
  const bar = document.getElementById('reading-progress');
  if (bar) {
    window.addEventListener('scroll', () => {
      const docH = document.documentElement.scrollHeight - window.innerHeight;
      const pct = docH > 0 ? (window.scrollY / docH) * 100 : 0;
      bar.style.width = pct + '%';
    }, { passive: true });
  }
</script>
