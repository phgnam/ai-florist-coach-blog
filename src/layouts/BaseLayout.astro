---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import '../styles/global.css';
import type { Lang } from '../i18n/ui';

interface HreflangLink {
  lang: string;
  url: string;
}

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  padTop?: boolean;
  lang?: Lang;
  pubDate?: Date;
  updatedDate?: Date;
  author?: string;
  tags?: string[];
  hreflang?: HreflangLink[];
  breadcrumbs?: BreadcrumbItem[];
}

const {
  title,
  description,
  image,
  type,
  padTop = true,
  lang = 'en',
  pubDate,
  updatedDate,
  author,
  tags,
  hreflang = [],
  breadcrumbs = [],
} = Astro.props;
---
<!doctype html>
<html lang={lang}>
  <head>
    <SEO
      title={title}
      description={description}
      image={image}
      type={type}
      lang={lang}
      pubDate={pubDate}
      updatedDate={updatedDate}
      author={author}
      tags={tags}
      hreflang={hreflang}
      breadcrumbs={breadcrumbs}
    />
  </head>
  <body>
    <Header lang={lang} />
    <main class:list={['relative z-10', padTop && 'pt-16']}>
      <slot />
    </main>
    <Footer lang={lang} />
    <Analytics />
    <SpeedInsights />

    <button id="back-to-top" aria-label="Back to top" title="Back to top">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
    </button>
  </body>
</html>

<style>
  #back-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: linear-gradient(135deg, #E8A4B0, #C47A8A);
    color: white;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 18px rgba(196, 122, 138, 0.45);
    opacity: 0;
    transform: translateY(12px) scale(0.9);
    transition: opacity 0.3s ease, transform 0.3s ease, background 0.2s ease, box-shadow 0.2s ease;
    pointer-events: none;
    z-index: 9000;
  }
  #back-to-top.visible {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }
  #back-to-top:hover {
    background: linear-gradient(135deg, #C47A8A, #9B5968);
    box-shadow: 0 6px 24px rgba(196, 122, 138, 0.6);
    transform: translateY(-2px) scale(1.05);
  }
  #back-to-top:active {
    transform: scale(0.96);
  }
</style>

<script>
  const btn = document.getElementById('back-to-top');
  if (btn) {
    window.addEventListener('scroll', () => {
      btn.classList.toggle('visible', window.scrollY > 400);
    }, { passive: true });
    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }

  // Scroll-reveal for post cards
  (function () {
    const cards = Array.from(document.querySelectorAll('.post-card')) as HTMLElement[];
    if (!('IntersectionObserver' in window) || !cards.length) return;

    cards.forEach((c) => {
      c.style.opacity = '0';
      c.style.transform = 'translateY(22px)';
      c.style.transition = 'opacity 0.55s ease, transform 0.55s ease';
    });

    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          el.style.opacity = '1';
          el.style.transform = '';
          setTimeout(() => {
            el.style.transition = '';
          }, 650);
          obs.unobserve(el);
        });
      },
      { threshold: 0.08, rootMargin: '0px 0px -30px 0px' }
    );

    cards.forEach((c) => obs.observe(c));
  })();
</script>