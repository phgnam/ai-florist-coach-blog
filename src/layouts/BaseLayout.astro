---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  padTop?: boolean;
}

const { title, description, image, type, padTop = true } = Astro.props;
---
<!doctype html>
<html lang="vi">
  <head>
    <SEO title={title} description={description} image={image} type={type} />
  </head>
  <body>
    <Header />
    <main class:list={['relative z-10', padTop && 'pt-16']}>
      <slot />
    </main>
    <Footer />
  </body>
</html>
