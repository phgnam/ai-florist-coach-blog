---
import FormattedDate from './FormattedDate.astro';
import { useTranslations } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
  heroImage?: ImageMetadata;
  heroImageUrl?: string;
  previewImageUrl?: string;
  heroAlt?: string;
  featured?: boolean;
  readingTime?: number;
}

const { title, description, pubDate, slug, tags = [], heroImage, heroImageUrl, previewImageUrl, heroAlt, featured = false, readingTime } = Astro.props;
const lang = Astro.currentLocale === 'vi' ? 'vi' : 'en';
const t = useTranslations(lang);
const href = slug.startsWith('/') ? slug : `/posts/${slug}`;

const cardGradients = [
  'from-[#F5C8D2] to-[#EDA8B8]',
  'from-[#EDA8B8] to-[#C47A8A]',
  'from-[#F0E2D0] to-[#E8A4B0]',
  'from-[#F5E6EA] to-[#C47A8A]',
];
const colorIdx = Math.abs(title.charCodeAt(0) + title.charCodeAt(1)) % 4;
---

<article class:list={['post-card', featured && 'post-card--featured']}>
  <a href={href} class="card-image-link" aria-hidden="true" tabindex="-1">
    <div class="card-image-wrap">
      {heroImage ? (
        <img src={heroImage.src} alt={heroAlt ?? title} width={heroImage.width} height={heroImage.height} class="card-image" loading="lazy" onerror="this.style.display='none';this.nextElementSibling&&this.nextElementSibling.classList.add('visible')" />
      ) : previewImageUrl ? (
        <img src={previewImageUrl} alt={heroAlt ?? title} class="card-image" loading="lazy" onerror="this.style.display='none';var p=this.parentElement.querySelector('.card-placeholder');if(p)p.style.display='flex'" />
      ) : heroImageUrl ? (
        <img src={heroImageUrl} alt={heroAlt ?? title} class="card-image" loading="lazy" onerror="this.style.display='none';var p=this.parentElement.querySelector('.card-placeholder');if(p)p.style.display='flex'" />
      ) : null}
      <div class={`card-placeholder bg-gradient-to-br ${cardGradients[colorIdx]}`} style={(heroImage || previewImageUrl || heroImageUrl) ? 'display:none' : ''}>
        <span class="placeholder-icon">🌸</span>
      </div>
      <div class="card-overlay"></div>
      {tags.length > 0 && (
        <div class="card-tag-badge">
          <span>{tags[0]}</span>
        </div>
      )}
    </div>
  </a>

  <div class="card-body">
    <div class="card-meta">
      <FormattedDate date={pubDate} lang={lang} />
      {readingTime && (
        <>
          <span class="meta-dot">·</span>
          <span>{readingTime} {t('post.readingTime')}</span>
        </>
      )}
    </div>
    <h2 class:list={['card-title', featured && 'card-title--featured']}>
      <a href={href} class="card-title-link">{title}</a>
    </h2>
    <p class="card-desc">{description}</p>
    <a href={href} class="card-cta">
      {t('posts.readMore')}
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="card-arrow">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</article>

<style>
  .post-card {
    background: rgba(255, 255, 255, 0.86);
    border-radius: 22px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 8px 24px rgba(196,122,138,0.09);
    border: 1px solid rgba(232,164,176,0.24);
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.35s ease, border-color 0.25s ease, background 0.25s ease;
    position: relative;
    backdrop-filter: blur(8px);
  }
  .post-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 18px 42px rgba(196,122,138,0.16);
    border-color: rgba(196,122,138,0.34);
    background: rgba(255, 255, 255, 0.94);
  }
  .post-card--featured {
    flex-direction: row;
    min-height: 280px;
  }
  .post-card--featured .card-image-link {
    flex: 0 0 45%;
  }
  .post-card--featured .card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2rem 2.5rem;
  }
  .post-card--featured .card-title--featured {
    font-size: 1.75rem;
    line-height: 1.2;
  }

  .card-image-link { display: block; text-decoration: none; }
  .card-image-wrap {
    position: relative;
    height: 210px;
    overflow: hidden;
  }
  .post-card--featured .card-image-wrap {
    height: 100%;
    min-height: 280px;
  }
  .card-image {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease, filter 0.35s ease;
  }
  .post-card:hover .card-image { transform: scale(1.07); filter: saturate(1.03) contrast(1.02); }
  .card-placeholder {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 3.5rem;
  }
  .placeholder-icon { filter: drop-shadow(0 3px 8px rgba(196,122,138,0.3)); }

  .card-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(74,45,53,0.12) 0%, transparent 50%);
    pointer-events: none;
  }
  .card-tag-badge {
    position: absolute;
    top: 12px; left: 12px;
    background: rgba(250,245,238,0.92);
    backdrop-filter: blur(8px);
    color: var(--blush-dark);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.28rem 0.75rem;
    border-radius: 999px;
    border: 1px solid rgba(232,164,176,0.4);
    font-family: 'Jost', sans-serif;
  }

  .card-body {
    padding: 1.35rem 1.45rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    flex: 1;
  }
  .card-meta {
    font-size: 0.72rem;
    color: var(--taupe);
    letter-spacing: 0.07em;
    font-weight: 300;
    font-family: 'Jost', sans-serif;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .meta-dot { color: var(--ivory-dark); }
  .card-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.18rem;
    font-weight: 600;
    line-height: 1.2;
    color: var(--mauve);
    margin: 0;
  }
  .card-title-link {
    text-decoration: none;
    color: inherit;
    transition: color 0.2s;
  }
  .card-title-link:hover { color: var(--blush-dark); }

  .card-desc {
    font-size: 0.9rem;
    color: var(--taupe);
    line-height: 1.7;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
    font-weight: 300;
    font-family: 'Jost', sans-serif;
  }

  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--blush-dark);
    text-decoration: none;
    margin-top: 0.35rem;
    font-family: 'Jost', sans-serif;
    transition: gap 0.2s ease, color 0.2s;
  }
  .card-cta:hover { color: var(--gold); gap: 9px; }
  .card-arrow { transition: transform 0.2s; }
  .card-cta:hover .card-arrow { transform: translateX(3px); }
</style>
