---
import FormattedDate from './FormattedDate.astro';
import TagList from './TagList.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
  heroImage?: ImageMetadata;
  heroAlt?: string;
}

const { title, description, pubDate, slug, tags = [], heroImage, heroAlt } = Astro.props;
---
<article class="flex flex-col rounded-2xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
  {heroImage && (
    <a href={`/posts/${slug}`}>
      <img src={heroImage.src} alt={heroAlt ?? title} class="w-full h-48 object-cover" width={heroImage.width} height={heroImage.height} />
    </a>
  )}
  <div class="p-5 flex flex-col gap-3 flex-1">
    <div class="text-sm text-gray-500">
      <FormattedDate date={pubDate} />
    </div>
    <h2 class="text-xl font-semibold leading-snug">
      <a href={`/posts/${slug}`} class="hover:text-rose-600 transition-colors">{title}</a>
    </h2>
    <p class="text-gray-600 text-sm flex-1">{description}</p>
    {tags.length > 0 && <TagList tags={tags} />}
  </div>
</article>
