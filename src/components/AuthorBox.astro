---
import { useTranslations } from '../i18n/utils';

interface Props {
  author: string;
  lang: 'en' | 'vi';
}

const { author, lang } = Astro.props;
const t = useTranslations(lang);

const bios: Record<string, { en: string; vi: string }> = {
  'Yor Flower': {
    en: 'Yor Flower is a companion blog to the AI Florist Coach app — sharing knowledge, inspiration, and craft for florists and flower lovers.',
    vi: 'Yor Flower là blog đồng hành của ứng dụng AI Florist Coach — chia sẻ kiến thức, cảm hứng và kỹ năng cho các florist và người yêu hoa.',
  },
};

const bio = (bios[author] ?? bios['Yor Flower'])[lang];
---

<div class="author-box">
  <div class="author-avatar" aria-hidden="true">🌸</div>
  <div class="author-info">
    <p class="author-label">{t('post.authorAbout')}</p>
    <p class="author-name">{author}</p>
    <p class="author-bio">{bio}</p>
  </div>
</div>

<style>
  .author-box {
    display: flex;
    align-items: flex-start;
    gap: 1.6rem;
    background: linear-gradient(110deg, rgba(255,255,255,0.95), rgba(253,240,242,0.8));
    border: 1px solid rgba(232,164,176,0.22);
    border-radius: 20px;
    padding: 1.85rem 2.1rem;
    margin-top: 3rem;
    box-shadow: 0 4px 24px rgba(196,122,138,0.07);
    position: relative;
    overflow: hidden;
  }
  .author-box::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px;
    height: 100%;
    background: linear-gradient(to bottom, var(--blush), var(--blush-dark));
    border-radius: 3px 0 0 3px;
  }
  .author-avatar {
    width: 62px;
    height: 62px;
    background: linear-gradient(135deg, #F5C8D2, #EDA8B8);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.65rem;
    flex-shrink: 0;
    box-shadow: 0 3px 12px rgba(196,122,138,0.2);
  }
  .author-info {
    flex: 1;
    min-width: 0;
  }
  .author-label {
    font-family: 'Jost', sans-serif;
    font-size: 0.63rem;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--gold);
    margin: 0 0 0.35rem;
  }
  .author-name {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--mauve);
    margin: 0 0 0.55rem;
    line-height: 1.18;
  }
  .author-bio {
    font-family: 'Jost', sans-serif;
    font-size: 0.87rem;
    color: var(--taupe);
    line-height: 1.72;
    margin: 0;
    font-weight: 300;
  }
</style>
