---
---
<button
  id="search-btn"
  class="text-gray-500 hover:text-rose-600 transition-colors"
  aria-label="Tìm kiếm"
>
  🔍
</button>

<dialog id="search-dialog" class="w-full max-w-2xl rounded-2xl p-6 backdrop:bg-black/40 shadow-xl">
  <button id="search-close" class="float-right text-gray-400 hover:text-gray-600 text-xl leading-none">&times;</button>
  <div id="search-container"></div>
</dialog>

<script>
  const btn = document.getElementById('search-btn');
  const dialog = document.getElementById('search-dialog') as HTMLDialogElement;
  const closeBtn = document.getElementById('search-close');

  btn?.addEventListener('click', async () => {
    if (!document.querySelector('#search-container link')) {
      const link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = '/pagefind/pagefind-ui.css';
      document.getElementById('search-container')!.prepend(link);

      const { PagefindUI } = await import('/pagefind/pagefind-ui.js' as any);
      new PagefindUI({ element: '#search-container', showSubResults: true });
    }
    dialog?.showModal();
  });

  closeBtn?.addEventListener('click', () => dialog?.close());
  dialog?.addEventListener('click', (e) => { if (e.target === dialog) dialog.close(); });
</script>
