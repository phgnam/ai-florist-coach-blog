---
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import type { Lang } from '../i18n/ui';

interface HreflangLink {
  lang: string;
  url: string;
}

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: URL;
  type?: 'website' | 'article';
  lang?: Lang;
  pubDate?: Date;
  updatedDate?: Date;
  author?: string;
  tags?: string[];
  hreflang?: HreflangLink[];
  breadcrumbs?: BreadcrumbItem[];
  noindex?: boolean;
  prevUrl?: string;
  nextUrl?: string;
}

const {
  title,
  description = SITE_DESCRIPTION,
  image = '',
  canonicalURL = new URL(Astro.url.pathname, Astro.site),
  type = 'website',
  lang = 'en',
  pubDate,
  updatedDate,
  author,
  tags = [],
  hreflang = [],
  breadcrumbs = [],
  noindex = false,
  prevUrl,
  nextUrl,
} = Astro.props;

const fullTitle = title ? `${title} | ${SITE_TITLE}` : SITE_TITLE;
const ogLocale = lang === 'vi' ? 'vi_VN' : 'en_US';
const siteUrl = (Astro.site?.toString() ?? import.meta.env.SITE_URL ?? 'https://ai-florist-coach-blog.vercel.app').replace(/\/$/, '');

const ogImage = image
  ? (image.startsWith('http') ? image : `${siteUrl}${image}`)
  : null;

const websiteSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "url": `${siteUrl}/`,
      "name": "Yor Flower",
      "description": "A blog about flowers and floristry, powered by AI Florist Coach.",
      "inLanguage": ["en", "vi"],
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": `${siteUrl}/posts?q={search_term_string}`
        },
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "Organization",
      "@id": `${siteUrl}/#organization`,
      "name": "Yor Flower",
      "url": `${siteUrl}/`,
      "logo": {
        "@type": "ImageObject",
        "url": `${siteUrl}/favicon.svg`,
        "width": 512,
        "height": 512
      }
    }
  ]
};

const articleSchema = (type === 'article' && pubDate) ? {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title ?? SITE_TITLE,
  "description": description,
  "author": {
    "@type": "Organization",
    "name": author ?? "Yor Flower",
    "url": siteUrl
  },
  "publisher": {
    "@type": "Organization",
    "name": "Yor Flower",
    "url": `${siteUrl}/`,
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/favicon.svg`
    }
  },
  "datePublished": pubDate.toISOString(),
  "dateModified": (updatedDate ?? pubDate).toISOString(),
  "url": canonicalURL.toString(),
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalURL.toString()
  },
  ...(ogImage ? { "image": ogImage } : {}),
  "keywords": tags.join(", "),
  "inLanguage": lang === 'vi' ? 'vi' : 'en'
} : null;

const breadcrumbSchema = breadcrumbs.length >= 2 ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbs.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.name,
    "item": item.url
  }))
} : null;
---
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="theme-color" content="#C47A8A" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="canonical" href={canonicalURL} />
{prevUrl && <link rel="prev" href={prevUrl} />}
{nextUrl && <link rel="next" href={nextUrl} />}
{noindex && <meta name="robots" content="noindex, follow" />}
<title>{fullTitle}</title>
<meta name="description" content={description} />
{tags.length > 0 && <meta name="keywords" content={tags.join(', ')} />}


<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:locale" content={ogLocale} />
<meta property="og:site_name" content="Yor Flower" />
{ogImage && <meta property="og:image" content={ogImage} />}
{ogImage && <meta property="og:image:width" content="1200" />}
{ogImage && <meta property="og:image:height" content="630" />}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={ogImage} />}

<!-- hreflang for multilingual -->
{hreflang.map(({ lang: l, url }) => (
  <link rel="alternate" hreflang={l} href={url} />
))}

<!-- Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
{articleSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
)}
{breadcrumbSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
)}
