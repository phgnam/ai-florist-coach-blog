---
interface Props {
  tags: string[];
}
const { tags } = Astro.props;
---
<ul class="flex flex-wrap gap-2 list-none p-0 m-0">
  {tags.map((tag) => (
    <li>
      <a
        href={`/tags/${tag}`}
        class="inline-block px-3 py-1 text-sm rounded-full bg-rose-100 text-rose-700 hover:bg-rose-200 transition-colors no-underline"
      >
        #{tag}
      </a>
    </li>
  ))}
</ul>
