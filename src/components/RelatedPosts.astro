---
import { useTranslations } from '../i18n/utils';
import FormattedDate from './FormattedDate.astro';

interface Post {
  id: string;
  data: {
    title: string;
    description: string;
    pubDate: Date;
    tags: string[];
    heroImage?: ImageMetadata;
    heroAlt?: string;
    draft?: boolean;
    lang?: string;
  };
  body: string;
}

interface Props {
  currentId: string;
  currentTags: string[];
  allPosts: Post[];
  lang: 'en' | 'vi';
  postBasePath: string;
}

const { currentId, currentTags, allPosts, lang, postBasePath } = Astro.props;
const t = useTranslations(lang);

const previewFallback = '/image_1777790654692.png';

const extractPreviewImage = (post: Post): string | null => {
  const bodyImg = post.body?.match(/<figure>[\s\S]*?<img[^>]+src="([^"]+)"/)?.[1] ?? null;
  if (bodyImg) return bodyImg;
  const hero = post.data.heroImage as any;
  if (!hero) return null;
  return typeof hero === 'string' ? hero : hero?.src ?? null;
};

const related = allPosts
  .filter((p) => p.id !== currentId)
  .map((p) => ({
    post: p,
    score: p.data.tags.filter((tag) => currentTags.includes(tag)).length,
  }))
  .filter(({ score }) => score > 0)
  .sort((a, b) => b.score - a.score || b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf())
  .slice(0, 3)
  .map(({ post }) => post);

if (related.length === 0) return;
---

<section class="related-posts">
  <div class="related-label">
    <span class="label-line"></span>
    <span class="label-text">{t('post.relatedPosts')}</span>
    <span class="label-line"></span>
  </div>
  <div class="related-grid">
    {related.map((post) => {
      const img = extractPreviewImage(post) ?? previewFallback;
      return (
        <a href={`${postBasePath}/${post.id}`} class="related-card">
          {img && (
            <div class="related-img-wrap">
              <img class="related-img" src={img} alt={post.data.title} loading="lazy" />
            </div>
          )}
          <div class="related-body">
            <span class="related-tag">{post.data.tags[0] ?? ''}</span>
            <h3 class="related-title">{post.data.title}</h3>
            <p class="related-desc">{post.data.description}</p>
            <span class="related-cta">{t('posts.readMore')} →</span>
          </div>
        </a>
      );
    })}
  </div>
</section>

<style>
  .related-posts {
    margin-top: 5.5rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--ivory-dark);
  }
  .related-label {
    display: flex;
    align-items: center;
    gap: 1.15rem;
    margin-bottom: 2.2rem;
  }
  .label-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--ivory-dark), transparent);
  }
  .label-text {
    font-family: 'Jost', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--taupe);
    white-space: nowrap;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    border-top: 1px solid rgba(232, 164, 176, 0.22);
    border-bottom: 1px solid rgba(232, 164, 176, 0.22);
    padding: 2rem 0;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-right: 1px solid rgba(232, 164, 176, 0.22);
    text-decoration: none;
    transition: transform 0.28s ease, opacity 0.28s ease;
    overflow: hidden;
  }
  .related-card:last-child { border-right: none; }
  .related-card:hover { opacity: 0.88; transform: translateY(-3px); }
  .related-card:hover .related-img { transform: scale(1.04); }

  .related-img-wrap {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 10px;
    margin-bottom: 1rem;
    background: var(--petal-mist);
  }
  .related-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.45s ease;
    display: block;
  }

  .related-body {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 0 1.4rem 0 0;
    flex: 1;
  }
  .related-card:last-child .related-body { padding-right: 0; }

  .related-tag {
    font-family: 'Jost', sans-serif;
    font-size: 0.64rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--taupe);
  }
  .related-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.18rem;
    font-weight: 600;
    color: var(--mauve);
    line-height: 1.2;
    margin: 0;
  }
  .related-desc {
    font-family: 'Jost', sans-serif;
    font-size: 0.86rem;
    color: var(--taupe);
    font-weight: 300;
    line-height: 1.7;
    margin: 0;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .related-cta {
    font-family: 'Jost', sans-serif;
    font-size: 0.74rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--blush-dark);
    text-transform: uppercase;
    margin-top: 0.1rem;
  }

  @media (max-width: 768px) {
    .related-grid {
      grid-template-columns: 1fr;
      gap: 0;
      padding: 0;
    }
    .related-card {
      border-right: none;
      border-bottom: 1px solid var(--ivory-dark);
      padding-bottom: 1.5rem;
      margin-bottom: 1.5rem;
    }
    .related-card:last-child { border-bottom: none; margin-bottom: 0; }
    .related-body { padding-right: 0; }
  }
</style>
