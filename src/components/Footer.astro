---
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { useTranslations, localePath } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = 'vi' } = Astro.props;
const t = useTranslations(lang);
const p = (path: string) => localePath(lang, path);
const year = new Date().getFullYear();
---
<footer class="footer-wrap mt-24">
  <div class="footer-body max-w-7xl mx-auto px-6 lg:px-10 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">

      <!-- Brand -->
      <div class="col-span-1 md:col-span-1">
        <a href={p('/')} class="footer-logo flex items-center gap-3 mb-4 no-underline">
          <span class="text-2xl">🌸</span>
          <span class="font-serif font-semibold text-xl footer-brand-name">Vườn Hoa</span>
        </a>
        <p class="footer-desc text-sm leading-relaxed">{t('site.description')}</p>
        <div class="flex gap-3 mt-6">
          <a href="/rss.xml" class="footer-badge">RSS</a>
          <a href="/sitemap-index.xml" class="footer-badge">Sitemap</a>
        </div>
      </div>

      <!-- Explore Links -->
      <div>
        <h4 class="footer-heading">{t('footer.explore')}</h4>
        <ul class="footer-links">
          <li><a href={p('/posts')}>{t('footer.allPosts')}</a></li>
          <li><a href={p('/tags')}>{t('footer.topics')}</a></li>
          <li><a href={p('/about')}>{t('footer.about')}</a></li>
        </ul>
      </div>

      <!-- Florist Resources -->
      <div>
        <h4 class="footer-heading">Florist Resources</h4>
        <ul class="footer-links">
          <li><a href="/learn/">Flower Glossary</a></li>
          <li><a href="/learn/rose/">Rose Guide</a></li>
          <li><a href="/learn/peony/">Peony Guide</a></li>
          <li><a href="/learn/dahlia/">Dahlia Guide</a></li>
          <li><a href="/learn/orchid/">Orchid Care</a></li>
          <li><a href="/tools/care-calculator/">Vase Life Calculator</a></li>
          <li><a href="/tools/season-planner/">Flower Season Planner</a></li>
        </ul>
      </div>

      <!-- Tagline -->
      <div>
        <h4 class="footer-heading">Vườn Hoa</h4>
        <p class="footer-desc text-sm leading-relaxed italic footer-quote">{t('footer.quote')}</p>
        <p class="footer-desc text-xs mt-4 opacity-60">{t('footer.companion')}</p>
      </div>
    </div>

    <div class="footer-divider mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="footer-desc text-xs">© {year} {SITE_TITLE}. {t('footer.rights')}</p>
      <p class="footer-desc text-xs opacity-50">Built with Astro · TailwindCSS · 🌸</p>
    </div>
  </div>

  <div class="h-1 bg-gradient-to-r from-blush-light via-blush to-gold-light"></div>
</footer>

<style>
  .footer-wrap {
    background: var(--mauve);
    position: relative;
    overflow: hidden;
  }
  .footer-wrap::before {
    content: '';
    position: absolute;
    top: -80px; right: -80px;
    width: 260px; height: 260px;
    background: radial-gradient(circle, rgba(232,164,176,0.1) 0%, transparent 70%);
    pointer-events: none;
  }
  .footer-wrap::after {
    content: '';
    position: absolute;
    bottom: -60px; left: -60px;
    width: 200px; height: 200px;
    background: radial-gradient(circle, rgba(200,149,106,0.07) 0%, transparent 70%);
    pointer-events: none;
  }
  .footer-logo { text-decoration: none; }
  .footer-brand-name { color: rgba(255,255,255,0.95); }
  .footer-heading {
    font-family: 'Jost', sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--blush);
    margin-bottom: 1rem;
    font-weight: 500;
  }
  .footer-desc { color: rgba(255,255,255,0.45); }
  .footer-quote { font-family: 'Cormorant Garamond', serif; font-size: 1rem; color: rgba(255,255,255,0.55); }
  .footer-links { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .footer-links a {
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    font-size: 0.88rem;
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--blush); }
  .footer-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border: 1px solid rgba(232,164,176,0.25);
    border-radius: 999px;
    color: rgba(255,255,255,0.45);
    font-size: 0.72rem;
    font-family: 'Jost', sans-serif;
    letter-spacing: 0.06em;
    text-decoration: none;
    transition: all 0.2s;
  }
  .footer-badge:hover { border-color: var(--blush); color: var(--blush); }
  .footer-divider { border-top: 1px solid rgba(232,164,176,0.1); }
</style>
