---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from './PostCard.astro';
import Pagination from './Pagination.astro';
import { useTranslations } from '../i18n/utils';
import { postsPageUrl } from '../lib/posts-pagination';
import type { CollectionEntry } from 'astro:content';
import { firstPreviewImage } from '../lib/postPreviewImage';

interface Props {
  lang: 'en' | 'vi';
  tag: string;
  posts: CollectionEntry<'posts'>[];
  currentPage: number;
  totalPages: number;
  totalPosts: number;
  basePath: string;
  postSlugPrefix: string;
}

const { lang, tag, posts, currentPage, totalPages, totalPosts, basePath, postSlugPrefix } = Astro.props;
const t = useTranslations(lang);

const siteUrl = (Astro.site?.toString() ?? import.meta.env.SITE_URL ?? 'https://ai-florist-coach-blog.vercel.app').replace(/\/$/, '');
const title = `#${tag}`;
const description = lang === 'vi' ? `Bài viết với chủ đề #${tag}` : `Articles with topic #${tag}`;
const pagedTitle = currentPage > 1 ? `${title} — ${t('posts.page')} ${currentPage}` : title;
const prevUrl = currentPage > 1 ? `${siteUrl}${postsPageUrl(basePath, currentPage - 1)}` : undefined;
const nextUrl = currentPage < totalPages ? `${siteUrl}${postsPageUrl(basePath, currentPage + 1)}` : undefined;
const noindex = currentPage > 1;
---
<BaseLayout
  lang={lang}
  title={pagedTitle}
  description={description}
  padTop={false}
  noindex={noindex}
  prevUrl={prevUrl}
  nextUrl={nextUrl}
>

  <div class="page-header">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 py-24 text-center" style="position:relative;z-index:2">
      <p class="page-eyebrow">{t('tags.topic')}</p>
      <h1 class="page-title">#{tag}</h1>
      <p class="page-sub">{totalPosts} {t('tags.posts')}</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 lg:px-10 py-14">
    <div class="posts-grid">
      {posts.map((post, idx) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          slug={`${postSlugPrefix}/${post.id}`}
          tags={post.data.tags}
          previewImageUrl={firstPreviewImage(post)}
          heroAlt={post.data.heroAlt}
          priority={idx === 0}
        />
      ))}
    </div>
    <Pagination currentPage={currentPage} totalPages={totalPages} basePath={basePath} lang={lang} />
    <div class="text-center mt-12">
      <a href={lang === 'vi' ? '/vi/tags' : '/tags'} class="back-link">{t('tags.back')}</a>
    </div>
  </div>
</BaseLayout>

<style>
  .page-header { background:linear-gradient(160deg,#FDF0F2 0%,#F5E6EA 50%,#EDA8B8 100%); position:relative; overflow:hidden; }
  .page-header::after { content:''; position:absolute; bottom:-1px; left:0; right:0; height:80px; background:linear-gradient(to top,var(--ivory),transparent); }
  .page-eyebrow { font-family:'Jost',sans-serif; font-size:0.68rem; font-weight:500; letter-spacing:0.3em; text-transform:uppercase; color:var(--gold); margin-bottom:1rem; }
  .page-title { font-family:'Cormorant Garamond',serif; font-size:clamp(2.8rem,7vw,5rem); font-weight:300; color:var(--mauve); line-height:1.08; margin:0 0 1rem; }
  .page-sub { font-family:'Jost',sans-serif; color:var(--mauve-mid); font-size:1rem; font-weight:300; line-height:1.7; }
  .posts-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:1.75rem; }
  .back-link { display:inline-block; padding:0.7rem 2rem; border:1px solid var(--ivory-dark); border-radius:999px; font-family:'Jost',sans-serif; color:var(--taupe); font-size:0.82rem; font-weight:400; text-decoration:none; transition:all 0.2s; }
  .back-link:hover { border-color:var(--blush-dark); color:var(--blush-dark); }
</style>
