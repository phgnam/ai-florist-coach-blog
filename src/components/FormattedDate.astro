---
interface Props {
  date: Date;
  lang?: 'en' | 'vi';
}
const { date, lang = 'vi' } = Astro.props;
const locale = lang === 'en' ? 'en-US' : 'vi-VN';
---
<time datetime={date.toISOString()}>
  {date.toLocaleString(locale, {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
    hourCycle: 'h23',
    timeZone: 'Asia/Ho_Chi_Minh',
  })}
</time>
